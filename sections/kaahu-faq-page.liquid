{{ 'section-kaahu-content-page.css' | asset_url | stylesheet_tag }}

<main class="kaahu-content-page kcp-content">
  <header class="kcp-hero kcp-wrap kcp-faq-wrap">
    <p class="kcp-eyebrow">{{ section.settings.eyebrow }}</p>
    <hr class="kcp-rule" aria-hidden="true">
    <h1>{{ section.settings.heading }}</h1>
    <div class="kcp-hero__lede kcp-rich">{{ section.settings.lede }}</div>
  </header>

  <nav class="kcp-jump kcp-wrap kcp-faq-wrap" aria-label="FAQ categories">
    {%- assign nav_seen = '|' -%}
    {%- for block in section.blocks -%}
      {%- assign nav_anchor = block.settings.category_anchor | handleize -%}
      {%- assign nav_token = nav_anchor | append: '|' | prepend: '|' -%}
      {%- unless nav_seen contains nav_token -%}
        <a href="#{{ nav_anchor }}">{{ block.settings.category_title }}</a>
        {%- assign nav_seen = nav_seen | append: nav_anchor | append: '|' -%}
      {%- endunless -%}
    {%- endfor -%}
  </nav>

  {%- assign category_seen = '|' -%}
  {%- for category_block in section.blocks -%}
    {%- assign category_anchor = category_block.settings.category_anchor | handleize -%}
    {%- assign category_token = category_anchor | append: '|' | prepend: '|' -%}
    {%- unless category_seen contains category_token -%}
      <section class="kcp-faq-category kcp-wrap kcp-faq-wrap" id="{{ category_anchor }}">
        <div class="kcp-faq-category__head">
          <p class="kcp-eyebrow">{{ category_block.settings.category_number }}</p>
          <h2>{{ category_block.settings.category_title }}</h2>
        </div>
        {%- for block in section.blocks -%}
          {%- assign item_anchor = block.settings.category_anchor | handleize -%}
          {%- if item_anchor == category_anchor -%}
            <details class="kcp-faq-item" {{ block.shopify_attributes }}>
              <summary>{{ block.settings.question }}</summary>
              <div class="kcp-answer kcp-rich">{{ block.settings.answer }}</div>
            </details>
          {%- endif -%}
        {%- endfor -%}
      </section>
      {%- assign category_seen = category_seen | append: category_anchor | append: '|' -%}
    {%- endunless -%}
    {%- endfor -%}

  <section class="kcp-close kcp-wrap kcp-faq-wrap">
    <div class="kcp-rich">{{ section.settings.close_text }}</div>
  </section>
</main>

{% schema %}
{
  "name": "Kaahu FAQ page",
  "tag": "section",
  "class": "section",
  "settings": [
    { "type": "text", "id": "eyebrow", "label": "Eyebrow", "default": "FAQ" },
    { "type": "text", "id": "heading", "label": "Heading", "default": "Questions, answered." },
    { "type": "richtext", "id": "lede", "label": "Intro text", "default": "<p>For anything not covered here, write to us at <a href=\"mailto:care@kaahu.us\">care@kaahu.us</a> - we respond within one business day.</p>" },
    { "type": "richtext", "id": "close_text", "label": "Closing text", "default": "<p>Still stuck? Write to <a href=\"mailto:care@kaahu.us\">care@kaahu.us</a> - a real person will get back to you within a business day.</p>" }
  ],
  "blocks": [
    {
      "type": "faq_item",
      "name": "FAQ item",
      "settings": [
        { "type": "text", "id": "category_number", "label": "Category number", "default": "01" },
        { "type": "text", "id": "category_title", "label": "Category title", "default": "Orders & shipping" },
        { "type": "text", "id": "category_anchor", "label": "Category anchor", "default": "orders" },
        { "type": "text", "id": "question", "label": "Question", "default": "Can I cancel or update my order?" },
        { "type": "richtext", "id": "answer", "label": "Answer", "default": "<p>You can cancel or update your order before it ships. Just email us at <a href=\"mailto:care@kaahu.us\">care@kaahu.us</a> with your order number. If your order has already shipped, we'll guide you through the return process.</p>" }
      ]
    }
  ],
  "presets": [
    { "name": "Kaahu FAQ page" }
  ]
}
{% endschema %}
