{{ 'section-kaahu-sustainability-page.css' | asset_url | stylesheet_tag }}

{%- liquid
  assign hero_alt = 'A Kaahu bag in everyday life'
  assign cotton_alt = 'Cotton boll on the plant'
  assign jute_alt = 'Bengal jute fiber'
  assign heritage_alt = 'Artisan craft and heritage textile work'
  assign planet_alt = '1% for the Planet'
  assign close_alt = 'Kaahu bag on a walk in nature'
-%}

<main class="kaahu-sustainability">
  <header class="ks-hero">
    <div class="ks-wrap">
      <p class="ks-eyebrow">Sustainability at Kaahu</p>
      <hr class="ks-rule" aria-hidden="true">
      <h1>What you carry should reflect what you value.</h1>
      <p class="ks-lede">So we account for it - at every stage. Here is what that means, in plain terms, including the parts we haven't finished yet.</p>
    </div>
    <div class="ks-wrap ks-hero-img">
      <div class="ks-frame ks-frame-wide">
        {%- if section.settings.hero_image != blank -%}
          {{ section.settings.hero_image | image_url: width: 1800 | image_tag: loading: 'eager', fetchpriority: 'high', alt: hero_alt }}
        {%- else -%}
          <img src="https://cdn.shopify.com/s/files/1/0709/9046/3195/files/20241021-DSC01765.jpg?v=1781672547" alt="{{ hero_alt | escape }}" width="1800" height="900" loading="eager" fetchpriority="high">
        {%- endif -%}
      </div>
    </div>
  </header>

  <section class="ks-intro">
    <div class="ks-wrap ks-narrow">
      <p>Kaahu is shaped by the Hawaiian principle of <em>Malama</em> - to care for one's people, and for the land, air, and water that hold them. That care decides what we make, and how.</p>
      <p>We choose natural fibers, low-impact methods, and partners who meet real standards. And we would rather move slowly than overstate.</p>
    </div>
  </section>

  <div class="ks-band">
    <section class="ks-section ks-wrap">
      <div class="ks-section-head">
        <p class="ks-eyebrow">Materials</p>
        <h2>Two fibers, chosen for what they conserve.</h2>
      </div>
      <div class="ks-tiles">
        <article class="ks-tile">
          <div class="ks-frame ks-frame-tile">
            {%- if section.settings.cotton_image != blank -%}
              {{ section.settings.cotton_image | image_url: width: 900 | image_tag: loading: 'lazy', alt: cotton_alt }}
            {%- else -%}
              <img src="https://cdn.shopify.com/s/files/1/0709/9046/3195/files/cotton_flower.png?v=1781663097" alt="{{ cotton_alt | escape }}" width="900" height="1125" loading="lazy">
            {%- endif -%}
          </div>
          <div class="ks-tile-copy">
            <p class="ks-kicker">Certified organic cotton</p>
            <h3>Grown gently, from the seed up.</h3>
            <p>No synthetic pesticides, no GM seeds, and certified to the Global Organic Textile Standard. It uses up to 91% less water than conventional cotton.</p>
            <div class="ks-chips">
              <span class="ks-chip">GOTS-certified</span>
              <span class="ks-chip">Up to 91% less water</span>
            </div>
          </div>
        </article>

        <article class="ks-tile">
          <div class="ks-frame ks-frame-tile ks-illus">
            {%- if section.settings.jute_image != blank -%}
              {{ section.settings.jute_image | image_url: width: 900 | image_tag: loading: 'lazy', alt: jute_alt }}
            {%- else -%}
              <img src="https://cdn.shopify.com/s/files/1/0709/9046/3195/files/Jute.svg?v=1778783129" alt="{{ jute_alt | escape }}" width="420" height="420" loading="lazy">
            {%- endif -%}
          </div>
          <div class="ks-tile-copy">
            <p class="ks-kicker">Bengal jute</p>
            <h3>One of the lowest-impact fibers there is.</h3>
            <p>Rain-fed, harvested within six months, and gentle on the soil it grows in - a fiber with a quiet strength we fell for.</p>
            <div class="ks-chips">
              <span class="ks-chip">Rain-fed</span>
              <span class="ks-chip">6-month harvest</span>
              <span class="ks-chip">Builds soil health</span>
            </div>
          </div>
        </article>
      </div>
    </section>
  </div>

  <section class="ks-section ks-wrap">
    <div class="ks-split">
      <div class="ks-media">
        <div class="ks-frame ks-frame-port">
          {%- if section.settings.heritage_image != blank -%}
            {{ section.settings.heritage_image | image_url: width: 1100 | image_tag: loading: 'lazy', alt: heritage_alt }}
          {%- else -%}
            <img src="https://cdn.shopify.com/s/files/1/0709/9046/3195/files/Heritage.jpg?v=1778784669" alt="{{ heritage_alt | escape }}" width="900" height="1125" loading="lazy">
          {%- endif -%}
        </div>
      </div>
      <div class="ks-split-copy">
        <p class="ks-eyebrow">Hands &amp; lineage</p>
        <p class="ks-lead">Made by people, and named as such.</p>
        <p>Small mills and artisan cooperatives carry the work forward - jute looms in Bengal, cotton spinning in Gujarat. One bag even carries a note in Bengali script, written by our own family.</p>
        <div class="ks-chips">
          <span class="ks-chip">Bengal looms</span>
          <span class="ks-chip">Gujarat spinning</span>
        </div>
      </div>
    </div>
  </section>

  <div class="ks-band">
    <section class="ks-section ks-wrap">
      <div class="ks-section-head">
        <p class="ks-eyebrow">How it's made</p>
        <h2>Held to a standard, every step.</h2>
      </div>
      <div class="ks-rows">
        <div class="ks-row">
          <div class="ks-row-label">Dyes &amp; water</div>
          <div>
            <p>GOTS-approved low-impact dyes. Several partner mills run closed-loop systems that recycle process water rather than discharge it.</p>
            <div class="ks-chips">
              <span class="ks-chip">GOTS-approved dyes</span>
              <span class="ks-chip">Closed-loop water</span>
            </div>
          </div>
        </div>
        <div class="ks-row">
          <div class="ks-row-label">Fair, safe labor</div>
          <div>
            <p>We work only with SEDEX-audited suppliers - fair pay in local terms, safe conditions, no forced labor. If a facility falls short, we move on, even when it costs more.</p>
            <div class="ks-chips">
              <span class="ks-chip">SEDEX-audited</span>
              <span class="ks-chip">ISO 14001:2015</span>
            </div>
          </div>
        </div>
      </div>
    </section>
  </div>

  <section class="ks-give ks-wrap">
    <div class="ks-mark">
      {%- if section.settings.planet_image != blank -%}
        {{ section.settings.planet_image | image_url: width: 240 | image_tag: loading: 'lazy', alt: planet_alt }}
      {%- else -%}
        <img src="https://cdn.shopify.com/s/files/1/0709/9046/3195/files/1_white_small_f9740041-dc0f-40c0-86f3-ca1ff3c9be95.png?v=1781041085" alt="{{ planet_alt | escape }}" width="120" height="120" loading="lazy">
      {%- endif -%}
    </div>
    <p class="ks-eyebrow">Giving back</p>
    <h2>One percent of revenue. Not profit.</h2>
    <p>We are a member of <a href="https://www.onepercentfortheplanet.org/" target="_blank" rel="noopener">1% for the Planet</a>, so a portion of every purchase goes to vetted environmental organizations. The network has directed over <span class="ks-fig">$672 million</span> to climate and conservation work across more than 110 countries.</p>
  </section>

  <section class="ks-section ks-last ks-wrap">
    <div class="ks-last-inner">
      <p class="ks-eyebrow">Built to last</p>
      <p class="ks-lead">Sustainability without durability is just slower waste.</p>
      <p>So we design for real life and for repair - choosing materials for resilience and hardware for strength. Fewer, better things, made to be used rather than shelved.</p>
    </div>
  </section>

  <section class="ks-progress">
    <div class="ks-wrap ks-section">
      <p class="ks-eyebrow">In progress</p>
      <h2>What we're still working on.</h2>
      <p class="ks-progress-line">We don't claim perfection. A few things are underway, and we would rather name them than hide them.</p>
      <ul class="ks-todo">
        <li>Moving more partner mills onto renewable energy.</li>
        <li>Finalizing verified NGO partnerships for reforestation and mangrove restoration across South Asia - measurable, not symbolic.</li>
        <li>Lowering water, energy, and chemical use further, one mill at a time.</li>
      </ul>
    </div>
  </section>

  <section class="ks-close ks-wrap">
    <p>Have a question we haven't answered? Write to <a href="mailto:care@kaahu.us">care@kaahu.us</a>. We'll tell you what we know - and what we're still learning.</p>
    <p class="ks-sign">Because what you carry should reflect what you believe.</p>
  </section>

  <div class="ks-wrap ks-close-img">
    <div class="ks-frame ks-frame-wide">
      {%- if section.settings.close_image != blank -%}
        {{ section.settings.close_image | image_url: width: 1800 | image_tag: loading: 'lazy', alt: close_alt }}
      {%- else -%}
        <img src="https://cdn.shopify.com/s/files/1/0709/9046/3195/files/Seraph_feather_75640f40-c730-471d-abae-3fb1ddfd5318.jpg?v=1777861927" alt="{{ close_alt | escape }}" width="1800" height="900" loading="lazy">
      {%- endif -%}
    </div>
  </div>
</main>

{% schema %}
{
  "name": "Sustainability",
  "tag": "section",
  "class": "section",
  "settings": [
    {
      "type": "paragraph",
      "content": "The page copy and layout are fixed. Use these settings only to replace the images."
    },
    {
      "type": "image_picker",
      "id": "hero_image",
      "label": "Hero image"
    },
    {
      "type": "image_picker",
      "id": "cotton_image",
      "label": "Cotton image"
    },
    {
      "type": "image_picker",
      "id": "jute_image",
      "label": "Jute image"
    },
    {
      "type": "image_picker",
      "id": "heritage_image",
      "label": "Heritage image"
    },
    {
      "type": "image_picker",
      "id": "planet_image",
      "label": "1% for the Planet image"
    },
    {
      "type": "image_picker",
      "id": "close_image",
      "label": "Closing image"
    }
  ],
  "presets": [
    {
      "name": "Sustainability"
    }
  ]
}
{% endschema %}
