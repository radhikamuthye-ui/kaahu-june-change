      "type": "image_picker",
      "id": "close_image",
      "label": "Close image"
    },
    {
      "type": "text",
      "id": "close_image_alt",
      "label": "Close image alt text"
    }
  ],
  "presets": [
    {
      "name": "Sustainability"
    }
  ]
}
{% endschema %}
