<section
  class="editorial-polaroid-band"
  data-editorial-polaroid-band
  data-settings='{{ section.settings | json | escape }}'
  style="
    --epb-left-width: {{ section.settings.left_width_percent }}%;
    --epb-height: {{ section.settings.section_height_px }}px;
    --epb-polaroid-desktop: {{ section.settings.desktop_polaroid_size_px }}px;
    --epb-polaroid-mobile: {{ section.settings.mobile_polaroid_size_px }}px;
    --epb-polaroid-padding: {{ section.settings.polaroid_padding_px }}px;
    --epb-polaroid-bottom: {{ section.settings.polaroid_bottom_px }}px;
    --epb-video-opacity: {{ section.settings.video_opacity_percent | default: 100 | divided_by: 100.0 }};
    --epb-mobile-margin: {{ section.settings.mobile_margin_px | default: 0 }}px;
    --epb-mobile-aspect-ratio: {{ section.settings.mobile_media_aspect_ratio | default: '4 / 5' }};
    --epb-content-bg: {{ section.settings.content_background_color | default: '#ffffff' }};
    --epb-eyebrow-color: {{ section.settings.eyebrow_color | default: '#7a6a52' }};
    --epb-eyebrow-size-desktop: {{ section.settings.eyebrow_size_desktop | default: 11 }}px;
    --epb-eyebrow-size-mobile: {{ section.settings.eyebrow_size_mobile | default: 11 }}px;
    --epb-eyebrow-weight: {{ section.settings.eyebrow_weight | default: '500' }};
    --epb-eyebrow-letter-spacing: {{ section.settings.eyebrow_letter_spacing | default: 14 | divided_by: 100.0 }}em;
    --epb-headline-color: {{ section.settings.headline_color | default: '#242424' }};
    --epb-headline-size-desktop: {{ section.settings.headline_size_desktop | default: 34 }}px;
    --epb-headline-size-mobile: {{ section.settings.headline_size_mobile | default: 26 }}px;
    --epb-headline-weight: {{ section.settings.headline_weight | default: '500' }};
    --epb-headline-line-height: {{ section.settings.headline_line_height | default: 110 | divided_by: 100.0 }};
    --epb-headline-letter-spacing: {{ section.settings.headline_letter_spacing | default: -2 | divided_by: 100.0 }}em;
    --epb-body-color: {{ section.settings.body_color | default: '#242424' }};
    --epb-body-opacity: {{ section.settings.body_opacity_percent | default: 65 | divided_by: 100.0 }};
    --epb-body-size-desktop: {{ section.settings.body_size_desktop | default: 14 }}px;
    --epb-body-size-mobile: {{ section.settings.body_size_mobile | default: 14 }}px;
    --epb-body-weight: {{ section.settings.body_weight | default: '400' }};
    --epb-body-line-height: {{ section.settings.body_line_height | default: 165 | divided_by: 100.0 }};
    --epb-body-max-width: {{ section.settings.body_max_width | default: 300 }}px;
    --epb-cta-color: {{ section.settings.cta_color | default: '#242424' }};
    --epb-cta-size-desktop: {{ section.settings.cta_size_desktop | default: 13 }}px;
    --epb-cta-size-mobile: {{ section.settings.cta_size_mobile | default: 13 }}px;
    --epb-cta-weight: {{ section.settings.cta_weight | default: '500' }};
    --epb-control-size: {{ section.settings.slider_control_size_px | default: 24 }}px;
    --epb-control-icon-size: {{ section.settings.slider_icon_size_px | default: 18 }}px;
    --epb-control-bg-opacity: {{ section.settings.slider_control_bg_opacity | default: 14 | divided_by: 100.0 }};
    --epb-control-border-opacity: {{ section.settings.slider_control_border_opacity | default: 22 | divided_by: 100.0 }};
    --epb-slider-track-height: {{ section.settings.slider_track_height_px | default: 3 }}px;
    --epb-slider-thumb-size: {{ section.settings.slider_thumb_size_px | default: 12 }}px;
    --epb-slider-color: {{ section.settings.slider_color | default: '#ffffff' }};
    --epb-slider-track-opacity: {{ section.settings.slider_track_opacity | default: 45 | divided_by: 100.0 }};
  "
>
  <div class="editorial-polaroid-band__inner">
    <div class="editorial-polaroid-band__media">
      {% if section.settings.video != blank %}
        {{
          section.settings.video
          | video_tag:
            class: 'editorial-polaroid-band__video',
            image_size: '1800x',
            autoplay: true,
            muted: true,
            loop: true,
            controls: false,
            playsinline: true,
            preload: 'metadata'
        }}
      {% elsif section.settings.fallback_image != blank %}
        {{
          section.settings.fallback_image
          | image_url: width: 1800
          | image_tag:
            loading: 'lazy',
            sizes: '(min-width: 768px) 58vw, 100vw',
            widths: '375, 550, 750, 1100, 1500, 1800',
            class: 'editorial-polaroid-band__fallback-image'
        }}
      {% endif %}

      <div
        class="editorial-polaroid-band__polaroids"
        data-polaroids
        data-blocks='{{ section.blocks | json | escape }}'
      >
        {% for block in section.blocks %}
          {% if block.type == 'polaroid' and block.settings.image != blank %}
            <div
              class="editorial-polaroid-band__polaroid"
              data-polaroid
              data-index="{{ forloop.index0 }}"
              style="z-index: {{ block.settings.z_index | default: forloop.index }};"
              {{ block.shopify_attributes }}
            >
              {{
                block.settings.image
                | image_url: width: 500
                | image_tag:
                  loading: 'lazy',
                  sizes: '(min-width: 768px) 220px, 150px',
                  widths: '100, 150, 220, 300, 400, 500',
                  class: 'editorial-polaroid-band__polaroid-image'
              }}
            </div>
          {% endif %}
        {% endfor %}
      </div>

      {% if section.blocks.size > 0 %}
        <div class="editorial-polaroid-band__controls">
          <button class="editorial-polaroid-band__control" type="button" aria-label="Pause animation" data-animation-toggle>
            <span class="editorial-polaroid-band__icon editorial-polaroid-band__icon--pause" data-icon-pause aria-hidden="true">
              <svg viewBox="0 0 28 28" focusable="false">
                <rect x="9" y="7" width="3" height="14" rx="0.5"></rect>
                <rect x="16" y="7" width="3" height="14" rx="0.5"></rect>
              </svg>
            </span>
            <span class="editorial-polaroid-band__icon editorial-polaroid-band__icon--play" data-icon-play aria-hidden="true">
              <svg viewBox="0 0 28 28" focusable="false">
                <path d="M10 7.5v13l10-6.5-10-6.5z"></path>
              </svg>
            </span>
          </button>
          <button class="editorial-polaroid-band__control" type="button" aria-label="Replay animation" data-animation-replay>
            <svg viewBox="0 0 28 28" focusable="false">
              <path d="M14 6a8 8 0 1 1-7.48 5.16l1.88.68A6 6 0 1 0 14 8h-1.3l1.9 1.9-1.4 1.4L8.9 7l4.3-4.3 1.4 1.4L12.7 6H14z"></path>
            </svg>
          </button>
          <input
            class="editorial-polaroid-band__timeline"
            type="range"
            min="0"
            max="100"
            step="0.01"
            value="0"
            aria-label="Video timeline"
            data-animation-timeline
          >
        </div>
      {% endif %}
    </div>

    <div class="editorial-polaroid-band__content">
      <div class="editorial-polaroid-band__content-inner">
        {% if section.settings.eyebrow_text != blank %}
          <p class="editorial-polaroid-band__eyebrow">{{ section.settings.eyebrow_text }}</p>
        {% endif %}

        {% if section.settings.headline != blank %}
          <h2 class="editorial-polaroid-band__headline">{{ section.settings.headline | newline_to_br }}</h2>
        {% endif %}

        {% if section.settings.body_text != blank %}
          <div class="editorial-polaroid-band__body">{{ section.settings.body_text | newline_to_br }}</div>
        {% endif %}

        {% if section.settings.cta_label != blank and section.settings.cta_url != blank %}
          <a class="editorial-polaroid-band__cta" href="{{ section.settings.cta_url }}">{{ section.settings.cta_label }}</a>
        {% endif %}
      </div>
    </div>
  </div>
</section>

<style>
  #shopify-section-{{ section.id }} {
    display: block;
  }

  #shopify-section-{{ section.id }} .editorial-polaroid-band {
    width: 100%;
    overflow: hidden;
    background: var(--color-background, #fff);
  }

  #shopify-section-{{ section.id }} .editorial-polaroid-band__inner {
    display: flex;
    width: 100%;
    min-height: var(--epb-height);
  }

  #shopify-section-{{ section.id }} .editorial-polaroid-band__content {
    order: 1;
    width: var(--epb-left-width);
    min-height: var(--epb-height);
    padding: 56px 48px;
    display: flex;
    align-items: center;
    background: var(--epb-content-bg);
    color: var(--epb-headline-color);
  }

  #shopify-section-{{ section.id }} .editorial-polaroid-band__content-inner {
    display: flex;
    flex-direction: column;
    gap: 18px;
    width: 100%;
  }

  #shopify-section-{{ section.id }} .editorial-polaroid-band__eyebrow {
    margin: 0;
    font-size: var(--epb-eyebrow-size-desktop);
    line-height: 1.2;
    letter-spacing: var(--epb-eyebrow-letter-spacing);
    text-transform: uppercase;
    color: var(--epb-eyebrow-color);
    font-weight: var(--epb-eyebrow-weight);
  }

  #shopify-section-{{ section.id }} .editorial-polaroid-band__headline {
    margin: 0;
    font-family: var(--font-heading-family);
    font-size: var(--epb-headline-size-desktop);
    font-weight: var(--epb-headline-weight);
    line-height: var(--epb-headline-line-height);
    letter-spacing: var(--epb-headline-letter-spacing);
    color: var(--epb-headline-color);
  }

  #shopify-section-{{ section.id }} .editorial-polaroid-band__body {
    max-width: var(--epb-body-max-width);
    font-size: var(--epb-body-size-desktop);
    font-weight: var(--epb-body-weight);
    line-height: var(--epb-body-line-height);
    color: var(--epb-body-color);
    opacity: var(--epb-body-opacity);
  }

  #shopify-section-{{ section.id }} .editorial-polaroid-band__body p {
    margin: 0;
  }

  #shopify-section-{{ section.id }} .editorial-polaroid-band__cta {
    width: fit-content;
    font-size: var(--epb-cta-size-desktop);
    font-weight: var(--epb-cta-weight);
    color: var(--epb-cta-color);
    text-decoration: underline;
    text-underline-offset: 4px;
  }

  #shopify-section-{{ section.id }} .editorial-polaroid-band__media {
    order: 2;
    position: relative;
    width: calc(100% - var(--epb-left-width));
    min-height: var(--epb-height);
    overflow: hidden;
    background: #1a1612;
  }

  #shopify-section-{{ section.id }} .editorial-polaroid-band__video,
  #shopify-section-{{ section.id }} .editorial-polaroid-band__fallback-image {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  #shopify-section-{{ section.id }} .editorial-polaroid-band__video {
    opacity: var(--epb-video-opacity);
  }

  #shopify-section-{{ section.id }} .editorial-polaroid-band__polaroids {
    position: absolute;
    inset: 0;
    pointer-events: none;
  }

  #shopify-section-{{ section.id }} .editorial-polaroid-band__polaroid {
    position: absolute;
    width: var(--epb-polaroid-desktop);
    height: calc((var(--epb-polaroid-desktop) * 1.2) + var(--epb-polaroid-bottom));
    padding: var(--epb-polaroid-padding) var(--epb-polaroid-padding) var(--epb-polaroid-bottom);
    background: #fff;
    box-shadow: 0 6px 24px rgba(0, 0, 0, 0.45), 0 1px 6px rgba(0, 0, 0, 0.3);
    opacity: 0;
    will-change: left, top, transform, opacity;
  }

  #shopify-section-{{ section.id }} .editorial-polaroid-band__polaroid-image {
    display: block;
    width: 100%;
    height: calc(var(--epb-polaroid-desktop) * 1.2);
    object-fit: cover;
  }

  #shopify-section-{{ section.id }} .editorial-polaroid-band__controls {
    position: absolute;
    bottom: 14px;
    left: 14px;
    right: 14px;
    z-index: 30;
    display: flex;
    align-items: center;
    gap: 8px;
  }

  #shopify-section-{{ section.id }} .editorial-polaroid-band__control {
    width: var(--epb-control-size);
    height: var(--epb-control-size);
    padding: 0;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    border: 0.5px solid rgba(255, 255, 255, var(--epb-control-border-opacity));
    border-radius: 4px;
    background: rgba(255, 255, 255, var(--epb-control-bg-opacity));
    color: var(--epb-slider-color);
    cursor: pointer;
    flex: 0 0 auto;
  }

  #shopify-section-{{ section.id }} .editorial-polaroid-band__timeline {
    flex: 1 1 auto;
    min-width: 80px;
    height: var(--epb-control-size);
    accent-color: var(--epb-slider-color);
    cursor: pointer;
    background: transparent;
    -webkit-appearance: none;
    appearance: none;
  }

  #shopify-section-{{ section.id }} .editorial-polaroid-band__icon,
  #shopify-section-{{ section.id }} .editorial-polaroid-band__icon svg,
  #shopify-section-{{ section.id }} .editorial-polaroid-band__control > svg {
    display: block;
    width: var(--epb-control-icon-size);
    height: var(--epb-control-icon-size);
    fill: currentColor;
  }

  #shopify-section-{{ section.id }} .editorial-polaroid-band__timeline::-webkit-slider-runnable-track {
    height: var(--epb-slider-track-height);
    border-radius: 999px;
    background: rgba(255, 255, 255, var(--epb-slider-track-opacity));
  }

  #shopify-section-{{ section.id }} .editorial-polaroid-band__timeline::-webkit-slider-thumb {
    width: var(--epb-slider-thumb-size);
    height: var(--epb-slider-thumb-size);
    margin-top: calc((var(--epb-slider-track-height) - var(--epb-slider-thumb-size)) / 2);
    border: 0;
    border-radius: 999px;
    background: var(--epb-slider-color);
  }

  #shopify-section-{{ section.id }} .editorial-polaroid-band__timeline::-moz-range-track {
    height: var(--epb-slider-track-height);
    border-radius: 999px;
    background: rgba(255, 255, 255, var(--epb-slider-track-opacity));
  }

  #shopify-section-{{ section.id }} .editorial-polaroid-band__timeline::-moz-range-thumb {
    width: var(--epb-slider-thumb-size);
    height: var(--epb-slider-thumb-size);
    border: 0;
    border-radius: 999px;
    background: var(--epb-slider-color);
  }

  #shopify-section-{{ section.id }} .editorial-polaroid-band__icon--play {
    display: none;
  }

  #shopify-section-{{ section.id }} .editorial-polaroid-band__control.is-paused .editorial-polaroid-band__icon--pause {
    display: none;
  }

  #shopify-section-{{ section.id }} .editorial-polaroid-band__control.is-paused .editorial-polaroid-band__icon--play {
    display: block;
  }

  @media screen and (max-width: 767px) {
    #shopify-section-{{ section.id }} .editorial-polaroid-band {
      padding: var(--epb-mobile-margin);
    }

    #shopify-section-{{ section.id }} .editorial-polaroid-band__inner {
      flex-direction: column;
      min-height: 0;
    }

    #shopify-section-{{ section.id }} .editorial-polaroid-band__media {
      order: 2;
      width: 100%;
      aspect-ratio: var(--epb-mobile-aspect-ratio);
      min-height: 0;
    }

    #shopify-section-{{ section.id }} .editorial-polaroid-band__content {
      order: 1;
      width: 100%;
      min-height: auto;
      padding: 32px 24px;
    }

    #shopify-section-{{ section.id }} .editorial-polaroid-band__headline {
      font-size: var(--epb-headline-size-mobile);
    }

    #shopify-section-{{ section.id }} .editorial-polaroid-band__eyebrow {
      font-size: var(--epb-eyebrow-size-mobile);
    }

    #shopify-section-{{ section.id }} .editorial-polaroid-band__body {
      font-size: var(--epb-body-size-mobile);
    }

    #shopify-section-{{ section.id }} .editorial-polaroid-band__cta {
      font-size: var(--epb-cta-size-mobile);
    }

    #shopify-section-{{ section.id }} .editorial-polaroid-band__polaroid {
      width: var(--epb-polaroid-mobile);
      height: calc((var(--epb-polaroid-mobile) * 1.2) + var(--epb-polaroid-bottom));
    }

    #shopify-section-{{ section.id }} .editorial-polaroid-band__polaroid-image {
      height: calc(var(--epb-polaroid-mobile) * 1.2);
    }
  }
</style>

<script>
  (function () {
    var instances = window.editorialPolaroidBandInstances || new WeakMap();
    window.editorialPolaroidBandInstances = instances;

    function sr(seed) {
      var x = Math.sin(seed + 1) * 10000;
      return x - Math.floor(x);
    }

    function readJson(element, attribute, fallback) {
      try {
        return JSON.parse(element.getAttribute(attribute) || '');
      } catch (error) {
        return fallback;
      }
    }

    function toNumber(value, fallback) {
      var parsed = parseFloat(value);
      return Number.isFinite(parsed) ? parsed : fallback;
    }

    function getBlockSettings(blocks, index) {
      var block = blocks[index] || {};
      return block.settings || {};
    }

    function buildOrder(count) {
      return Array.from({ length: count }, function (_, index) {
        return index;
      }).sort(function (a, b) {
        return sr(a * 41 + 7) - sr(b * 41 + 7);
      });
    }

    function EditorialPolaroidBand(section) {
      this.section = section;
      this.media = section.querySelector('.editorial-polaroid-band__media');
      this.container = section.querySelector('[data-polaroids]');
      this.polaroids = Array.from(section.querySelectorAll('[data-polaroid]'));
      this.video = section.querySelector('video');
      this.timeline = section.querySelector('[data-animation-timeline]');
      this.settings = readJson(section, 'data-settings', {});
      this.blocks = this.container ? readJson(this.container, 'data-blocks', []) : [];
      this.hasPlayed = false;
      this.isPaused = false;
      this.isVisible = false;
      this.isScrubbing = false;
      this.lastVideoTime = 0;
      this.animations = [];
      this.timers = [];
      this.timelineFrame = null;
      this.resizeTimer = null;
      this.observer = null;
      this.onResize = this.onResize.bind(this);

      this.initAnimationControls();
      this.initTimeline();
      this.layout(false);
      this.observe();
      window.addEventListener('resize', this.onResize);
    }

    EditorialPolaroidBand.prototype.destroy = function () {
      window.removeEventListener('resize', this.onResize);
      if (this.observer) {
        this.observer.disconnect();
      }
      clearTimeout(this.resizeTimer);
      this.clearTimers();
      this.cancelAnimations();
      this.stopTimelineUpdates();
    };

    EditorialPolaroidBand.prototype.initAnimationControls = function () {
      var self = this;
      var toggle = this.section.querySelector('[data-animation-toggle]');
      var replay = this.section.querySelector('[data-animation-replay]');

      if (toggle) {
        toggle.addEventListener('click', function () {
          if (self.isPaused) {
            self.resume();
          } else {
            self.pause();
          }
        });
      }

      if (replay) {
        replay.addEventListener('click', function () {
          self.replay();
        });
      }
    };

    EditorialPolaroidBand.prototype.initTimeline = function () {
      var self = this;

      if (!this.timeline) {
        return;
      }

      this.timeline.addEventListener('input', function () {
        self.isScrubbing = true;
        if (self.video && Number.isFinite(self.video.duration) && self.video.duration > 0) {
          self.video.currentTime = toNumber(self.timeline.value, 0);
        }
      });

      this.timeline.addEventListener('change', function () {
        var value = toNumber(self.timeline.value, 0);
        self.isScrubbing = false;

        if (self.video && Number.isFinite(self.video.duration) && self.video.duration > 0) {
          self.video.currentTime = value;
          if (value <= 0.05) {
            self.replay();
          } else if (!self.isPaused) {
            self.video.play();
          }
        }
      });

      if (this.video) {
        this.video.addEventListener('loadedmetadata', function () {
          self.syncTimelineBounds();
        });

        this.video.addEventListener('timeupdate', function () {
          if (self.video.currentTime + 0.25 < self.lastVideoTime) {
            self.play();
          }
          self.lastVideoTime = self.video.currentTime;
        });
      }

      this.syncTimelineBounds();
      this.startTimelineUpdates();
    };

    EditorialPolaroidBand.prototype.syncTimelineBounds = function () {
      if (!this.timeline) {
        return;
      }

      if (this.video && Number.isFinite(this.video.duration) && this.video.duration > 0) {
        this.timeline.max = String(this.video.duration);
        this.timeline.step = '0.01';
        return;
      }

      this.timeline.max = String(this.getAnimationTotalDuration() / 1000);
      this.timeline.step = '0.01';
    };

    EditorialPolaroidBand.prototype.startTimelineUpdates = function () {
      var self = this;

      if (!this.timeline || this.timelineFrame) {
        return;
      }

      function tick() {
        if (!self.isScrubbing) {
          if (self.video && Number.isFinite(self.video.duration) && self.video.duration > 0) {
            self.timeline.max = String(self.video.duration);
            self.timeline.value = String(self.video.currentTime);
          }
        }
        self.timelineFrame = window.requestAnimationFrame(tick);
      }

      this.timelineFrame = window.requestAnimationFrame(tick);
    };

    EditorialPolaroidBand.prototype.stopTimelineUpdates = function () {
      if (this.timelineFrame) {
        window.cancelAnimationFrame(this.timelineFrame);
      }
      this.timelineFrame = null;
    };

    EditorialPolaroidBand.prototype.setToggleState = function () {
      var toggle = this.section.querySelector('[data-animation-toggle]');

      if (!toggle) {
        return;
      }

      toggle.classList.toggle('is-paused', this.isPaused);
      toggle.setAttribute('aria-label', this.isPaused ? 'Play animation' : 'Pause animation');
    };

    EditorialPolaroidBand.prototype.observe = function () {
      var self = this;

      if (!('IntersectionObserver' in window)) {
        this.play();
        return;
      }

      this.observer = new IntersectionObserver(function (entries) {
        entries.forEach(function (entry) {
          if (entry.isIntersecting) {
            self.isVisible = true;
            self.replay();
          } else {
            self.isVisible = false;
            self.reset();
          }
        });
      }, { threshold: 0.2 });

      this.observer.observe(this.section);
    };

    EditorialPolaroidBand.prototype.onResize = function () {
      var self = this;
      clearTimeout(this.resizeTimer);
      this.resizeTimer = setTimeout(function () {
        self.layout(self.hasPlayed);
      }, 150);
    };

    EditorialPolaroidBand.prototype.layout = function (settled) {
      if (!this.media || !this.polaroids.length) {
        return;
      }

      var panelWidth = this.media.clientWidth;
      var panelHeight = this.media.clientHeight;

      if (!panelWidth || !panelHeight) {
        return;
      }

      var count = this.polaroids.length;
      var isMobile = window.matchMedia('(max-width: 767px)').matches;
      var polW = toNumber(isMobile ? this.settings.mobile_polaroid_size_px : this.settings.desktop_polaroid_size_px, isMobile ? 75 : 115);
      var bottom = toNumber(this.settings.polaroid_bottom_px, 26);
      var totalH = (polW * 1.2) + bottom;
      var maxRotation = toNumber(this.settings.max_rotation_deg, 20);
      var radius = toNumber(this.settings.spread_radius_px, 95) * (isMobile ? 0.6 : 1);
      var chaos = toNumber(this.settings.throw_chaos, 60) / 100;
      var order = buildOrder(count);

      this.polaroids.forEach(function (polaroid, i) {
        var blockSettings = getBlockSettings(this.blocks, i);
        var center = this.getFinalCenter(i, count, panelWidth, panelHeight, radius, blockSettings);
        var finalRot = (sr(i * 7 + 1) * 2 - 1) * maxRotation;
        var rotationOverride = toNumber(blockSettings.rotation_deg, null);
        var zIndex = parseInt(blockSettings.z_index, 10);

        if (Number.isFinite(rotationOverride)) {
          finalRot = rotationOverride;
        }

        if (!Number.isFinite(zIndex) || zIndex < 1) {
          zIndex = i + 1;
        }

        var finalLeft = center.x - (polW / 2);
        var finalTop = center.y - (totalH / 2);
        var throwPosition = this.getThrowPosition(i, panelWidth, panelHeight, maxRotation, chaos);
        var step = order.indexOf(i);

        polaroid.style.zIndex = String(zIndex);
        polaroid.dataset.finalLeft = String(finalLeft);
        polaroid.dataset.finalTop = String(finalTop);
        polaroid.dataset.finalRot = String(finalRot);
        polaroid.dataset.throwLeft = String(throwPosition.x);
        polaroid.dataset.throwTop = String(throwPosition.y);
        polaroid.dataset.throwRot = String(throwPosition.rotation);
        polaroid.dataset.throwScale = String(throwPosition.scale);
        polaroid.dataset.step = String(step);

        if (settled) {
          polaroid.style.transition = 'none';
          polaroid.style.left = finalLeft + 'px';
          polaroid.style.top = finalTop + 'px';
          polaroid.style.transform = 'rotate(' + finalRot + 'deg) scale(1)';
          polaroid.style.opacity = '1';
        } else {
          this.placeAtThrow(polaroid);
        }
      }, this);
    };

    EditorialPolaroidBand.prototype.getFinalCenter = function (i, count, panelWidth, panelHeight, radius, blockSettings) {
      var cx = panelWidth * 0.5;
      var cy = panelHeight * 0.5;
      var baseAngle = (i / count) * Math.PI * 2 - Math.PI / 2;
      var jitter = (sr(i * 17 + 3) - 0.5) * (Math.PI * 2 / count) * 0.55;
      var angle = baseAngle + jitter;
      var rVar = 0.55 + sr(i * 11 + 5) * 0.9;
      var finalX = cx + Math.cos(angle) * radius * rVar;
      var finalY = cy + Math.sin(angle) * radius * rVar;
      var topOverride = toNumber(blockSettings.pos_top_percent, null);
      var leftOverride = toNumber(blockSettings.pos_left_percent, null);

      if (Number.isFinite(topOverride) && Number.isFinite(leftOverride)) {
        finalX = panelWidth * (leftOverride / 100);
        finalY = panelHeight * (topOverride / 100);
      }

      return { x: finalX, y: finalY };
    };

    EditorialPolaroidBand.prototype.getThrowPosition = function (i, panelWidth, panelHeight, maxRotation, chaos) {
      var zone = sr(i * 13 + 9);
      var tx;
      var ty;

      if (zone < 0.25) {
        tx = (-0.1 + sr(i * 3) * 0.3) * panelWidth;
        ty = (0.1 + sr(i * 5) * 0.8) * panelHeight;
      } else if (zone < 0.50) {
        tx = (0.7 + sr(i * 7) * 0.4) * panelWidth;
        ty = (0.1 + sr(i * 11) * 0.8) * panelHeight;
      } else if (zone < 0.75) {
        tx = (0.1 + sr(i * 9) * 0.8) * panelWidth;
        ty = (-0.1 + sr(i * 3) * 0.25) * panelHeight;
      } else {
        tx = (0.1 + sr(i * 11) * 0.8) * panelWidth;
        ty = (0.75 + sr(i * 7) * 0.35) * panelHeight;
      }

      var cx2 = (0.35 + sr(i * 19) * 0.3) * panelWidth;
      var cy2 = (0.35 + sr(i * 23) * 0.3) * panelHeight;

      return {
        x: tx * chaos + cx2 * (1 - chaos),
        y: ty * chaos + cy2 * (1 - chaos),
        rotation: (sr(i * 31 + 13) * 2 - 1) * (maxRotation + chaos * 35),
        scale: 0.75 + chaos * 0.35
      };
    };

    EditorialPolaroidBand.prototype.placeAtThrow = function (polaroid) {
      polaroid.style.transition = 'none';
      polaroid.style.left = polaroid.dataset.throwLeft + 'px';
      polaroid.style.top = polaroid.dataset.throwTop + 'px';
      polaroid.style.transform = 'rotate(' + polaroid.dataset.throwRot + 'deg) scale(' + polaroid.dataset.throwScale + ')';
      polaroid.style.opacity = '0';
    };

    EditorialPolaroidBand.prototype.clearTimers = function () {
      this.timers.forEach(function (timer) {
        window.clearTimeout(timer);
      });
      this.timers = [];
    };

    EditorialPolaroidBand.prototype.cancelAnimations = function () {
      this.animations.forEach(function (animation) {
        animation.cancel();
      });
      this.animations = [];
    };

    EditorialPolaroidBand.prototype.reset = function () {
      this.hasPlayed = false;
      this.clearTimers();
      this.cancelAnimations();
      this.layout(false);
    };

    EditorialPolaroidBand.prototype.replay = function () {
      this.isPaused = false;
      this.setToggleState();
      this.reset();
      if (this.video) {
        this.video.currentTime = 0;
        this.lastVideoTime = 0;
        this.video.play();
      }
      if (this.timeline) {
        this.timeline.value = '0';
      }
      this.play();
    };

    EditorialPolaroidBand.prototype.pause = function () {
      this.isPaused = true;
      this.setToggleState();
      if (this.video) {
        this.video.pause();
      }

      if (this.animations.length) {
        this.animations.forEach(function (animation) {
          animation.pause();
        });
        return;
      }

      this.polaroids.forEach(function (polaroid) {
        var computed = window.getComputedStyle(polaroid);
        polaroid.style.transition = 'none';
        polaroid.style.left = computed.left;
        polaroid.style.top = computed.top;
        polaroid.style.transform = computed.transform;
        polaroid.style.opacity = computed.opacity;
      });
      this.clearTimers();
    };

    EditorialPolaroidBand.prototype.resume = function () {
      this.isPaused = false;
      this.setToggleState();
      if (this.video) {
        this.video.play();
      }

      if (this.animations.length) {
        this.animations.forEach(function (animation) {
          animation.play();
        });
        return;
      }

      if (this.isVisible) {
        this.replay();
      }
    };

    EditorialPolaroidBand.prototype.getAnimationTotalDuration = function () {
      var throwDuration = toNumber(this.settings.throw_duration_ms, 700);
      var count = this.polaroids.length || 1;
      return ((count - 1) * 80) + throwDuration;
    };

    EditorialPolaroidBand.prototype.play = function () {
      this.hasPlayed = true;
      this.clearTimers();
      this.cancelAnimations();
      var self = this;
      var throwDuration = toNumber(this.settings.throw_duration_ms, 700);
      var appearDuration = Math.min(150, throwDuration * 0.45);
      var appearOffset = Math.max(0.05, Math.min(0.9, appearDuration / throwDuration));

      this.polaroids.forEach(function (polaroid) {
        var step = parseInt(polaroid.dataset.step, 10) || 0;
        var phaseOneDelay = step * 80;
        var keyframes = [
          {
            left: polaroid.dataset.throwLeft + 'px',
            top: polaroid.dataset.throwTop + 'px',
            transform: 'rotate(' + polaroid.dataset.throwRot + 'deg) scale(' + polaroid.dataset.throwScale + ')',
            opacity: 0,
            offset: 0
          },
          {
            left: polaroid.dataset.throwLeft + 'px',
            top: polaroid.dataset.throwTop + 'px',
            transform: 'rotate(' + polaroid.dataset.throwRot + 'deg) scale(' + polaroid.dataset.throwScale + ')',
            opacity: 1,
            offset: appearOffset
          },
          {
            left: polaroid.dataset.finalLeft + 'px',
            top: polaroid.dataset.finalTop + 'px',
            transform: 'rotate(' + polaroid.dataset.finalRot + 'deg) scale(1)',
            opacity: 1,
            offset: 1
          }
        ];

        this.placeAtThrow(polaroid);

        if (polaroid.animate) {
          var animation = polaroid.animate(keyframes, {
            duration: throwDuration,
            delay: phaseOneDelay,
            easing: 'cubic-bezier(0.22, 1, 0.36, 1)',
            fill: 'forwards'
          });

          if (this.isPaused) {
            animation.pause();
          }

          animation.addEventListener('finish', function () {
            polaroid.style.left = polaroid.dataset.finalLeft + 'px';
            polaroid.style.top = polaroid.dataset.finalTop + 'px';
            polaroid.style.transform = 'rotate(' + polaroid.dataset.finalRot + 'deg) scale(1)';
            polaroid.style.opacity = '1';
            animation.cancel();
            self.animations = self.animations.filter(function (item) {
              return item !== animation;
            });
          });

          this.animations.push(animation);
          return;
        }

        this.timers.push(window.setTimeout(function () {
          if (polaroid.closest('[data-editorial-polaroid-band]')) {
            polaroid.style.transition = 'opacity 0.15s ease';
            polaroid.style.opacity = '1';
          }
        }, phaseOneDelay));

        this.timers.push(window.setTimeout(function () {
          if (polaroid.closest('[data-editorial-polaroid-band]')) {
            var durationSeconds = throwDuration / 1000;
            polaroid.style.transition = 'left ' + durationSeconds + 's cubic-bezier(0.22, 1, 0.36, 1), top ' + durationSeconds + 's cubic-bezier(0.22, 1, 0.36, 1), transform ' + durationSeconds + 's cubic-bezier(0.22, 1, 0.36, 1)';
            polaroid.style.left = polaroid.dataset.finalLeft + 'px';
            polaroid.style.top = polaroid.dataset.finalTop + 'px';
            polaroid.style.transform = 'rotate(' + polaroid.dataset.finalRot + 'deg) scale(1)';
          }
        }, phaseOneDelay + appearDuration));
      }, this);
    };

    function initSection(section) {
      if (!section) {
        return;
      }

      var previous = instances.get(section);
      if (previous) {
        previous.destroy();
      }

      instances.set(section, new EditorialPolaroidBand(section));
    }

    function initAll(root) {
      Array.from((root || document).querySelectorAll('[data-editorial-polaroid-band]')).forEach(initSection);
    }

    if (document.readyState === 'loading') {
      document.addEventListener('DOMContentLoaded', function () {
        initAll(document);
      });
    } else {
      initAll(document);
    }

    document.addEventListener('shopify:section:load', function (event) {
      initAll(event.target);
    });

    document.addEventListener('shopify:section:unload', function (event) {
      Array.from(event.target.querySelectorAll('[data-editorial-polaroid-band]')).forEach(function (section) {
        var instance = instances.get(section);
        if (instance) {
          instance.destroy();
          instances.delete(section);
        }
      });
    });
  })();
</script>

