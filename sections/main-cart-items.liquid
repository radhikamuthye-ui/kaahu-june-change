{{ 'component-cart.css' | asset_url | stylesheet_tag }}
{{ 'component-cart-items.css' | asset_url | stylesheet_tag }}
{{ 'component-totals.css' | asset_url | stylesheet_tag }}
{{ 'component-price.css' | asset_url | stylesheet_tag }}
{{ 'component-discounts.css' | asset_url | stylesheet_tag }}
{{ 'component-loading-overlay.css' | asset_url | stylesheet_tag }}

{%- unless settings.cart_type == 'drawer' -%}
  <script src="{{ 'cart.js' | asset_url }}" defer="defer"></script>
{%- endunless -%}

<cart-items class="main-cart--items{% if cart == empty %} is-empty{% endif %} section-{{ section.id }}-padding">
  <div class="cart__warnings">
    <p class="cart__empty-text">{{ 'sections.cart.empty' | t }}</p>
  </div>

  <form action="{{ routes.cart_url }}" id="cart" class="cart__contents" method="post">
    <div class="cart__items" id="main-cart-items" data-id="{{ section.id }}">
      <div class="js-contents">
        {%- if cart != empty -%}
          <table class="cart-items">
            <caption class="visually-hidden">{{ 'sections.cart.title' | t }}</caption>
            <tbody>
              {%- for item in cart.items -%}
                <tr class="cart-item" id="CartItem-{{ item.index | plus: 1 }}">
                  <td class="cart-item__media">
                    {% if item.image %}
                      <a href="{{ item.url }}"> 
                        <div class="cart-item__image-wrapper cart-item-image-ratio-{{ settings.card_img_aspect_ratio }}">
                          {{ item.image | image_url: width: 300 | image_tag }}
                        </div>
                      </a>
                    {% endif %}
                  {% if item.product.gift_card? and item.image == blank %}
                  <a href="{{ item.url }}"> 
                  <div class="cart-item__image-container global-product-card-media-settings">
                    {% render 'gift-card-placeholder' %}
                  </div>
                  </a>
                  {% endif %}
                  </td>

                  <td class="cart-item__details">
                    {%- if settings.show_vendor -%}
                      <p class="cart-item__vendor">{{ item.product.vendor }}</p>
                    {%- endif -%}
                    {% if item.image %}
                      <p class="cart-item__product-title product-title-{{ settings.card_title_font }} h4 break">{{ item.product.title | escape }}</p>
                    {% else %}
                      <a href="{{ item.url }}" class="cart-item__product-title product-title-{{ settings.card_title_font }} h4 break">{{ item.product.title | escape }}</a>
                    {% endif %}
                    

                    {%- if item.original_price != item.final_price -%}
                      <div class="cart-item__discounted-prices">
                        <span class="visually-hidden">
                          {{ 'products.product.price.regular_price' | t }}
                        </span>
                        <s class="cart-item__old-price product-option">
                          {%- if item.variant.compare_at_price != blank and item.variant.compare_at_price > item.original_price -%}<span class="cart-item__compare_at_price">{{ item.variant.compare_at_price | money }}</span>{%- endif -%}{%- if item.variant.compare_at_price != blank and item.variant.compare_at_price > item.original_price -%}<span class="price-item--sale">{{ item.original_price | money }}</span>{%- else -%}{{ item.original_price | money }}{%- endif -%}
                        </s>
                        <span class="visually-hidden">
                          {{ 'products.product.price.sale_price' | t }}
                        </span>
                        <span class="cart-item__final-price product-option">
                          {{ item.final_price | money }}
                        </span>
                      </div>
                    {%- else -%}
                      <div class="product-option product-option-price">
                        {%- if item.variant.compare_at_price != blank and item.variant.compare_at_price > item.original_price -%}<span class="cart-item__compare_at_price">{{ item.variant.compare_at_price | money }}</span>{%- endif -%}{%- if item.variant.compare_at_price != blank and item.variant.compare_at_price > item.original_price -%}<span class="price-item--sale">{{ item.original_price | money }}</span>{%- else -%}{{ item.original_price | money }}{%- endif -%}
                      </div>
                    {%- endif -%}

                      {%- if item.variant.available and item.unit_price_measurement -%}
                        <div class="unit-price caption">
                          <span class="visually-hidden">{{ 'products.product.price.unit_price' | t }}</span>
                          {{ item.variant.unit_price | money }}
                          <span aria-hidden="true">/</span>
                          <span class="visually-hidden">&nbsp;{{ 'accessibility.unit_price_separator' | t }}&nbsp;</span>
                          {%- if item.variant.unit_price_measurement.reference_value != 1 -%}
                            {{- item.variant.unit_price_measurement.reference_value -}}
                          {%- endif -%}
                          {{ item.variant.unit_price_measurement.reference_unit }}
                        </div>
                      {%- endif -%}

                    {%- if item.product.has_only_default_variant == false or item.properties.size != 0 or item.selling_plan_allocation != nil -%}
                      <dl>
                        {%- if item.product.has_only_default_variant == false -%}
                          {%- for option in item.options_with_values -%}
                            <div class="product-option text-small">
                              <dt>{{ option.name }}: </dt>
                              <dd>{{ option.value }}</dd>
                            </div>
                          {%- endfor -%}
                        {%- endif -%}

                        {%- for property in item.properties -%}
                          {%- assign property_first_char = property.first | slice: 0 -%}
                          {%- if property.last != blank and property_first_char != '_' -%}
                            <div class="product-option text-small">
                              <dt>{{ property.first }}: </dt>
                              <dd>
                                {%- if property.last contains '/uploads/' -%}
                                  <a href="{{ property.last }}" class="link" target="_blank">
                                    {{ property.last | split: '/' | last }}
                                  </a>
                                {%- else -%}
                                  {{ property.last }}
                                {%- endif -%}
                              </dd>
                            </div>
                          {%- endif -%}
                        {%- endfor -%}
                      </dl>

                      <p class="product-option text-small">{{ item.selling_plan_allocation.selling_plan.name }}</p>
                    {%- endif -%}

                    <ul class="discounts list-unstyled" role="list" aria-label="{{ 'customer.order.discount' | t }}">
                      {%- for discount in item.discounts -%}
                        <li class="discounts__discount">
                        {{ 'customer.order.discount' | t }}:  {{ discount.title }}
                        </li>
                      {%- endfor -%}
                    </ul>
                      <div class="cart-item__quantity-wrapper{% if settings.cart_show_quantity == false %} cart-item-quantity-hidden{% endif %}">
                      <label class="visually-hidden" for="Quantity-{{ item.index | plus: 1 }}">
                        {{ 'products.product.quantity.label' | t }}
                      </label>
                      <quantity-input class="quantity qty-selector-border-style--{{ settings.qty_selector_border }}">
                        <button class="quantity__button no-js-hidden" name="minus" type="button">
                          <span class="visually-hidden">{{ 'products.product.quantity.decrease' | t: product: item.product.title | escape }}</span>
                          {% render 'icon-minus' %}
                        </button>
                        <input class="quantity__input"
                          type="number"
                          name="updates[]"
                          value="{{ item.quantity }}"
                          min="0"
                          aria-label="{{ 'products.product.quantity.input_label' | t: product: item.product.title | escape }}"
                          id="Quantity-{{ item.index | plus: 1 }}"
                          data-index="{{ item.index | plus: 1 }}"
                        >
                        <button class="quantity__button no-js-hidden" name="plus" type="button">
                          <span class="visually-hidden">{{ 'products.product.quantity.increase' | t: product: item.product.title | escape }}</span>
                          {% render 'icon-plus' %}
                        </button>
                      </quantity-input>

                    </div>
                    <div class="cart-item__error" id="Line-item-error-{{ item.index | plus: 1 }}" role="alert">
                      <small class="cart-item__error-text"></small>
                        <svg aria-hidden="true" focusable="false" class="icon icon-error" xmlns="http://www.w3.org/2000/svg" version="1.1" viewBox="0 0 16 16">
                          <path fill="currentColor" d="M13.657227,2.362305C10.538086-.756836,5.462402-.756836,2.343262,2.362305.832031,3.873047,0,5.882324,0,8.019043c0,2.137207.832031,4.145996,2.343262,5.656738,1.55957,1.55957,3.607422,2.338867,5.656738,2.338867,2.047852,0,4.097656-.779297,5.657227-2.338867,1.510742-1.510742,2.342773-3.519531,2.342773-5.656738,0-2.136719-.832031-4.145996-2.342773-5.656738ZM12.950195,12.96875c-2.729492,2.728516-7.17041,2.728516-9.899902,0-1.322266-1.322266-2.050293-3.080078-2.050293-4.949707s.728027-3.627441,2.050293-4.949707c1.364746-1.364258,3.156738-2.046875,4.949707-2.046875s3.584961.682617,4.950195,2.046875c2.728516,2.729492,2.729492,7.169922,0,9.899414Z"/>
                          <path fill="currentColor" d="M8,8.689453c.276367,0,.5-.223633.5-.5v-3.75c0-.276367-.223633-.5-.5-.5s-.5.223633-.5.5v3.75c0,.276367.223633.5.5.5Z"/>
                          <path fill="currentColor" d="M8,10.405457c-.564819,0-1.022705.457886-1.022705,1.022766,0,.564819.457886,1.022705,1.022705,1.022705s1.022705-.457886,1.022705-1.022705c0-.56488-.457886-1.022766-1.022705-1.022766Z"/>
                        </svg>
                    </div>
                      <cart-remove-button id="Remove-{{ item.index | plus: 1 }}" data-index="{{ item.index | plus: 1 }}">
                        <a href="{{ item.url_to_remove }}" class="cart-remove--button-link" aria-label="{{ 'sections.cart.remove_title' | t }}">
                          {% render 'icon-delete' %}{{ 'sections.cart.remove_title' | t }}
                        </a>
                      </cart-remove-button>
                  </td>

                  <td class="cart-item__totals right medium-hide large-up-hide">
                    <div class="loading-overlay hidden">
                      <div class="loading-overlay__spinner">
                        <svg aria-hidden="true" focusable="false" role="presentation" class="spinner" viewBox="0 0 66 66" xmlns="http://www.w3.org/2000/svg">
                          <circle class="path" fill="none" stroke-width="6" cx="33" cy="33" r="30"></circle>
                        </svg>
                      </div>
                    </div>
                    <div class="cart-item__price-wrapper">
                      {%- if item.original_line_price != item.final_line_price -%}
                        <dl class="cart-item__discounted-prices">
                          <dt class="visually-hidden">
                            {{ 'products.product.price.regular_price' | t }}
                          </dt>
                          <dd>
                            <s class="cart-item__old-price price price--end">
                              {{ item.original_line_price | money }}
                            </s>
                          </dd>
                          <dt class="visually-hidden">
                            {{ 'products.product.price.sale_price' | t }}
                          </dt>
                          <dd class="price price--end">
                            {{ item.final_line_price | money }}
                          </dd>
                        </dl>
                      {%- else -%}
                        <span class="price price--end">
                          {{ item.original_line_price | money }}
                        </span>
                      {%- endif -%}

                      {%- if item.variant.available and item.unit_price_measurement -%}
                        <div class="unit-price caption">
                          <span class="visually-hidden">{{ 'products.product.price.unit_price' | t }}</span>
                          {{ item.variant.unit_price | money }}
                          <span aria-hidden="true">/</span>
                          <span class="visually-hidden">&nbsp;{{ 'accessibility.unit_price_separator' | t }}&nbsp;</span>
                          {%- if item.variant.unit_price_measurement.reference_value != 1 -%}
                            {{- item.variant.unit_price_measurement.reference_value -}}
                          {%- endif -%}
                          {{ item.variant.unit_price_measurement.reference_unit }}
                        </div>
                      {%- endif -%}
                    </div>
                  </td>
                
                  <td class="cart-item__totals right small-hide">
                    <div class="loading-overlay hidden">
                      <div class="loading-overlay__spinner">
                        <svg aria-hidden="true" focusable="false" role="presentation" class="spinner" viewBox="0 0 66 66" xmlns="http://www.w3.org/2000/svg">
                          <circle class="path" fill="none" stroke-width="6" cx="33" cy="33" r="30"></circle>
                        </svg>
                      </div>
                    </div>

                    <div class="cart-item__price-wrapper">
                      {%- if item.original_line_price != item.final_line_price -%}
                        <dl class="cart-item__discounted-prices">
                          <dt class="visually-hidden">
                            {{ 'products.product.price.regular_price' | t }}
                          </dt>
                          <dd>
                            <s class="cart-item__old-price price price--end visually-hidden">
                              {{ item.original_line_price | money }}
                            </s>
                          </dd>
                          <dt class="visually-hidden">
                            {{ 'products.product.price.sale_price' | t }}
                          </dt>
                          <dd class="price price--end">
                            {{ item.final_line_price | money }}
                          </dd>
                        </dl>
                      {%- else -%}
                        <span class="price price--end">
                          {{ item.original_line_price | money }}
                        </span>
                      {%- endif -%}
                      {% comment %}
                      {%- if item.variant.available and item.unit_price_measurement -%}
                        <div class="unit-price caption">
                          <span class="visually-hidden">{{ 'products.product.price.unit_price' | t }}</span>
                          {{ item.variant.unit_price | money }}
                          <span aria-hidden="true">/</span>
                          <span class="visually-hidden">&nbsp;{{ 'accessibility.unit_price_separator' | t }}&nbsp;</span>
                          {%- if item.variant.unit_price_measurement.reference_value != 1 -%}
                            {{- item.variant.unit_price_measurement.reference_value -}}
                          {%- endif -%}
                          {{ item.variant.unit_price_measurement.reference_unit }}
                        </div>
                      {%- endif -%}
                      {% endcomment %}
                    </div>
                  </td>
                  
                </tr>
              {%- endfor -%}
            </tbody>
          </table>
        {%- endif -%}        
      </div>
    </div>

    <p class="visually-hidden" id="cart-live-region-text" aria-live="polite" role="status"></p>
    <p class="visually-hidden" id="shopping-cart-line-item-status" aria-live="polite" aria-hidden="true" role="status">{{ 'accessibility.loading' | t }}</p>   

  </form> 

{%- if settings.show_cart_note and cart != empty -%}
<div class="main-cart-footer-note-wrapper">
  <div class="main-cart-footer--note">
    <details>
      <summary>{{ 'sections.cart.note' | t }}
        {% if settings.accordion_icon == 'plus' %}
        <span class="icon--open">{% render 'icon-plus' %}</span>
        <span class="icon--close">{% render 'icon-minus' %}</span>            
        {% else %}
        <span class="icon--caret">{% render 'icon-caret' %}</span>              
        {% endif %}
      </summary>
      {% if settings.cart_note_description != blank %}
      <div class="cart-note--description text-body">
        {{ settings.cart_note_description }}
      </div>
      {% endif %}
      <cart-note class="cart__note field">
        <label class="cart-note__label" for="Cart-note">{{ 'sections.cart.note' | t }}</label>
        <textarea class="text-area field__input" name="note" form="cart" id="Cart-note" placeholder="{{ 'sections.cart.note_placeholder' | t }}">{{ cart.note }}</textarea>
        <div class="cart-note--buttons">
        <button type="button" class="button button--outline cart-note--clear">{{ 'sections.cart.note_clear' | t }}</button>
        <button type="button" class="button button--outline cart-note--save">{{ 'sections.cart.note_save' | t }}</button>
        </div>
      </cart-note>
    </details>
  </div>
</div>

<script>
document.addEventListener('click', function (event) {
  // Note Save Button
  const saveBtn = event.target.closest('.cart-note--save');
  if (saveBtn) {
    event.preventDefault();

    const details = saveBtn.closest('details');
    if (details) {
      details.removeAttribute('open');
    }
  }

  // Note Clear Button
  const clearBtn = event.target.closest('.cart-note--clear');
  if (clearBtn) {
    event.preventDefault();

    const container = clearBtn.closest('cart-note');
    const textarea = container ? container.querySelector('textarea') : null;

    if (textarea) {
      textarea.value = '';
      textarea.dispatchEvent(new Event('input', { bubbles: true }));
      textarea.dispatchEvent(new Event('change', { bubbles: true }));
    }
  }
});  
</script>

{%- endif -%}                        
</cart-items> 

{% schema %}
{
  "name": "t:sections.main-cart-items.name",
  "class": "cart__items-wrapper"
}
{% endschema %}
