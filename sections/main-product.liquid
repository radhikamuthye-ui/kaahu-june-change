          "id": "homepage_link",
          "default": false,
          "label": "t:sections.breadcrumb.settings.homepage_link.label"
        },
        {
          "type": "checkbox",
          "id": "use_collection_metafield",
          "default": true,
          "label": "Use collection breadcrumb metafield"
        },
        {
          "type": "text",
          "id": "collection_metafield_namespace",
          "default": "custom",
          "label": "Collection metafield namespace"
        },
        {
