                expanded_initial_state: care_expanded_initial_state,
                content: care_content
              %}

            {%- when 'sustainability_details' -%}
              {% assign sustain_details_expanded_initial_state = false %}
              {% if block.settings.open_by_default %}
                {% assign sustain_details_expanded_initial_state = true %}
              {% endif %}
              {% capture sustain_details_content %}
                    {% if block.settings.intro != blank %}
                      <div class="product-sustainability-details-block__intro">{{ block.settings.intro }}</div>
                    {% endif %}
                    <div class="product-sustainability-details-block__items">
                      {% if block.settings.item_1_title != blank or block.settings.item_1_text != blank or block.settings.item_1_image != blank %}
                        <div class="product-sustainability-details-block__item">
                          <div class="product-sustainability-details-block__badge">
                            {% if block.settings.item_1_image != blank %}
                              {{ block.settings.item_1_image | image_url: width: 220 | image_tag: loading: 'lazy' }}
                            {% else %}
                              <span>{{ block.settings.item_1_fallback }}</span>
                            {% endif %}
                          </div>
                          <div class="product-sustainability-details-block__copy">
                            {% if block.settings.item_1_title != blank %}
                              <h3>{{ block.settings.item_1_title }}</h3>
                            {% endif %}
                            {% if block.settings.item_1_text != blank %}
                              <div>{{ block.settings.item_1_text }}</div>
                            {% endif %}
                          </div>
                        </div>
                      {% endif %}
                      {% if block.settings.item_2_title != blank or block.settings.item_2_text != blank or block.settings.item_2_image != blank %}
                        <div class="product-sustainability-details-block__item">
                          <div class="product-sustainability-details-block__badge">
                            {% if block.settings.item_2_image != blank %}
                              {{ block.settings.item_2_image | image_url: width: 220 | image_tag: loading: 'lazy' }}
                            {% else %}
                              <span>{{ block.settings.item_2_fallback }}</span>
                            {% endif %}
                          </div>
                          <div class="product-sustainability-details-block__copy">
                            {% if block.settings.item_2_title != blank %}
                              <h3>{{ block.settings.item_2_title }}</h3>
                            {% endif %}
                            {% if block.settings.item_2_text != blank %}
                              <div>{{ block.settings.item_2_text }}</div>
                            {% endif %}
                          </div>
                        </div>
                      {% endif %}
                      {% if block.settings.item_3_title != blank or block.settings.item_3_text != blank or block.settings.item_3_image != blank %}
                        <div class="product-sustainability-details-block__item">
                          <div class="product-sustainability-details-block__badge">
                            {% if block.settings.item_3_image != blank %}
                              {{ block.settings.item_3_image | image_url: width: 220 | image_tag: loading: 'lazy' }}
                            {% else %}
                              <span>{{ block.settings.item_3_fallback }}</span>
                            {% endif %}
                          </div>
                          <div class="product-sustainability-details-block__copy">
                            {% if block.settings.item_3_title != blank %}
                              <h3>{{ block.settings.item_3_title }}</h3>
                            {% endif %}
                            {% if block.settings.item_3_text != blank %}
                              <div>{{ block.settings.item_3_text }}</div>
                            {% endif %}
                          </div>
                        </div>
                      {% endif %}
                      {% if block.settings.item_4_title != blank or block.settings.item_4_text != blank or block.settings.item_4_image != blank %}
                        <div class="product-sustainability-details-block__item">
                          <div class="product-sustainability-details-block__badge">
                            {% if block.settings.item_4_image != blank %}
                              {{ block.settings.item_4_image | image_url: width: 220 | image_tag: loading: 'lazy' }}
                            {% else %}
                              <span>{{ block.settings.item_4_fallback }}</span>
                            {% endif %}
                          </div>
                          <div class="product-sustainability-details-block__copy">
                            {% if block.settings.item_4_title != blank %}
                              <h3>{{ block.settings.item_4_title }}</h3>
                            {% endif %}
                            {% if block.settings.item_4_text != blank %}
                              <div>{{ block.settings.item_4_text }}</div>
                            {% endif %}
                          </div>
                        </div>
                      {% endif %}
                    </div>
              {% endcapture %}
              {% capture sustain_details_style %}
                --pdp-sustain-details-icon-size: {{ block.settings.badge_size }}px;
                --pdp-sustain-details-image-scale: {{ block.settings.badge_image_scale }}%;
                --pdp-sustain-details-icon-bg: {{ block.settings.badge_background_color }};
                --pdp-sustain-details-row-gap: {{ block.settings.row_gap }}px;
                --pdp-sustain-details-column-gap: {{ block.settings.column_gap }}px;
                --pdp-sustain-details-intro-bottom: {{ block.settings.intro_bottom_spacing }}px;
                --pdp-sustain-details-item-title-size: {{ block.settings.item_title_size }}px;
                --pdp-sustain-details-item-title-color: {{ block.settings.item_title_color }};
                --pdp-sustain-details-item-title-weight: {{ block.settings.item_title_weight }};
              {% endcapture %}
              {% render 'product-detail-accordion',
                block: block,
                section_settings: section.settings,
                section_id: section.id,
                panel_id: 'sustainability-panel',
                button_id: 'sustainability-button',
                extra_class: 'product-sustainability-details-block',
                extra_style: sustain_details_style,
                expanded_initial_state: sustain_details_expanded_initial_state,
                content: sustain_details_content
              %}

            {%- when 'shipping_returns' -%}
              {% assign shipping_returns_expanded_initial_state = false %}
              {% if block.settings.open_by_default %}
                {% assign shipping_returns_expanded_initial_state = true %}
              {% endif %}
              {% capture shipping_returns_content %}
                <div class="product-shipping-returns-block__body">{{ block.settings.body }}</div>
              {% endcapture %}
              {% render 'product-detail-accordion',
                block: block,
                section_settings: section.settings,
                section_id: section.id,
                panel_id: 'shipping-panel',
                button_id: 'shipping-button',
                extra_class: 'product-shipping-returns-block',
                expanded_initial_state: shipping_returns_expanded_initial_state,
                content: shipping_returns_content
              %}

            {%- when 'service_highlights' -%}
              <div
                class="product-service-highlights"
                style="
                  --pdp-service-margin-top: {{ block.settings.margin_top }}px;
                  --pdp-service-margin-bottom: {{ block.settings.margin_bottom }}px;
                  --pdp-service-border-color: {{ block.settings.border_color }};
                  --pdp-service-border-width: {{ block.settings.border_width }}px;
                  --pdp-service-radius: {{ block.settings.corner_radius }}px;
                  --pdp-service-bg: {{ block.settings.background_color }};
                  --pdp-service-row-padding-y: {{ block.settings.row_padding_vertical }}px;
                  --pdp-service-row-padding-x: {{ block.settings.row_padding_horizontal }}px;
                  --pdp-service-row-gap: {{ block.settings.row_gap }}px;
                  --pdp-service-icon-size: {{ block.settings.icon_size }}px;
                  --pdp-service-icon-color: {{ block.settings.icon_color }};
                  --pdp-service-title-size-mobile: {{ block.settings.title_size_mobile }}px;
                  --pdp-service-title-size-desktop: {{ block.settings.title_size_desktop }}px;
                  --pdp-service-title-weight: {{ block.settings.title_weight }};
                  --pdp-service-title-color: {{ block.settings.title_color }};
                  --pdp-service-body-size-mobile: {{ block.settings.body_size_mobile }}px;
                  --pdp-service-body-size-desktop: {{ block.settings.body_size_desktop }}px;
                  --pdp-service-body-color: {{ block.settings.body_color }};
                  --pdp-service-divider-color: {{ block.settings.divider_color }};
                "
                {{ block.shopify_attributes }}
              >
                {% for index in (1..3) %}
                  {% liquid
                    assign title_key = 'row_' | append: index | append: '_title'
                    assign text_key = 'row_' | append: index | append: '_text'
                    assign icon_key = 'row_' | append: index | append: '_icon'
                    assign row_title = block.settings[title_key]
                    assign row_text = block.settings[text_key]
                    assign row_icon = block.settings[icon_key]
                  %}
                  {% if row_title != blank or row_text != blank %}
                    <div class="product-service-highlights__row">
                      <div class="product-service-highlights__icon" aria-hidden="true">
                        {% case row_icon %}
                          {% when 'box' %}
                            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><path d="m21 8-9-5-9 5 9 5 9-5Z"/><path d="M3 8v8l9 5 9-5V8"/><path d="M12 13v8"/></svg>
                          {% when 'chat' %}
                            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><path d="M21 15a4 4 0 0 1-4 4H8l-5 3V7a4 4 0 0 1 4-4h10a4 4 0 0 1 4 4v8Z"/></svg>
                          {% when 'heart' %}
                            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><path d="M20.8 4.6a5.4 5.4 0 0 0-7.6 0L12 5.8l-1.2-1.2a5.4 5.4 0 1 0-7.6 7.6L12 21l8.8-8.8a5.4 5.4 0 0 0 0-7.6Z"/></svg>
                          {% when 'leaf' %}
                            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><path d="M11 20A7 7 0 0 1 4 13c0-6 8-10 16-10 0 8-4 16-10 16Z"/><path d="M4 21c4-7 9-10 16-18"/></svg>
                          {% when 'none' %}
                          {% else %}
                            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><path d="M3 7h11v9H3z"/><path d="M14 10h3l4 4v2h-7v-6Z"/><path d="M7 19a2 2 0 1 0 0-4 2 2 0 0 0 0 4Z"/><path d="M18 19a2 2 0 1 0 0-4 2 2 0 0 0 0 4Z"/></svg>
                        {% endcase %}
                      </div>
                      <div class="product-service-highlights__copy">
                        {% if row_title != blank %}
                          <h3>{{ row_title }}</h3>
                        {% endif %}
                        {% if row_text != blank %}
                          <p>{{ row_text }}</p>
                        {% endif %}
                      </div>
                    </div>
                  {% endif %}
                {% endfor %}
              </div>

            {%- when 'fit_dimensions' -%}
              {% liquid
                assign dimension_metafield = product.metafields[block.settings.metafield_namespace][block.settings.dimension_key]
                assign closure_metafield = product.metafields[block.settings.metafield_namespace][block.settings.closure_key]
                assign pockets_metafield = product.metafields[block.settings.metafield_namespace][block.settings.pockets_key]
                assign straps_metafield = product.metafields[block.settings.metafield_namespace][block.settings.straps_key]
                assign dimension_value = dimension_metafield.value | default: dimension_metafield | strip
                assign normalized_dimension = dimension_value | downcase | replace: '×', 'x'
                assign dimension_parts = normalized_dimension | split: 'x'
                assign height_value = dimension_parts[0] | strip
                assign depth_value = dimension_parts[1] | strip
                assign width_value = dimension_parts[2] | strip
                assign closure_value = closure_metafield.value | default: closure_metafield
                assign pockets_value = pockets_metafield.value | default: pockets_metafield
                assign straps_value = straps_metafield.value | default: straps_metafield
                assign dimensions_media = blank
                assign alt_label = block.settings.image_alt_label | upcase
                for media in product.media
                  assign media_alt = media.alt | upcase
                  if dimensions_media == blank and media.media_type == 'image' and media_alt contains alt_label
                    assign dimensions_media = media
                  endif
                endfor
                assign fit_has_content = false
                assign fit_has_fields = false
                if width_value != blank or height_value != blank or depth_value != blank or closure_value != blank or pockets_value != blank or straps_value != blank or dimensions_media != blank
                  assign fit_has_content = true
                endif
                if width_value != blank or height_value != blank or depth_value != blank or closure_value != blank or pockets_value != blank or straps_value != blank
                  assign fit_has_fields = true
                endif
              %}
              {% if fit_has_content %}
                {% assign fit_expanded_initial_state = false %}
                {% if block.settings.open_by_default %}
                  {% assign fit_expanded_initial_state = true %}
                {% endif %}
                {% capture fit_content %}
                      {% if fit_has_fields %}
                        <div class="product-fit-dimensions-block__grid">
                          {% if width_value != blank %}
                            <div class="product-fit-dimensions-block__cell">
                              <span>{{ block.settings.width_label }}</span>
                              <strong>{{ width_value }}{% unless width_value contains '"' %}"{% endunless %}</strong>
                            </div>
                          {% endif %}
                          {% if height_value != blank %}
                            <div class="product-fit-dimensions-block__cell">
                              <span>{{ block.settings.height_label }}</span>
                              <strong>{{ height_value }}{% unless height_value contains '"' %}"{% endunless %}</strong>
                            </div>
                          {% endif %}
                          {% if depth_value != blank %}
                            <div class="product-fit-dimensions-block__cell">
                              <span>{{ block.settings.depth_label }}</span>
                              <strong>{{ depth_value }}{% unless depth_value contains '"' %}"{% endunless %}</strong>
                            </div>
                          {% endif %}
                          {% if closure_value != blank %}
                            <div class="product-fit-dimensions-block__cell">
                              <span>{{ block.settings.closure_label }}</span>
                              <strong>{{ closure_value }}</strong>
                            </div>
                          {% endif %}
                          {% if pockets_value != blank %}
                            <div class="product-fit-dimensions-block__cell">
                              <span>{{ block.settings.pockets_label }}</span>
                              <strong>{{ pockets_value }}</strong>
                            </div>
                          {% endif %}
                          {% if straps_value != blank %}
                            <div class="product-fit-dimensions-block__cell">
                              <span>{{ block.settings.straps_label }}</span>
                              <strong>{{ straps_value }}</strong>
                            </div>
                          {% endif %}
                        </div>
                      {% endif %}
                      {% if dimensions_media != blank %}
                        <div class="product-fit-dimensions-block__image">
                          {{ dimensions_media.preview_image | image_url: width: 1200 | image_tag: loading: 'lazy' }}
                        </div>
                      {% endif %}
                {% endcapture %}
                {% capture fit_style %}
                  --pdp-fit-table-border: {{ block.settings.table_border_color }};
                  --pdp-fit-label-color: {{ block.settings.label_color }};
                  --pdp-fit-value-color: {{ block.settings.value_color }};
                  --pdp-fit-image-radius: {{ block.settings.image_radius }}px;
                  --pdp-fit-table-radius: {{ block.settings.table_radius }}px;
                  --pdp-fit-cell-min-height: {{ block.settings.cell_min_height }}px;
                  --pdp-fit-cell-padding-y: {{ block.settings.cell_padding_vertical }}px;
                  --pdp-fit-cell-padding-x: {{ block.settings.cell_padding_horizontal }}px;
                  --pdp-fit-cell-gap: {{ block.settings.cell_label_gap }}px;
                  --pdp-fit-label-size: {{ block.settings.label_size }}px;
                  --pdp-fit-image-margin-top: {{ block.settings.image_margin_top }}px;
                {% endcapture %}
                {% render 'product-detail-accordion',
                  block: block,
                  section_settings: section.settings,
                  section_id: section.id,
                  panel_id: 'fit-panel',
                  button_id: 'fit-button',
                  extra_class: 'product-fit-dimensions-block',
                  extra_style: fit_style,
                  expanded_initial_state: fit_expanded_initial_state,
                  content: fit_content
                %}
              {% endif %}
            

              {%- when 'quantity_selector' -%}
              <div
                id="Quantity-Form-{{ section.id }}"
                class="product-form__input product-form__quantity"
                {{ block.shopify_attributes }}
              >
              {% if block.settings.border_top %}
              <hr class="product-block-hr-top" />
              {% endif %}
                <div class="quantity-selector-layout-{{ block.settings.selector_layout }}">                  
                    {% # theme-check-disable %}
                    {%- assign cart_qty = cart | item_count_for_variant: product.selected_or_first_available_variant.id -%}
                    {% # theme-check-enable %}
                    <span class="visually-hidden" id="quantity-label-{{ section.id }}">
                      {%- if cart_qty > 0 -%}
                        {{- 'products.product.quantity.in_cart_html' | t: quantity: cart_qty -}}
                      {%- else -%}
                        {{- 'products.product.quantity.label' | t -}}
                      {%- endif -%}
                    </span>
                    <label
                      class="quantity__label form__label{% unless block.settings.show_label %} visually-hidden{% endunless %}"
                      for="Quantity-{{ section.id }}"
                      aria-labelledby="quantity-label-{{ section.id }}"
                    >
                      <span>{{ 'products.product.quantity.label' | t }}</span>
                      <span class="quantity__rules-cart{% if cart_qty == 0 %} hidden{% endif %}" aria-hidden="true">
                        <span>({{- 'products.product.quantity.in_cart_html' | t: quantity: cart_qty -}})</span>
                        {%- render 'loading-spinner' -%}
                      </span>
                    </label>
                    <div class="price-per-item__container">
                      <quantity-input class="quantity qty-selector-border-style--{{ settings.qty_selector_border }}" data-url="{{ product.url }}" data-section="{{ section.id }}">
                        <button class="quantity__button" name="minus" type="button">
                          <span class="visually-hidden">
                            {{- 'products.product.quantity.decrease' | t: product: product.title | escape -}}
                          </span>
                          {% render 'icon-minus' %}
                        </button>
                          <input
                            class="quantity__input"
                            type="number"
                            name="quantity"
                            id="Quantity-{{ section.id }}"
                            data-cart-quantity="{{ cart_qty }}"
                            data-min="{{ product.selected_or_first_available_variant.quantity_rule.min }}"
                            min="{{ product.selected_or_first_available_variant.quantity_rule.min }}"
                            {% if product.selected_or_first_available_variant.quantity_rule.max != null %}
                              data-max="{{ product.selected_or_first_available_variant.quantity_rule.max }}"
                              max="{{ product.selected_or_first_available_variant.quantity_rule.max }}"
                            {% endif %}
                            {% if product.selected_or_first_available_variant.quantity_rule.max == null and product.selected_or_first_available_variant.inventory_management == 'shopify' and product.selected_or_first_available_variant.inventory_policy == 'deny' %}
                              data-max="{{ product.selected_or_first_available_variant.inventory_quantity | at_least: 1 }}"
                              max="{{ product.selected_or_first_available_variant.inventory_quantity | at_least: 1 }}"
                            {% endif %}
                            {% if product.selected_or_first_available_variant.quantity_rule.max == null and product.selected_or_first_available_variant.inventory_management == 'shopify' and product.selected_or_first_available_variant.inventory_policy == 'continue' %}
                              data-max="999"
                              max="999"
                            {% endif %}
                            step="{{ product.selected_or_first_available_variant.quantity_rule.increment }}"
                            value="{{ product.selected_or_first_available_variant.quantity_rule.min }}"
                            form="{{ product_form_id }}"
                          />
                        <button class="quantity__button" name="plus" type="button">
                          <span class="visually-hidden">
                            {{- 'products.product.quantity.increase' | t: product: product.title | escape -}}
                          </span>
                          {% render 'icon-plus' %}
                        </button>
                      </quantity-input>
                      {%- liquid
                        assign volume_pricing_array = product.selected_or_first_available_variant.quantity_price_breaks | sort: 'quantity' | reverse
                        assign current_qty_for_volume_pricing = cart_qty | plus: product.selected_or_first_available_variant.quantity_rule.min
                        if cart_qty > 0
                          assign current_qty_for_volume_pricing = cart_qty | plus: product.selected_or_first_available_variant.quantity_rule.increment
                        endif
                      -%}
                      {%- if product.quantity_price_breaks_configured? -%}
                        <price-per-item
                          id="Price-Per-Item-{{ section.id }}"
                          data-section-id="{{ section.id }}"
                          data-variant-id="{{ product.selected_or_first_available_variant.id }}"
                        >
                          {%- if product.selected_or_first_available_variant.quantity_price_breaks.size > 0 -%}
                            {%- assign variant_price_compare = product.selected_or_first_available_variant.compare_at_price -%}
                            <div class="price-per-item">
                              {%- if variant_price_compare -%}
                                <dl class="price-per-item--current">
                                  <dt class="visually-hidden">
                                    {{ 'products.product.price.regular_price' | t }}
                                  </dt>
                                  <dd>
                                    <s class="variant-item__old-price">
                                      {{ variant_price_compare | money_with_currency }}
                                    </s>
                                  </dd>
                                </dl>
                              {%- endif -%}
                              {%- if current_qty_for_volume_pricing < volume_pricing_array.last.minimum_quantity -%}
                                {%- assign variant_price = product.selected_or_first_available_variant.price
                                  | money_with_currency
                                -%}
                                <span class="price-per-item--current">
                                  {{- 'products.product.volume_pricing.price_at_each' | t: price: variant_price -}}
                                </span>
                              {%- else -%}
                                {%- for price_break in volume_pricing_array -%}
                                  {%- if current_qty_for_volume_pricing >= price_break.minimum_quantity -%}
                                    {%- assign price_break_price = price_break.price | money_with_currency -%}
                                    <span class="price-per-item--current">
                                      {{- 'products.product.volume_pricing.price_at_each' | t: price: price_break_price -}}
                                    </span>
                                    {%- break -%}
                                  {%- endif -%}
                                {%- endfor -%}
                              {%- endif -%}
                            </div>
                          {%- else -%}
                            {%- assign variant_price = product.selected_or_first_available_variant.price
                              | money_with_currency
                            -%}
                            {%- assign variant_price_compare = product.selected_or_first_available_variant.compare_at_price -%}
                            <div class="price-per-item">
                              {%- if variant_price_compare -%}
                                <dl class="price-per-item--current">
                                  <dt class="visually-hidden">
                                    {{ 'products.product.price.regular_price' | t }}
                                  </dt>
                                  <dd>
                                    <s class="variant-item__old-price">
                                      {{ variant_price_compare | money_with_currency }}
                                    </s>
                                  </dd>
                                  <dt class="visually-hidden">
                                    {{ 'products.product.price.sale_price' | t }}
                                  </dt>
                                  <dd>
                                    <span class="price-per-item--current">
                                      {{-
                                        'products.product.volume_pricing.price_at_each'
                                        | t: price: variant_price
                                      -}}
                                    </span>
                                  </dd>
                                </dl>
                              {%- else -%}
                                <span class="price-per-item--current">
                                  {{- 'products.product.volume_pricing.price_at_each' | t: price: variant_price -}}
                                </span>
                              {%- endif -%}
                            </div>
                          {%- endif -%}
                        </price-per-item>
                      {%- endif -%}
                    </div>
                    <div class="quantity__rules caption" id="Quantity-Rules-{{ section.id }}">
                      {%- if product.selected_or_first_available_variant.quantity_rule.increment > 1 -%}
                        <span class="divider">
                          {{-
                            'products.product.quantity.multiples_of'
                            | t: quantity: product.selected_or_first_available_variant.quantity_rule.increment
                          -}}
                        </span>
                      {%- endif -%}
                      {%- if product.selected_or_first_available_variant.quantity_rule.min > 1 -%}
                        <span class="divider">
                          {{-
                            'products.product.quantity.minimum_of'
                            | t: quantity: product.selected_or_first_available_variant.quantity_rule.min
                          -}}
                        </span>
                      {%- endif -%}
                      {%- if product.selected_or_first_available_variant.quantity_rule.max != null -%}
                        <span class="divider">
                          {{-
                            'products.product.quantity.maximum_of'
                            | t: quantity: product.selected_or_first_available_variant.quantity_rule.max
                          -}}
                        </span>
                      {%- endif -%}
                    </div>
                    {%- if product.quantity_price_breaks_configured? -%}
                      <volume-pricing class="parent-display" id="Volume-{{ section.id }}">
                        {%- if product.selected_or_first_available_variant.quantity_price_breaks.size > 0 -%}
                          <span class="caption-large">{{ 'products.product.volume_pricing.title' | t }}</span>
                          <ul class="list-unstyled">
                            <li>
                              <span>{{ product.selected_or_first_available_variant.quantity_rule.min }}+</span>
                              {%- assign price = product.selected_or_first_available_variant.price
                                | money_with_currency
                              -%}
                              <span data-text="{{ 'products.product.volume_pricing.price_at_each' | t: price: variant_price }}">
                                {{- 'sections.quick_order_list.each' | t: money: price -}}
                              </span>
                            </li>
                            {%- for price_break in product.selected_or_first_available_variant.quantity_price_breaks -%}
                              {%- assign price_break_price = price_break.price | money_with_currency -%}
                              <li class="{%- if forloop.index >= 3 -%}show-more-item hidden{%- endif -%}">
                                <span>
                                  {{- price_break.minimum_quantity -}}
                                  <span aria-hidden="true">+</span></span
                                >
                                <span data-text="{{ 'products.product.volume_pricing.price_at_each' | t: price: price_break_price }}">
                                  {{- 'sections.quick_order_list.each' | t: money: price_break_price -}}
                                </span>
                              </li>
                            {%- endfor -%}
                          </ul>
                          {%- if product.selected_or_first_available_variant.quantity_price_breaks.size >= 3 -%}
                            <show-more-button>
                              <button
                                class="button-show-more link underlined-link"
                                id="Show-More-{{ section.id }}"
                                type="button"
                              >
                                <span class="label-show-more label-text"
                                  ><span aria-hidden="true">+ </span>{{ 'products.facets.show_more' | t }}
                                </span>
                              </button>
                            </show-more-button>
                          {%- endif -%}
                        {%- endif -%}
                      </volume-pricing>
                    {%- endif -%}
              </div>
              </div>

            
            {%- when 'popup' -%}
            <style>
              #ProductPopup-{{ block.id }} {
                margin-top: {{ block.settings.padding_top }}px;
                margin-bottom: {{ block.settings.padding_bottom }}px;
              }
            </style>
              <modal-opener
                class="product-popup-modal__opener no-js-hidden quick-add-hidden align-{{ block.settings.text_alignment }}"
                data-modal="#PopupModal-{{ block.id }}"
                {{ block.shopify_attributes }}
              >
                <button
                  id="ProductPopup-{{ block.id }}"
                  class="{% if block.settings.link_style == 'button-outline' %}button button--outline{% endif %}{% if block.settings.link_style == 'button' %}button{% endif %}{% if block.settings.link_style == 'text' %}product-popup-modal__button link text-{{ block.settings.text_size }} icon-{{ block.settings.link_icon }}{% endif %}"
