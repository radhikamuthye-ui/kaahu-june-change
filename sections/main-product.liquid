<product-info
  id="MainProduct-{{ section.id }}"
  class=""
  data-section="{{ section.id }}"
  data-product-id="{{ product.id }}"
  data-update-url="true"
  data-url="{{ product.url }}"
>
  {{ 'section-main-product.css' | asset_url | stylesheet_tag }}
  {{ 'component-accordion.css' | asset_url | stylesheet_tag }}
  {{ 'component-price.css' | asset_url | stylesheet_tag }}
  {{ 'component-loading-overlay.css' | asset_url | stylesheet_tag }}
  {{ 'component-slider.css' | asset_url | stylesheet_tag }}

  {%- style -%}
    #MainProduct-{{ section.id }} {
      --pdp-mobile-paper: {{ section.settings.pdp_mobile_paper_color }};
      --pdp-mobile-ink: {{ section.settings.pdp_mobile_ink_color }};
      --pdp-mobile-text: {{ section.settings.pdp_mobile_text_color }};
      --pdp-mobile-muted: {{ section.settings.pdp_mobile_muted_color }};
      --pdp-mobile-line: {{ section.settings.pdp_mobile_line_color }};
      --pdp-mobile-soft-bg: {{ section.settings.pdp_mobile_soft_bg_color }};
      --pdp-mobile-gallery-bg: {{ section.settings.pdp_mobile_gallery_bg_color }};
      --pdp-mobile-accent: {{ section.settings.pdp_mobile_accent_color }};
      --pdp-mobile-sale: {{ section.settings.pdp_mobile_sale_color }};
      --pdp-mobile-star: {{ section.settings.pdp_mobile_star_color }};
      --pdp-details-summary-heading-color: {{ section.settings.product_details_summary_heading_color }};
      --pdp-details-summary-text-color: {{ section.settings.product_details_summary_text_color }};
      --pdp-details-summary-heading-size-mobile: {{ section.settings.product_details_summary_heading_size_mobile }}px;
      --pdp-details-summary-heading-size-desktop: {{ section.settings.product_details_summary_heading_size_desktop }}px;
      --pdp-details-summary-body-size-mobile: {{ section.settings.product_details_summary_body_size_mobile }}px;
      --pdp-details-summary-body-size-desktop: {{ section.settings.product_details_summary_body_size_desktop }}px;
      --pdp-details-summary-max-width: {{ section.settings.product_details_summary_max_width }}px;
      --pdp-details-summary-margin-top-mobile: {{ section.settings.product_details_summary_margin_top_mobile }}px;
      --pdp-details-summary-margin-top-desktop: {{ section.settings.product_details_summary_margin_top_desktop }}px;
      --pdp-details-summary-padding-top: {{ section.settings.product_details_summary_padding_top }}px;
      --pdp-details-summary-border-color: {{ section.settings.product_details_summary_border_color }};
      --pdp-details-desktop-offset-x: {{ section.settings.product_detail_desktop_offset_x }}px;
      --pdp-details-desktop-offset-top: {{ section.settings.product_detail_desktop_offset_top }}px;
      --pdp-details-desktop-max-width: {{ section.settings.product_detail_desktop_max_width }}px;
    }
    .section-{{ section.id }}-padding {
      padding-top: {{ section.settings.padding_top_mobile }}px;
      padding-bottom: {{ section.settings.padding_bottom_mobile }}px;
    }
    .product-media-image {
      background: {{ section.settings.media_bg_col }};
    }
    .gallery-slider--thumbnail, .lightbox-thumbnail, .stacked-thumbnails-wrapper button {
      background: {{ section.settings.media_bg_col }} !important;
    }
    {% if section.settings.thumbnail_border_opacity == 0 %}
    .gallery-slider--thumbnail img, .lightbox-thumbnail img, .stacked-thumbnails-wrapper button, .stacked-thumbnails-wrapper button.highlight-disable {
      border: 1px solid transparent;  
    }
    {% endif %}
    {% if section.settings.thumbnail_border_opacity > 0 %}
    .gallery-slider--thumbnail img, .lightbox-thumbnail img, .stacked-thumbnails-wrapper button, .stacked-thumbnails-wrapper button.highlight-disable {
      border: 1px solid rgba(var(--color-foreground-rgb),{{ section.settings.thumbnail_border_opacity | divided_by: 100.0 }});  
    }
    {% endif %}
    .gallery-slider--thumbnail.active img, .stacked-thumbnails-wrapper button.active {
      border: 1px solid rgba(var(--color-foreground-rgb),{{ section.settings.thumbnail_border_opacity_active | divided_by: 100.0 }});
    }
    .stacked-thumbnails-wrapper button.highlight-selected {
      border: 1px solid rgba(var(--color-foreground-rgb),{{ section.settings.thumbnail_border_opacity_active | divided_by: 100.0 }}) !important;
    }
    .stacked-thumbnails-wrapper.stacked-gt-style--trackbar button.highlight-selected {
      border: 0 !important;
    }
    {% if section.settings.thumbnail_border_opacity > 0 %}
    .stacked-thumbnails-wrapper button.highlight-disable {
      border: 1px solid rgba(var(--color-foreground-rgb),{{ section.settings.thumbnail_border_opacity | divided_by: 100.0 }});  
    }
    {% endif %}
    {% if section.settings.thumbnail_border_opacity == 0 %}
    .stacked-thumbnails-wrapper button.highlight-disable {
      border: 1px solid transparent;  
    }
    {% endif %}
    .modal-gallery-fg-fg-body .lightbox-thumbnail-active img {
      border: 1px solid rgba(var(--color-foreground-rgb),{{ section.settings.thumbnail_border_opacity_active | divided_by: 100.0 }});
    }
    .modal-gallery-fg-fg-01 .lightbox-thumbnail-active img {
      border: 1px solid rgba(var(--color-accent-one-rgb),{{ section.settings.thumbnail_border_opacity_active | divided_by: 100.0 }});
    }
    .modal-gallery-fg-fg-02 .lightbox-thumbnail-active img {
      border: 1px solid rgba(var(--color-accent-two-rgb),{{ section.settings.thumbnail_border_opacity_active | divided_by: 100.0 }});
    }
    .modal-gallery-fg-fg-03 .lightbox-thumbnail-active img {
      border: 1px solid rgba(var(--color-accent-three-rgb),{{ section.settings.thumbnail_border_opacity_active | divided_by: 100.0 }});
    }
    .modal-gallery-fg-fg-04 .lightbox-thumbnail-active img {
      border: 1px solid rgba(var(--color-accent-four-rgb),{{ section.settings.thumbnail_border_opacity_active | divided_by: 100.0 }});
    }
    .modal-gallery-fg-fg-05 .lightbox-thumbnail-active img {
      border: 1px solid rgba(var(--color-accent-five-rgb),{{ section.settings.thumbnail_border_opacity_active | divided_by: 100.0 }});
    }
    .product__info-container .product__title, .product__vendor_block, .product-button-block, .product__inset_image_block, .product-block-rating-wrapper, .product__upsell-products, .product-feature-icon-grid--wrapper, .product-inventory-container, .product-app-block, .product-text-clamp-toggle, .product-description-standard, .main-product--badge, .product-info-tabs, .product-breadcrumb-block, .product__info-container .product-price-block, .product__info-container .product__text, .product__info-container .product-custom-liquid-block {
      margin-bottom: {{ section.settings.blocks_vertical_spacing }}px;
    }
    .product__info-container > div:has(.installment) {
      margin-bottom: {{ section.settings.blocks_vertical_spacing | at_least: 15 }}px;
    }
    .product-share-component {
      margin-bottom: {{ section.settings.blocks_vertical_spacing | minus: 5 | at_least: 10 }}px;
    }
    .product__info-container .product-variant-picker-block, .product__info-container .product-form__quantity {
      margin-bottom: {{ section.settings.blocks_vertical_spacing | at_least: 20 }}px;
    }
    .product__cross-links {
      margin-top: {{ section.settings.blocks_vertical_spacing | at_least: 20 }}px;
      margin-bottom: {{ section.settings.blocks_vertical_spacing | at_least: 20 }}px;
    }
    .product-form__input:nth-child(2), .product-form__input:nth-child(3) {
      margin-top: {{ section.settings.blocks_vertical_spacing }}px;
    }
    .product-form__buttons {
      margin-top: {{ section.settings.blocks_vertical_spacing | at_least: 20 }}px;
    }
    .product__info-container {
      --pdp-sticky-bg: {{ section.settings.sticky_buttons_background_color }};
      --pdp-sticky-border: {{ section.settings.sticky_buttons_border_color }};
      --pdp-sticky-button-bg: {{ section.settings.sticky_buttons_button_background }};
      --pdp-sticky-button-text: {{ section.settings.sticky_buttons_button_text_color }};
      --pdp-sticky-more-options: {{ section.settings.sticky_buttons_more_options_color }};
      --pdp-sticky-title: {{ section.settings.sticky_buttons_title_color }};
      --pdp-sticky-price: {{ section.settings.sticky_buttons_price_color }};
      --pdp-sticky-compare-price: {{ section.settings.sticky_buttons_compare_price_color }};
      --pdp-sticky-button-height: {{ section.settings.sticky_buttons_button_height }}px;
      --pdp-sticky-button-radius: {{ section.settings.sticky_buttons_button_radius }}px;
      --pdp-sticky-button-size: {{ section.settings.sticky_buttons_button_text_size }}px;
      --pdp-sticky-dynamic-gap: {{ section.settings.sticky_buttons_dynamic_checkout_gap }}px;
      --pdp-sticky-more-options-size: {{ section.settings.sticky_buttons_more_options_size }}px;
      --pdp-sticky-title-size: {{ section.settings.sticky_buttons_title_size }}px;
      --pdp-sticky-price-size: {{ section.settings.sticky_buttons_price_size }}px;
    }
    .product-buy-buttons-wrapper {
      margin-bottom: {{ section.settings.blocks_vertical_spacing | at_least: 30 }}px;
    }
    .product-block-hr-top {
      margin-bottom: {{ section.settings.blocks_vertical_spacing | at_least: 20 }}px;
    }
    .product-block-hr-bottom {
      margin-top: {{ section.settings.blocks_vertical_spacing | at_least: 20 }}px;
    }
    {% if section.settings.section_desktop_layout == 'stacked' %}
    .product-template-dt-stacked {
      background: {{ section.settings.media_bg_col }};
    }
    .product-main-info-section {
      background: var(--color-background);
    }
    {% endif %}
    {% if settings.badge_corner_radius > 18 %}
    .main-product--badge > span {
      padding: 5px 11px;
    }
    {% endif %}
    {% if section.settings.media_mobile_width == 'page-width' %}
    @media screen and (max-width: 750px) {
      .product-media-component {
        padding: var(--page-margin-mobile);
        padding-bottom: 0;
      }
      .product-media-component img, .product-media-component video {
        border-radius: var(--media-radius);
      }
    }
      @media screen and (min-width: 750px) and (max-width: 950px) {
      .product-media-component {
        padding: var(--page-margin-tablet);
      }
      .product-media-component img, .product-media-component video {
        border-radius: var(--media-radius);
      }
    }
    {% endif %}

    @media screen and (min-width: 750px) {
      .section-{{ section.id }}-padding {
        padding-bottom: {{ section.settings.padding_bottom }}px;
      }
      {% if section.settings.product_section_width == 'standard' %}
        .product-main-top-section {
          padding-left: var(--page-margin-tablet);
          padding-right: var(--page-margin-tablet);
        }
      {% endif %}
    }
          
    @media only screen and (min-width: 950px) {
      .section-{{ section.id }}-padding {
        padding-top: {{ section.settings.padding_top }}px;
        padding-bottom: {{ section.settings.padding_bottom }}px;
      }
      .pdp-border--vertical {
        height: calc(100% + {{ section.settings.padding_top }}px + {{ section.settings.padding_bottom }}px);
        top: -{{ section.settings.padding_top }}px;
      }
      .stacked-thumbnails-wrapper.stacked-gt-placement--adjacent {
        top: calc(var(--site-header-height-mobile) + {{ section.settings.padding_top | at_least: 20 }}px) !important;
      }
      body:has(.full-width-announcement-bar) .stacked-thumbnails-wrapper.stacked-gt-placement--adjacent {
        top: calc(var(--site-header-height-mobile) + 35px + {{ section.settings.padding_top | at_least: 20 }}px) !important;
      }
      .stacked-thumbnails-wrapper.stacked-thumbnails-wrapper.stacked-gt-placement--overlay {
        top: calc(var(--site-header-height-mobile) + 20px + {{ section.settings.padding_top }}px) !important;
      }
      body:has(.full-width-announcement-bar) .stacked-thumbnails-wrapper.stacked-gt-placement--overlay {
        top: calc(var(--site-header-height-mobile) + 45px + {{ section.settings.padding_top }}px) !important;
      }
      body:has(.full-width-announcement-bar) .product-template-dt-stacked .stacked-thumbnails-wrapper.stacked-gt-placement--overlay {
        top: 20px !important;
      }
      body:has(.header-bar--full) .product__column-sticky {
        top: calc(var(--site-header-height-desktop) + {{ section.settings.padding_top }}px);
      }
      body:has(.header-bar--full):has(.full-width-announcement-bar) .product__column-sticky {
        top: calc(var(--site-header-height-desktop) + 35px + {{ section.settings.padding_top }}px);
      }
      .product__info-container {
        max-width: {{ section.settings.text_section_max_width }}px;
      }
      .product__info-container {
        padding-top: {{ section.settings.text_section_padding | divided_by: 10 }}rem;
      }
      body:has(.hbi-semi-transparent) .product__info-container {
        padding-top: calc(var(--site-header-height-mobile) + {{ section.settings.text_section_padding }}px);
      }
      body:has(.header-bar--page-margins) .product__info-container {
        padding-top: calc(var(--site-header-height-mobile) + {{ section.settings.text_section_padding | plus: 10 }}px);
      }
      {% if section.settings.product_section_width == 'standard' %}
        .product-main-top-section {
          padding-left: var(--page-margin-tablet);
          padding-right: var(--page-margin-tablet);
        }
      {% endif %}
    }  
    
    @media only screen and (min-width: 1025px) {
      .stacked-thumbnails-wrapper.stacked-thumbnails-wrapper.stacked-gt-placement--adjacent {
        top: calc(var(--site-header-height-desktop) + {{ section.settings.padding_top | at_least: 20 }}px) !important;
      }
      body:has(.full-width-announcement-bar) .stacked-thumbnails-wrapper.stacked-gt-placement--adjacent {
        top: calc(var(--site-header-height-desktop) + 35px + {{ section.settings.padding_top | at_least: 20 }}px) !important;
      }
      .stacked-thumbnails-wrapper.stacked-thumbnails-wrapper.stacked-gt-placement--overlay {
        top: calc(var(--site-header-height-desktop) + 20px + {{ section.settings.padding_top }}px) !important;
      }
      body:has(.full-width-announcement-bar) .stacked-thumbnails-wrapper.stacked-gt-placement--overlay {
        top: calc(var(--site-header-height-desktop) + 55px + {{ section.settings.padding_top }}px) !important;
      }
      body:has(.hbi-semi-transparent) .product__info-container {
        padding-top: calc(var(--site-header-height-desktop) + {{ section.settings.text_section_padding }}px);
      }
      body:has(.header-bar--page-margins) .product__info-container {
        padding-top: calc(var(--site-header-height-desktop) + {{ section.settings.text_section_padding | plus: 10 }}px);
      }
      {% if section.settings.product_section_width == 'standard' %}
        .product-main-top-section {
          padding-left: var(--page-margin-desktop);
          padding-right: var(--page-margin-desktop);
        }
      {% endif %}
    }

    {% if settings.page_margin_desktop > 120 %}
    @media only screen and (min-width: 950px) and (max-width: 1300px) {
      .product-main-info-section {
        padding-left: 4rem !important;
      }
    }
    {% endif %}
    
    {%- if section.settings.bottom_border -%}
      .section-{{ section.id }}-padding {
        padding-bottom: 0;
      }
      .main-product--section .section-border {
        margin-top: {{ section.settings.padding_bottom_mobile }}px;
      }
      @media only screen and (min-width: 950px) {
        .section-{{ section.id }}-padding {
          padding-bottom: 0;
        }
        .main-product--section .section-border {
          margin-top: {{ section.settings.padding_bottom }}px;
        }
      }
    {%- endif -%}

    @media only screen and (max-width: 949px) {
      .sticky-buy-buttons .product-form {
        padding: {{ section.settings.sticky_buttons_padding }}px {{ section.settings.sticky_buttons_padding_horizontal }}px calc({{ section.settings.sticky_buttons_padding }}px + env(safe-area-inset-bottom, 0px)) {{ section.settings.sticky_buttons_padding_horizontal }}px;
        box-shadow: 0px 0px 12px 0px rgba(0,0,0,{{ section.settings.sticky_buttons_shadow | divided_by: 100.0 }});
      }
    }

    {%- if section.settings.padding_top > 0 -%}
    .pmc-thumbnail-position--adjacent-left-normal .gallery-slider-thumbnails, 
    .pmc-thumbnail-position--adjacent-left-large .gallery-slider-thumbnails,
    .pmc-thumbnail-position--adjacent-right-normal .gallery-slider-thumbnails, 
    .pmc-thumbnail-position--adjacent-right-large .gallery-slider-thumbnails {
      top: 0 !important;
    }
    {%- endif -%}
  {%- endstyle -%}


  <script src="{{ 'product-info.js' | asset_url }}" defer="defer"></script>
  <script src="{{ 'product-form.js' | asset_url }}" defer="defer"></script>
  {% unless product.media.size == 0 %}
  <script src="{{ 'product-media-gallery.js' | asset_url }}" defer="defer"></script>
  {% endunless %}
  {%- if request.design_mode -%}
  <script src="{{ 'theme-editor.js' | asset_url }}" defer="defer"></script>
  {%- endif -%}

  {%- assign first_3d_model = product.media | where: 'media_type', 'model' | first -%}
  {%- if first_3d_model -%}  
  <script type="application/json" id="ProductJSON-{{ product.id }}">
      {{ product.media | where: 'media_type', 'model' | json }}
  </script>
  <script src="{{ 'product-model.js' | asset_url }}" defer></script>
  {{ 'component-product-model.css' | asset_url | stylesheet_tag }}
  <link
      id="ModelViewerStyle"
      rel="stylesheet"
      href="https://cdn.shopify.com/shopifycloud/model-viewer-ui/assets/v1.0/model-viewer-ui.css"
      media="print"
      onload="this.media='all'"
    >
    <link
      id="ModelViewerOverride"
      rel="stylesheet"
      href="{{ 'component-model-viewer-ui.css' | asset_url }}"
      media="print"
      onload="this.media='all'"
    >
  {%- endif -%}

<section id="ProductInfo-{{ section.id }}" class="main-product--section page-width-mob-full-width section-{{ section.id }}-padding">

{%- assign product_form_id = 'product-form-' | append: section.id -%}

  <div class="product-main-top-section{% if product.media.size == 0 %} product-main-media-zero{% endif %} product-template-dt-{{ section.settings.section_desktop_layout }} product-main-top-section-margin--{{ section.settings.product_section_width }} product-main-section-layout-{{ section.settings.media_section_width }}{% if section.settings.section_desktop_layout != 'stacked' %} media-offset--{{ section.settings.media_width_offset }}{% endif %}">
    <div class="product-main-media-section media-play-style--{{ section.settings.media_video_play_button_style }}{% if section.settings.product_section_width == 'standard' %} product-main-media-section-rounded-media{% endif %}" id="pageGallery-{{ section.id }}">
    {% unless product.media.size == 0 %}
      {% render 'product-media-gallery',
      layout: section.settings.gallery_layout,
      media_aspect_ratio: section.settings.gallery_aspect_ratio,
      media_scale: section.settings.gallery_media_scale,
      media_screen_height: section.settings.gallery_height_limit_desktop,
      enable_zoom: section.settings.zoom_enable,
      video_autoplay: section.settings.media_video_autoplay,
      grid_spacing: section.settings.gallery_grid_spacing,
      mobile_navigation: section.settings.mobile_media_nav,
      mobile_bullet_position: section.settings.mobile_media_nav_position,
      desktop_navigation: section.settings.desktop_media_nav,
      thumbnail_size_setting: section.settings.desktop_media_thumbnail_size,
      thumbnail_position_setting: section.settings.desktop_media_thumbnail_position,
      thumbnail_placement: section.settings.desktop_media_thumbnail_placement,
      balance_grid: section.settings.balance_grid
      %}
      {% endunless %}
    </div>
    
    {% if section.settings.vertical_border and section.settings.section_desktop_layout != 'stacked' %}<div class="pdp-border--vertical"></div>{% endif %}

    <div class="product product-main-info-section align-{{ section.settings.info_txt_alignment }} vertical-align-{{ section.settings.text_section_vertical_position }}">
      <div class="product__info-container product-info-justify-{{ section.settings.text_section_position }}{% if section.settings.enable_sticky_info %} product__column-sticky{% endif %}{% if section.settings.enable_sticky_buttons_desktop %} sticky-buy-buttons-dt sticky-buttons-dt-width--full sticky-buy-buttons--border-{{ section.settings.sticky_buttons_border }} sticky-buttons-dt-position--{{ section.settings.sticky_buttons_desktop_position }} sticky-buttons-dt-margin--{{ section.settings.sticky_buttons_desktop_margin }}{% endif %}{% if section.settings.enable_sticky_buttons %} sticky-buy-buttons sticky-buy-buttons--border-{{ section.settings.sticky_buttons_border }}{% endif %}">
                
        {%- for block in section.blocks -%}
          {%- case block.type -%}
            {%- when '@app' -%}
              <div class="product-app-block">
              {% render block %}
              </div>
            
            {%- when 'breadcrumb' -%}
            {% assign position_counter = 0 %}
            {% assign breadcrumb_collection = blank %}
            {% assign breadcrumb_collection_metafield_namespace = block.settings.collection_metafield_namespace | default: 'custom' %}
            {% assign breadcrumb_collection_metafield_key = block.settings.collection_metafield_key | default: 'breadcrumb' %}
            {% if block.settings.use_collection_metafield and breadcrumb_collection_metafield_namespace != blank and breadcrumb_collection_metafield_key != blank %}
              {% for breadcrumb_candidate in product.collections %}
                {% assign breadcrumb_metafield = breadcrumb_candidate.metafields[breadcrumb_collection_metafield_namespace][breadcrumb_collection_metafield_key] %}
                {% if breadcrumb_metafield != blank and breadcrumb_metafield.value == true %}
                  {% assign breadcrumb_collection = breadcrumb_candidate %}
                  {% break %}
                {% endif %}
              {% endfor %}
            {% endif %}
            <nav aria-label="Breadcrumb">
              <div
                class="product-breadcrumb-block {{ block.settings.breadcrumb_size }} {{ block.settings.text_case }}"
                style="--breadcrumb-divider-spacing: {{ block.settings.divider_spacing }}px;"
                {{ block.shopify_attributes }}
              >
                <ol itemscope itemtype="https://schema.org/BreadcrumbList">
                {% if block.settings.homepage_link %}
                  {% assign position_counter = 1 %}
                  <li itemprop="itemListElement" itemscope itemtype="https://schema.org/ListItem">
                    <a itemprop="item" href="{{ routes.root_url }}"><span itemprop="name">{{ 'templates.home_page.home_page' | t }}</span></a> <span class="product-breadcrumb--divider">{% if block.settings.divider_style == 'slash' %}/{% else %}&bull;{% endif %}</span>
                    <meta itemprop="position" content="1" />
                  </li>
                {% endif %}
                {% if product.metafields.custom.breadcrumb != blank %}
                  {% for collection in product.metafields.custom.breadcrumb.value %}
                    {% assign position_counter = position_counter | plus: 1 %}
                    <li itemprop="itemListElement" itemscope itemtype="https://schema.org/ListItem">
                      <a itemprop="item" href="{{ collection.url }}"><span itemprop="name">{{ collection.title }}</span></a> <span class="product-breadcrumb--divider">{% if block.settings.divider_style == 'slash' %}/{% else %}&bull;{% endif %}</span>
                      <meta itemprop="position" content="{{ position_counter }}" />
                    </li>
                  {% endfor %}
                {% elsif breadcrumb_collection != blank %}
                  {% assign position_counter = position_counter | plus: 1 %}
                  <li itemprop="itemListElement" itemscope itemtype="https://schema.org/ListItem">
                    <a itemprop="item" href="{{ breadcrumb_collection.url }}"><span itemprop="name">{{ breadcrumb_collection.title }}</span></a> <span class="product-breadcrumb--divider">{% if block.settings.divider_style == 'slash' %}/{% else %}&bull;{% endif %}</span>
                    <meta itemprop="position" content="{{ position_counter }}" />
                  </li>
                {% elsif collection != blank %}
                  {% assign position_counter = position_counter | plus: 1 %}
                  <li itemprop="itemListElement" itemscope itemtype="https://schema.org/ListItem">
                    <a itemprop="item" href="{{ collection.url }}"><span itemprop="name">{{ collection.title }}</span></a> <span class="product-breadcrumb--divider">{% if block.settings.divider_style == 'slash' %}/{% else %}&bull;{% endif %}</span>
                    <meta itemprop="position" content="{{ position_counter }}" />
                  </li>
                {% elsif product.collections.first != blank %}
                  {% assign position_counter = position_counter | plus: 1 %}
                  <li itemprop="itemListElement" itemscope itemtype="https://schema.org/ListItem">
