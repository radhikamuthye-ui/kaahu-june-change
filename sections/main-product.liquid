                </button>
              </modal-opener>
            
            {%- when 'share' -%}
              {% assign share_url = product.selected_variant.url | default: product.url | prepend: request.origin %}
            <div class="product-share-component align-{{ block.settings.alignment }}{% if block.settings.show_label %} product-share-with-label{% endif %}" {{ block.shopify_attributes }}>
              {% render 'product-share-button',
                block: block,
                share_link: share_url
              %}
            </div>
            
            {%- when 'variant_picker' -%}
            {% unless product.has_only_default_variant %}
            <style>
            .product-form__input input[type=radio]+label {
              min-width: {{ block.settings.pill_min_width }}px;
            }
            .pill-layout--flex-grow .product-form__input .radio-options-wrapper input[type=radio]+label {
              min-width: 44px;
            }
            .product-form__input input[type=radio]+label.variant-picker-image {
              min-width: 53px !important;
            }
            .product-variant-picker-block .form__label {
              text-align: {{ block.settings.label_alignment }};
            }
            </style>
            <div class="product-variant-picker-block variant-picker-{{ block.settings.picker_type }} variant-picker-label-alignment-{{ block.settings.label_alignment }}{% if block.settings.picker_type == 'button' %} pill-layout--{{ block.settings.pill_layout }} pill-alignment--{{ block.settings.pill_alignment }}{% endif %} swatch-shape-{{ block.settings.color_swatches_style }} swatch-size-{{ block.settings.color_swatch_size }} pill-selected-state--{{ block.settings.pill_selected_state }} minimal-selected-state--{{ block.settings.minimal_highlight_style }}">
            {% if block.settings.border_top %}
            <hr class="product-block-hr-top" />
            {% endif %}
            {% if block.settings.picker_title != blank %}
              <div class="variant-picker--block-title">{{ block.settings.picker_title | escape }}</div>
            {% endif %}

            {% if block.settings.use_color_swatches %}
              {% assign swatches = block.settings.color_swatches_array | strip | newline_to_br | strip_newlines | split: "<br />"  %}
              {% assign visual_variants = block.settings.visual_variants_array | split: ', '  %}
              
              {% for swatch in swatches %}
              <style>
              .picker-swatch-{{ swatch | split: " - " | first | handleize }} {
                background: {{ swatch | split: " - " | last }} !important;
              }  
              </style>
              {% endfor %}
            {% endif %}

            {% assign thumbnail_variants = block.settings.thumbnail_variants_label %}
            {% if block.settings.use_color_swatches %}
              {% assign visual_variants = block.settings.visual_variants_array | split: ', '  %}
            {% endif %}
              {% render 'product-variant-picker', 
                product: product, 
                block: block, 
                product_form_id: product_form_id, 
                labels: block.settings.show_labels, 
                pill_threshold: block.settings.pill_threshold,
                pill_options_display: block.settings.pill_additional_options_display, 
                show_variant_images: block.settings.use_variant_images, 
                thumbnail_variants: thumbnail_variants, 
                visual_variants: visual_variants, 
                swatches: block.settings.use_color_swatches, 
                swatch_style: block.settings.color_swatches_style, 
                swatch_size: block.settings.color_swatch_size, 
                swatch_label_position: block.settings.swatch_label_position
              %}
            {% if block.settings.border_bottom %}
            <hr class="product-block-hr-bottom" />
            {% endif %}
            </div>
            {% endunless %}

            {%- when 'buy_buttons' -%}
            <style>
              .pickup-availability-info {
                text-align: {{ block.settings.pickup_alignment }};
              }
              @media only screen and (min-width: 950px) {
                .product-buy-buttons-wrapper:not(.quick-add-modal .product-buy-buttons-wrapper) {
                  margin-bottom: {{ section.settings.blocks_vertical_spacing | at_least: 30 }}px;
                }                
              }
            </style>
            {% if block.settings.show_pickup_icon == false %}
            <style>
              .pickup-availability-info .icon {
                display: none;
              }
            </style>  
            {% endif %}
            {% if section.settings.enable_sticky_buttons %}
            <style>
              @media only screen and (max-width: 949px) {
                .sub-footer {
                  padding-bottom: 100px;
                }
              }
            </style>
            {% endif %}
            {% if section.settings.enable_sticky_buttons_desktop and section.settings.sticky_buttons_desktop_position == 'bottom' %}
            <style>
              @media only screen and (min-width: 950px) {
                .sub-footer {
                  padding-bottom: 80px;
                }
              }
            </style>
            {% endif %}
              {%- render 'buy-buttons', 
                block: block, 
                product: product, 
                product_form_id: product_form_id, 
                section_id: section.id, 
                style: block.settings.button_style, 
                show_payment_methods: block.settings.show_payment_methods, 
                show_pickup_availability: block.settings.show_pickup 
              -%}              
          {%- endcase -%}
          {%- endfor -%}
      <div class="quick-add-view-product-button text-small"><a href="{{ product.url }}">{{ 'products.product.view_full_details' | t }}</a></div>  
        </div>
    </div>
  </div>

  {% render 'product-desktop-details', product: product, section: section %}

{% if section.settings.bottom_border %}
<hr class="section-border section-border-color-{{ section.settings.border_color }} section-border-width-{{ section.settings.border_width }}">
{% endif %}
  
  {% assign popups = section.blocks | where: 'type', 'popup' %}
  {%- for block in popups -%}
    <modal-dialog id="PopupModal-{{ block.id }}" class="product-popup-modal product-popup-modal-width-{{ block.settings.popup_width }} popup-display-type-{{ block.settings.popup_display_type }}" {{ block.shopify_attributes }}>
      <div
        role="dialog"
        aria-label="{{ block.settings.text }}"
        aria-modal="true"
        class="product-popup-modal__content"
        tabindex="-1"
      >
        <div class="modal-header modal-header-align-{{ settings.popup_header_alignment }}">
        <button
          id="ModalClose-{{ block.id }}"
          type="button"
          class="product-popup-modal__toggle"
          aria-label="{{ 'accessibility.close' | t }}"
        >
          {% render 'icon-close' %}
        </button>
        <span class="dialog-title">{% if block.settings.content_source == 'block' %}{{ block.settings.popup_content_heading }}{% else %}{{ block.settings.page.title }}{% endif %}</span>
        </div>
        <div class="product-popup-modal__content-info">

          {% if block.settings.content_source == 'block' %}
            {% if block.settings.popup_content_image %}
              {% assign popup_image_render_size = 1400 %}
              {% if block.settings.popup_width == 'narrow' %}
              {% assign popup_image_render_size = 900 %} 
              {% endif %}
            <div class="product-popup-modal__block_image">
              {{ block.settings.popup_content_image | image_url: width: popup_image_render_size | image_tag: loading: 'lazy' }}
            </div>
            {% endif %}
            <div class="rte">
              {{ block.settings.popup_content_text }}
            </div>

          {% else %}

          {% assign enable_unit_toggle = false %}
            {% if block.settings.page.url contains 'size' and enable_unit_toggle %}
              <div class="unit-toggle-container text-small">
                <div class="unit-toggle selected metric-toggle">CM</div>
                <div class="unit-toggle imperial-toggle">IN</div>
              </div>
            {% endif %}

          {{ block.settings.page.content }}

          {% if block.settings.page.url contains 'size' and enable_unit_toggle %}
          <script>
            var metricBtn = document.querySelector(".metric-toggle");
            var imperialBtn = document.querySelector(".imperial-toggle");
            var imperialTables = document.querySelectorAll(".imperial-table");
            var metricTables = document.querySelectorAll(".metric-table");
          
            // Hide all imperial tables on page load
            window.addEventListener("DOMContentLoaded", function () {
              imperialTables.forEach(table => table.style.display = "none");
            });
            
            if (metricBtn && imperialBtn) {
              metricBtn.addEventListener("click", function () {
                // Show metric tables, hide imperial tables
                metricTables.forEach(table => table.style.display = "block");
                imperialTables.forEach(table => table.style.display = "none");
                this.classList.add("selected");
                imperialBtn.classList.remove("selected");
              });
          
              imperialBtn.addEventListener("click", function () {
                // Show imperial tables, hide metric tables
                imperialTables.forEach(table => table.style.display = "block");
                metricTables.forEach(table => table.style.display = "none");
                metricBtn.classList.remove("selected");
                this.classList.add("selected");
              });
            }
          </script>
          {% endif %}

          {% endif %}
        </div>
      </div>
    </modal-dialog>
  {%- endfor -%}


{% for block in section.blocks %}
{% case block.type %}
{% when 'description' %}
{% if block.settings.display_type == 'drawer' %}
{% assign specifications_split_word = section.settings.description_split_keyword %}
<div class="product-description-drawer quick-add-hidden">
  <div class="product-description-drawer--contents{% if settings.drawer_margin > 0 %} drawer-with-margin{% endif %}">
    <button class="product-description-drawer--close">{% render 'icon-close' %}</button>
    <div class="product-description-drawer--header">
    <div class="product-description-drawer--title dialog-title">{{ product.title }}</div>   
    </div>
    <div class="product-description-drawer--contents-text">
    {% if product.description contains specifications_split_word %}
    {{ product.description | split: specifications_split_word | first }}
    {{ product.description | split: specifications_split_word | last }}
    {% else %}
    {{ product.description }}
    {% endif %}
    </div>
  </div>
  <div class="product-description-drawer--background"></div>
</div>
<script>
  var pDrawerOpener = document.querySelector(".product-description-drawer--opener");
  var pDrawer = document.querySelector(".product-description-drawer");
  var pDrawerBg = document.querySelector(".product-description-drawer--background");
  var pDrawerCloseButton = document.querySelector(".product-description-drawer--close");
  var lastFocusedButton = null;
  
  if (pDrawerOpener) {
    pDrawerOpener.addEventListener("click", function (event) {
      lastFocusedButton = event.currentTarget;
      pDrawer.classList.add("open");
    setTimeout(() => {
      pDrawerCloseButton.focus();
    }, 200);
    });
    pDrawerCloseButton.addEventListener("click", function (event) {
      pDrawer.classList.remove("open");
      lastFocusedButton?.focus();
    });
    pDrawerBg.addEventListener("click", function (event) {
      pDrawer.classList.remove("open");
      lastFocusedButton?.focus();
    });
  }
</script>
{% endif %}
{% endcase %}
{% endfor %}

{% if section.settings.enable_sticky_buttons_desktop %}
<style>
@media only screen and (min-width: 950px) {
  .product-buy-buttons-wrapper.stick-now .product-form {
    padding-top: {{ section.settings.sticky_buttons_desktop_padding_vertical }}px;
    padding-bottom: {{ section.settings.sticky_buttons_desktop_padding_vertical }}px;
    padding-left: {{ section.settings.sticky_buttons_desktop_padding_vertical }}px;
    padding-right: {{ section.settings.sticky_buttons_desktop_padding_vertical }}px;
    box-shadow: 0px 0px 12px 0px rgba(0,0,0,{{ section.settings.sticky_buttons_shadow | divided_by: 100.0 }});
  }
}
</style>

<script>
document.addEventListener('DOMContentLoaded', function () {
  const buyButtonsWrapper = document.querySelector('#ProductInfo-{{ section.id }} .product-buy-buttons-wrapper');

  if (!buyButtonsWrapper) return;

  const threshold = 150;
  const fadeDelay = 200;
  let isSticky = false;
  let fadeInTimeout = null;
  let fadeOutTimeout = null;

  function getReserveHeight() {
    return buyButtonsWrapper.offsetHeight;
  }

  function updateSticky() {
    if (window.innerWidth < 950) {
      buyButtonsWrapper.style.minHeight = '';
      buyButtonsWrapper.classList.remove('stick-now', 'stick-visible');
      isSticky = false;
      return;
    }

    const shouldStick = buyButtonsWrapper.getBoundingClientRect().top <= -threshold;

    if (shouldStick && !isSticky) {
      isSticky = true;
      clearTimeout(fadeOutTimeout);
      clearTimeout(fadeInTimeout);
      buyButtonsWrapper.style.minHeight = `${getReserveHeight()}px`;
      buyButtonsWrapper.classList.add('stick-now');
      buyButtonsWrapper.classList.remove('stick-visible');
      fadeInTimeout = setTimeout(function () {
        if (isSticky) buyButtonsWrapper.classList.add('stick-visible');
      }, fadeDelay);
    }

    if (!shouldStick && isSticky) {
      isSticky = false;
      clearTimeout(fadeInTimeout);
      buyButtonsWrapper.classList.remove('stick-visible');
      clearTimeout(fadeOutTimeout);
      fadeOutTimeout = setTimeout(function () {
        if (!isSticky) {
          buyButtonsWrapper.classList.remove('stick-now');
          buyButtonsWrapper.style.minHeight = '';
        }
      }, 0);
    }
  }

  window.addEventListener('scroll', updateSticky, { passive: true });
  window.addEventListener('resize', function () {
    if (isSticky) buyButtonsWrapper.style.minHeight = `${getReserveHeight()}px`;
    updateSticky();
  });

  updateSticky();
});
</script>
{% endif %}

<script type="application/ld+json">
  {{ product | structured_data }}
</script>
  
</section>  
</product-info>

