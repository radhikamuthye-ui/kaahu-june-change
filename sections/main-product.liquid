                  hide_trailing_zeros: true
                -%}
                {% if block.settings.show_promo_message and promo_text != blank %}
                  <div class="product-price-promo" aria-label="{{ promo_text | escape }}">
                    <div class="product-price-promo__message">
                      <span class="product-price-promo__text">{{ promo_text | escape }}</span>
                    </div>
                    {% if show_promo_details %}
                      <div class="product-price-promo__details">
                        {% if block.settings.promo_helper_text != blank %}
                          <span class="product-price-promo__helper">{{ block.settings.promo_helper_text | escape }}</span>
                        {% endif %}
                        {% if block.settings.show_promo_estimate and block.settings.promo_percent > 0 %}
                          <span class="product-price-promo__estimate">
                            {{ block.settings.promo_estimate_label | escape }}: <strong>{{ promo_estimate | money_without_trailing_zeros }}</strong>
                          </span>
                        {% endif %}
                      </div>
                    {% endif %}
                  </div>
                {% endif %}
                {% if block.settings.price_show_taxes %}
                  {%- if shop.taxes_included or shop.shipping_policy.body != blank -%}
                    <div class="product__tax caption">
                      {%- if shop.taxes_included -%}
                        {{ 'products.product.include_taxes' | t }}
                      {%- endif -%}
                      {%- if shop.shipping_policy.body != blank -%}
                        {{ 'products.product.shipping_policy_html' | t: link: shop.shipping_policy.url }}
                      {%- endif -%}
                    </div>
                  {%- endif -%}
                {% endif %}
              </div>
            {% if block.settings.show_shoppay_banner %}
              <div {{ block.shopify_attributes }}>
                {%- assign product_form_installment_id = 'product-form-installment-' | append: section.id -%}
                {%- form 'product', product, id: product_form_installment_id, class: 'installment caption-large' -%}
                  <input type="hidden" name="id" value="{{ product.selected_or_first_available_variant.id }}">
                  {{ form | payment_terms }}
                {%- endform -%}
              </div>
              {% endif %}
              
              {%- when 'inventory' -%}

              <div class="product-inventory-container{% if block.settings.inventory-color-coded %} inventory-color-coded{% endif %} inventory-display-type-{{ block.settings.inventory_display }}" {{ block.shopify_attributes }}>            
              <p class="product__inventory text-small no-js-hidden{% if product.selected_or_first_available_variant.inventory_management != 'shopify' %} visibility-hidden{% endif %}"
                              {{ block.shopify_attributes }}
                              id="Inventory-{{ section.id }}"
                              role="status"
                            >
              {%- if product.selected_or_first_available_variant.inventory_management == 'shopify' -%}
              
              {% if block.settings.inventory_display == 'quantity' %}
              <span class="inventory-display--quantity{% if product.selected_or_first_available_variant.inventory_quantity == 0 %} inventory-display--quantity-zero{% endif %}{% if product.selected_or_first_available_variant.inventory_quantity > 0 and product.selected_or_first_available_variant.inventory_quantity <= block.settings.inventory_threshold %} inventory-display--quantity-low{% endif %}"><span class="inventory-number">{{ product.selected_or_first_available_variant.inventory_quantity }}</span>&nbsp;{{- 'products.product.inventory_in_stock' | t -}}</span>
              {% endif %}

              {% if block.settings.inventory_display == 'status' %}

              {%- if product.selected_or_first_available_variant.inventory_quantity == 0 and product.selected_or_first_available_variant.inventory_policy == 'deny' -%}
              <span class="inventory-display--message inventory-display--quantity-zero">{{- 'products.product.inventory_out_of_stock' | t -}}</span>
              {%- endif -%}

              {%- if product.selected_or_first_available_variant.inventory_quantity == 0 and product.selected_or_first_available_variant.inventory_policy == 'continue' -%}
              <span class="inventory-display--message inventory-display--quantity-normal{% if block.settings.hide_if_in_stock %} inventory--hide-in-stock{% endif %}">{{- 'products.product.inventory_out_of_stock_continue_selling' | t -}}</span>
              {%- endif -%}
              
              {%- if product.selected_or_first_available_variant.inventory_quantity > 0 and product.selected_or_first_available_variant.inventory_quantity <= block.settings.inventory_threshold and block.settings.inventory_threshold > 0 -%}
              <span class="inventory-display--message inventory-display--quantity-low">{{- 'products.product.inventory_low_stock' | t -}}</span>
              {%- endif -%}     

              {%- if product.selected_or_first_available_variant.inventory_quantity > 0 and product.selected_or_first_available_variant.inventory_quantity > block.settings.inventory_threshold -%}
              <span class="inventory-display--message inventory-display--quantity-normal{% if block.settings.hide_if_in_stock %} inventory--hide-in-stock{% endif %}">{{- 'products.product.inventory_in_stock' | t -}}</span>
              {%- endif -%}

              {% endif %}

              {%- endif -%}
              </p>
              </div>

              {%- when 'rating' -%}
                {% liquid
                  assign rating_block_visible = true
                  assign rating_visibility_namespace = block.settings.visibility_metafield_namespace | default: 'custom' | strip
                  assign rating_visibility_key = block.settings.visibility_metafield_key | default: 'show_review_summary' | strip

                  if block.settings.enable_metafield_visibility
                    assign rating_block_visible = false
                    if rating_visibility_namespace != blank and rating_visibility_key != blank
                      assign rating_visibility_metafield = product.metafields[rating_visibility_namespace][rating_visibility_key]
                      if rating_visibility_metafield == blank
                        assign rating_block_visible = block.settings.show_when_metafield_blank
                      else
                        assign rating_visibility_value = rating_visibility_metafield.value | default: rating_visibility_metafield, allow_false: true
                        assign rating_visibility_string = rating_visibility_value | downcase | strip

                        if block.settings.metafield_visible_value == 'false'
                          assign rating_block_visible = true
                          if rating_visibility_value == true or rating_visibility_string == 'true' or rating_visibility_string == '1' or rating_visibility_string == 'yes'
                            assign rating_block_visible = false
                          endif
                        elsif rating_visibility_value == true or rating_visibility_string == 'true' or rating_visibility_string == '1' or rating_visibility_string == 'yes'
                          assign rating_block_visible = true
                        endif
                      endif
                    endif
                  endif
                %}
                {%- if rating_block_visible and product.metafields.reviews.rating.value != blank -%}
                  <div
                    class="product-block-rating-wrapper"
                    style="
                      --pdp-rating-margin-top: {{ block.settings.margin_top }}px;
                      --pdp-rating-margin-bottom: {{ block.settings.margin_bottom }}px;
                      --pdp-rating-gap: {{ block.settings.item_gap }}px;
                      --pdp-rating-text-size-mobile: {{ block.settings.text_size_mobile }}px;
                      --pdp-rating-text-size-desktop: {{ block.settings.text_size_desktop }}px;
                      --pdp-rating-text-color: {{ block.settings.text_color }};
                      --pdp-rating-star-color: {{ block.settings.star_color }};
                      --pdp-rating-link-line-color: {{ block.settings.link_underline_color }};
                    "
                    {{ block.shopify_attributes }}
                  >
                    <a class="pdp-rating-link" href="{{ block.settings.link_anchor | default: '#pdp-reviews' }}">
                    {% liquid
                      assign rating_decimal = 0
                      assign decimal = product.metafields.reviews.rating.value.rating | modulo: 1
                      if decimal >= 0.3 and decimal <= 0.7
                        assign rating_decimal = 0.5
                      elsif decimal > 0.7
                        assign rating_decimal = 1
                      endif
                    %}
                    <div
                      class="rating"
                      role="img"
                      aria-label="{{ 'accessibility.star_reviews_info' | t: rating_value: product.metafields.reviews.rating.value, rating_max: product.metafields.reviews.rating.value.scale_max }}"
                    >
                      <span
                        aria-hidden="true"
                        class="rating-star"
                        style="--rating: {{ product.metafields.reviews.rating.value.rating | floor }}; --rating-max: {{ product.metafields.reviews.rating.value.scale_max }}; --rating-decimal: {{ rating_decimal }};"
                      ></span>
                    </div>
                    {%- if block.settings.show_rating_value -%}
                      <p class="rating-text caption">
                        <span aria-hidden="true">
                          {{- product.metafields.reviews.rating.value -}}
                        </span>
                      </p>
                    {%- endif -%}
                    {%- if block.settings.show_review_count -%}
                      <p class="rating-count caption">
                        <span aria-hidden="true">
                          {%- if block.settings.show_count_separator -%}&middot; {% endif -%}
                          {{ product.metafields.reviews.rating_count }}
                          {{ block.settings.review_count_label | default: 'reviews' }}
                        </span>
                        <span class="visually-hidden">
                          {{- product.metafields.reviews.rating_count }}
                          {{ 'accessibility.total_reviews' | t -}}
                        </span>
                      </p>
                    {%- endif -%}
                    </a>
                  </div>
                {%- endif -%}
            
            {%- when 'description' -%}
            {% assign specifications_split_word = 'SPECIFICATIONS' %}

            {% if section.settings.description_split_keyword != blank %}
            {% assign specifications_split_word = section.settings.description_split_keyword %}
            {% endif %}
            {%- if product.description != blank -%}

              {% if block.settings.display_type == 'accordion' %}

              {% assign expanded_initial_state = false %}
                
              {% if block.settings.accordion_open_default %}
              {% assign expanded_initial_state = true %} 
              {% endif %}
              
              <div class="accordion" {{ block.shopify_attributes }}>
              <button class="accordion-title{% if expanded_initial_state == true %} active{% endif %}" aria-expanded="{{ expanded_initial_state }}" aria-controls="{{ section.id }}-{{ block.id }}-description" id="{{ section.id }}-{{ block.id }}-button">{{ 'products.product.description' | t }}
              <div class="accordion-icons-wrapper">
              <div class="accordion-icon-open">{% if settings.accordion_icon == 'plus' %}{% render 'icon-plus' %}{% else %}{% render 'icon-caret' %}{% endif %}</div>
              <div class="accordion-icon-close">{% if settings.accordion_icon == 'plus' %}{% render 'icon-minus' %}{% else %}{% render 'icon-caret' %}{% endif %}</div>
              </div>
              </button>
              <div id="{{ section.id }}-{{ block.id }}-description" class="accordion-panel{% if expanded_initial_state == true %} panel-open{% endif %}" {% if expanded_initial_state == true %}aria-hidden="false"{% else %}aria-hidden="true"{% endif %} aria-labelledby="{{ section.id }}-{{ block.id }}-button">
              {{ product.description | split: specifications_split_word | first }}
              </div>
              </div>
              {% endif %}
              
              {% if block.settings.display_type == 'truncated' %} 
              <div id="productDescriptionTxt" class="product-description-static{% if block.settings.text_indent %} description-indent{% endif %} text-line-clamp-three rte" {{ block.shopify_attributes }}>
                {{ product.description | split: specifications_split_word | first }}
              </div>
              <button id="TxtClampControl" class="product-text-clamp-toggle" tabindex="0" aria-controls="productDescriptionTxt" aria-label="{{ 'products.product.read_more' | t }}">
                <span class="closed">{{ 'products.product.read_more' | t }}</span>
                <span class="open">{{ 'products.product.read_less' | t }}</span>
                </button>
              <script>
                const clamp_toggle = document.getElementById('TxtClampControl');
                const text = document.getElementById('productDescriptionTxt');
                if(clamp_toggle) { 
                clamp_toggle.addEventListener('click', function() {
                  text.classList.toggle('text-line-clamp-three');
                  this.classList.toggle('open');
                });
                }
              </script>
              {% endif %}
              {%- endif -%}
              {% if block.settings.display_type == 'normal' %}
              <div id="productDescriptionTxt" class="product-description-standard product-description-static{% if block.settings.text_indent %} description-indent{% endif %} rte" {{ block.shopify_attributes }}>
                {{ product.description | split: specifications_split_word | first }}
              </div>
              {% endif %}

            {% if block.settings.display_type == 'drawer' %}
            <div class="product-description-standard quick-add-hidden" {{ block.shopify_attributes }}>
            <button class="product-description-drawer--opener link-style--{{ block.settings.description_drawer_link_style }}">
              {{ 'products.product.description' | t }}
              {% if block.settings.description_drawer_link_style == 'arrow' %}{% render 'icon-caret' %}{% endif %}
            </button>
            </div>
            {% endif %}

            {%- when 'product_specifications' -%}
              {% if product.description contains specifications_split_word %}
              <div class="accordion" {{ block.shopify_attributes }}>
              <button class="accordion-title" aria-expanded="false" id="{{ section.id }}-{{ block.id }}-details-button" aria-controls="{{ section.id }}-{{ block.id }}-details-panel">{{ block.settings.title }}
              <div class="accordion-icons-wrapper">
              <div class="accordion-icon-open">{% if settings.accordion_icon == 'plus' %}{% render 'icon-plus' %}{% else %}{% render 'icon-caret' %}{% endif %}</div>
              <div class="accordion-icon-close">{% if settings.accordion_icon == 'plus' %}{% render 'icon-minus' %}{% else %}{% render 'icon-caret' %}{% endif %}</div>  
              </div>
              </button>
              <div class="accordion-panel" id="{{ section.id }}-{{ block.id }}-details-panel" aria-hidden="true" aria-labelledby="{{ section.id }}-{{ block.id }}-details-button">
              {{ product.description | split: specifications_split_word | last }}
              </div>
              </div>
              {% endif %}

            {%- when 'sku' -%}
            {% if product.selected_or_first_available_variant.sku.size > 1 %}
              <p
                class="product__sku text-small no-js-hidden{% if product.selected_or_first_available_variant.sku.size == 0 %} visibility-hidden{% endif %}"
                id="Sku-{{ section.id }}"
                role="status"
                {{ block.shopify_attributes }}
              >
                <span class="visually-hidden">{{ 'products.product.sku' | t }}:</span> {{- product.selected_or_first_available_variant.sku -}}
              </p>
              {% endif %}
            
            {%- when 'custom_liquid' -%}
            <div class="product-custom-liquid-block" {{ block.shopify_attributes }}>
              {{ block.settings.custom_liquid }}
            </div>

            {%- when 'sustainability_card' -%}
              {% assign sustainability_badges = block.settings.badges | newline_to_br | split: '<br />' %}
              <div
                class="product-sustainability-card product-sustainability-card--footer-{{ block.settings.footer_layout }} product-sustainability-card--desktop-image-{{ block.settings.desktop_image_position }}{% if block.settings.mobile_only %} product-sustainability-card--mobile-only{% endif %}{% if block.settings.desktop_image != blank %} product-sustainability-card--has-desktop-image{% endif %}"
                style="
                  --pdp-sustain-margin-top: {{ block.settings.margin_top }}px;
                  --pdp-sustain-margin-bottom: {{ block.settings.margin_bottom }}px;
                  --pdp-sustain-padding-mobile: {{ block.settings.padding_mobile }}px;
                  --pdp-sustain-padding-desktop: {{ block.settings.padding_desktop }}px;
                  --pdp-sustain-radius: {{ block.settings.card_radius }}px;
                  --pdp-sustain-border-width: {{ block.settings.card_border_width }}px;
                  --pdp-sustain-align: {{ block.settings.text_alignment }};
                  --pdp-sustain-bg: {{ block.settings.background_color }};
                  --pdp-sustain-text: {{ block.settings.text_color }};
                  --pdp-sustain-heading: {{ block.settings.heading_color }};
                  --pdp-sustain-accent: {{ block.settings.accent_color }};
                  --pdp-sustain-border: {{ block.settings.border_color }};
                  --pdp-sustain-divider: {{ block.settings.divider_color }};
                  --pdp-sustain-eyebrow-size: {{ block.settings.eyebrow_size }}px;
                  --pdp-sustain-eyebrow-spacing: {{ block.settings.eyebrow_letter_spacing | divided_by: 100.0 }}em;
                  --pdp-sustain-heading-size-mobile: {{ block.settings.heading_size_mobile }}px;
                  --pdp-sustain-heading-size-desktop: {{ block.settings.heading_size_desktop }}px;
                  --pdp-sustain-body-size-mobile: {{ block.settings.body_size_mobile }}px;
                  --pdp-sustain-body-size-desktop: {{ block.settings.body_size_desktop }}px;
                  --pdp-sustain-badge-gap: {{ block.settings.badge_gap }}px;
                  --pdp-sustain-badge-margin-top: {{ block.settings.badge_margin_top }}px;
                  --pdp-sustain-badge-padding-y: {{ block.settings.badge_padding_vertical }}px;
                  --pdp-sustain-badge-padding-x: {{ block.settings.badge_padding_horizontal }}px;
                  --pdp-sustain-badge-radius: {{ block.settings.badge_radius }}px;
                  --pdp-sustain-badge-bg: {{ block.settings.badge_background_color }};
                  --pdp-sustain-badge-text: {{ block.settings.badge_text_color }};
                  --pdp-sustain-badge-border: {{ block.settings.badge_border_color }};
                  --pdp-sustain-badge-size: {{ block.settings.badge_font_size }}px;
                  --pdp-sustain-footer-gap: {{ block.settings.footer_gap }}px;
                  --pdp-sustain-footer-margin-top: {{ block.settings.footer_margin_top }}px;
                  --pdp-sustain-footer-padding-top: {{ block.settings.footer_padding_top }}px;
                  --pdp-sustain-footer-size: {{ block.settings.footer_text_size }}px;
                  --pdp-sustain-logo-width: {{ block.settings.logo_width }}px;
                  --pdp-sustain-desktop-image-width: {{ block.settings.desktop_image_width }}%;
                  --pdp-sustain-desktop-image-radius: {{ block.settings.desktop_image_radius }}px;
                  --pdp-sustain-desktop-image-fit: {{ block.settings.desktop_image_fit }};
                "
                {{ block.shopify_attributes }}
              >
                <div class="product-sustainability-card__content">
                  {% if block.settings.eyebrow != blank %}
                    <div class="product-sustainability-card__eyebrow">
                      {% if block.settings.eyebrow_icon != blank %}
                        <span aria-hidden="true">{{ block.settings.eyebrow_icon }}</span>
                      {% endif %}
                      <span>{{ block.settings.eyebrow | escape }}</span>
                    </div>
                  {% endif %}
                  {% if block.settings.heading != blank %}
                    <h2 class="product-sustainability-card__heading">{{ block.settings.heading | escape }}</h2>
                  {% endif %}
                  {% if block.settings.body != blank %}
                    <div class="product-sustainability-card__body rte">{{ block.settings.body }}</div>
                  {% endif %}
                  {% if block.settings.badges != blank %}
                    <div class="product-sustainability-card__badges">
                      {% for badge in sustainability_badges %}
                        {% assign badge_text = badge | strip %}
                        {% if badge_text != blank %}
                          <span class="product-sustainability-card__badge">{{ badge_text | escape }}</span>
                        {% endif %}
                      {% endfor %}
                    </div>
                  {% endif %}
                  {% if block.settings.give_text != blank or block.settings.logo != blank %}
                    <div class="product-sustainability-card__give{% if block.settings.show_divider %} product-sustainability-card__give--divider{% endif %}">
                      {% if block.settings.logo != blank %}
                        {{ block.settings.logo | image_url: width: 120 | image_tag: loading: 'lazy', class: 'product-sustainability-card__logo' }}
                      {% endif %}
                      {% if block.settings.give_text != blank %}
                        <div class="product-sustainability-card__give-text rte">{{ block.settings.give_text }}</div>
                      {% endif %}
                    </div>
                  {% endif %}
                </div>
                {% if block.settings.desktop_image != blank %}
                  <div class="product-sustainability-card__desktop-image">
                    {% assign sustain_desktop_image_width = 1200 %}
                    {% if block.settings.desktop_image_width < 42 %}
                      {% assign sustain_desktop_image_width = 900 %}
                    {% endif %}
                    {{ block.settings.desktop_image | image_url: width: sustain_desktop_image_width | image_tag: loading: 'lazy' }}
                  </div>
                {% endif %}
              </div>

            {%- when 'feature_chips' -%}
              {% liquid
                assign feature_chips = blank
                if block.settings.metafield_namespace != blank and block.settings.metafield_key != blank
                  assign feature_chips = product.metafields[block.settings.metafield_namespace][block.settings.metafield_key].value
                endif
                assign fallback_chips = block.settings.fallback_chips | newline_to_br | split: '<br />'
              %}
              {% if feature_chips != blank or block.settings.fallback_chips != blank %}
                <div
                  class="product-feature-chips-block"
                  style="
                    --pdp-feature-chips-margin-top: {{ block.settings.margin_top }}px;
                    --pdp-feature-chips-margin-bottom: {{ block.settings.margin_bottom }}px;
                    --pdp-feature-chips-row-gap: {{ block.settings.row_gap }}px;
                    --pdp-feature-chips-column-gap: {{ block.settings.column_gap }}px;
                    --pdp-feature-chips-justify: {{ block.settings.alignment }};
                    --pdp-feature-chip-min-height: {{ block.settings.chip_min_height }}px;
                    --pdp-feature-chip-padding-y: {{ block.settings.padding_vertical }}px;
                    --pdp-feature-chip-padding-x: {{ block.settings.padding_horizontal }}px;
                    --pdp-feature-chip-radius: {{ block.settings.border_radius }}px;
                    --pdp-feature-chip-border-width: {{ block.settings.border_width }}px;
                    --pdp-feature-chip-bg: {{ block.settings.background_color }};
                    --pdp-feature-chip-text: {{ block.settings.text_color }};
                    --pdp-feature-chip-border: {{ block.settings.border_color }};
                    --pdp-feature-chip-font-size-mobile: {{ block.settings.font_size_mobile }}px;
                    --pdp-feature-chip-font-size-desktop: {{ block.settings.font_size_desktop }}px;
                    --pdp-feature-chip-font-weight: {{ block.settings.font_weight }};
                  "
                  {{ block.shopify_attributes }}
                >
                  <div class="pdp-feature-chips">
                    {% if feature_chips != blank %}
                      {% for chip in feature_chips %}
                        <span class="pdp-feature-chip">{{ chip }}</span>
                      {% endfor %}
                    {% else %}
                      {% for chip in fallback_chips %}
                        {% assign chip_text = chip | strip %}
                        {% if chip_text != blank %}
                          <span class="pdp-feature-chip">{{ chip_text | escape }}</span>
                        {% endif %}
                      {% endfor %}
                    {% endif %}
                  </div>
                </div>
              {% endif %}

            {%- when 'trust_strip' -%}
              <div class="product-trust-strip" {{ block.shopify_attributes }}>
                {% for index in (1..3) %}
                  {% assign icon_key = 'row_' | append: index | append: '_icon' %}
                  {% assign title_key = 'row_' | append: index | append: '_title' %}
                  {% assign text_key = 'row_' | append: index | append: '_text' %}
                  {% assign row_title = block.settings[title_key] %}
                  {% assign row_text = block.settings[text_key] %}
                  {% if row_title != blank or row_text != blank %}
                    <div class="product-trust-strip__row">
                      {% if block.settings[icon_key] != blank %}
                        <span class="product-trust-strip__icon" aria-hidden="true">{{ block.settings[icon_key] }}</span>
                      {% endif %}
                      <div class="product-trust-strip__copy">
                        {% if row_title != blank %}
                          <div class="product-trust-strip__title">{{ row_title | escape }}</div>
                        {% endif %}
                        {% if row_text != blank %}
                          <div class="product-trust-strip__text">{{ row_text | escape }}</div>
                        {% endif %}
                      </div>
                    </div>
                  {% endif %}
                {% endfor %}
              </div>

            {%- when 'tabs' -%}
            <script src="{{ 'component-tabs.js' | asset_url }}" defer="defer"></script>

            <style>
              .product-info-tabs .tab-content {
                text-align: {{ block.settings.text_alignment }}
              }
            </style>
            
            {% assign specifications_split_word = 'SPECIFICATIONS' %}

            {% if section.settings.description_split_keyword != blank %}
            {% assign specifications_split_word = section.settings.description_split_keyword %}
            {% endif %}
            
            <div class="product-info-tabs tab-grand" {{ block.shopify_attributes }}>

            <div role="tablist" class="tab-menu tab-style-{{ block.settings.tab_style }} tab-spacing-{{ block.settings.tab_spacing }}{% if block.settings.tab_list_border %} tab-menu-with-border{% endif %}">
            {% if block.settings.description_tab and product.description != blank %}
            <button role="tab" id="productTabZero" class="tab-button" aria-controls="productTabContentZero" aria-selected="true">{{ block.settings.description_label }}</button>
            {% endif %}
            <button role="tab" id="productTabOne" class="tab-button" aria-controls="productTabContentOne" {% if block.settings.description_tab and product.description != blank %}aria-selected="false"{% else %}aria-selected="true"{% endif %}>{{ block.settings.tab_one_label }}</button>
            {% if block.settings.tab_two_label != blank %}<button role="tab" id="productTabTwo" class="tab-button" aria-controls="productTabContentTwo" aria-selected="false">{{ block.settings.tab_two_label }}</button>{% endif %}
            {% if block.settings.tab_three_label != blank %}<button role="tab" id="productTabThree" class="tab-button" aria-controls="productTabContentThree" aria-selected="false">{{ block.settings.tab_three_label }}</button>{% endif %}
            </div>

            {% if block.settings.description_tab and product.description != blank %}
            <div id="productTabContentZero" class="tab-content rte" role="tabpanel" aria-labelled-by="productTabZero">
              {{ product.description | split: specifications_split_word | first }}
            </div>
            {% endif %}
            {% if block.settings.tab_one_label != blank %}
