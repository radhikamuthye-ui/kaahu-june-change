{{ 'swiper.css' | asset_url | stylesheet_tag }}
{{ 'section-collection-metafield-slideshow.css' | asset_url | stylesheet_tag }}

<script src="{{ 'swiper.js' | asset_url }}" defer="defer"></script>
<script src="{{ 'section-collection-metafield-slideshow.js' | asset_url }}" defer="defer"></script>

{%- liquid
  assign slideshow_metafield = collection.metafields[section.settings.metafield_namespace][section.settings.metafield_key]
  assign mobile_slideshow_metafield = collection.metafields[section.settings.mobile_metafield_namespace][section.settings.mobile_metafield_key]
  assign slideshow_eyebrow_metafield = collection.metafields[section.settings.eyebrow_metafield_namespace][section.settings.eyebrow_metafield_key]
  assign slideshow_description_metafield = collection.metafields[section.settings.description_metafield_namespace][section.settings.description_metafield_key]

  if slideshow_eyebrow_metafield == blank
    assign slideshow_eyebrow_metafield = collection.metafields.custom.collection_slideshow_eyebrow
  endif
  if slideshow_eyebrow_metafield == blank
    assign slideshow_eyebrow_metafield = collection.metafields.custom.collection_slideshow_eyebrow_
  endif
  if slideshow_eyebrow_metafield == blank
    assign slideshow_eyebrow_metafield = collection.metafields.custom.collection_slideshow_eyebrows
  endif
  if slideshow_eyebrow_metafield == blank
    assign slideshow_eyebrow_metafield = collection.metafields.custom.slideshow_eyebrow
  endif
  if slideshow_eyebrow_metafield == blank
    assign slideshow_eyebrow_metafield = collection.metafields.custom.collection_eyebrow
  endif
  if slideshow_eyebrow_metafield == blank
    assign slideshow_eyebrow_metafield = collection.metafields.custom.eyebrow
  endif
  if slideshow_eyebrow_metafield == blank
    assign slideshow_eyebrow_metafield = collection.metafields.custom.ss1_eyebrow
  endif

  if slideshow_description_metafield == blank
    assign slideshow_description_metafield = collection.metafields.custom.collection_slideshow_description
  endif
  if slideshow_description_metafield == blank
    assign slideshow_description_metafield = collection.metafields.custom.collection_slideshow_description_
  endif
  if slideshow_description_metafield == blank
    assign slideshow_description_metafield = collection.metafields.custom.collection_slideshow_descriptions
  endif
  if slideshow_description_metafield == blank
    assign slideshow_description_metafield = collection.metafields.custom.slideshow_description
  endif
  if slideshow_description_metafield == blank
    assign slideshow_description_metafield = collection.metafields.custom.collection_description
  endif
  if slideshow_description_metafield == blank
    assign slideshow_description_metafield = collection.metafields.custom.ss1_description
  endif
  if slideshow_description_metafield == blank
    assign slideshow_description_metafield = collection.metafields.custom.description
  endif

  assign slideshow_images = slideshow_metafield.value
  assign mobile_slideshow_images = mobile_slideshow_metafield.value
  assign slideshow_eyebrow = slideshow_eyebrow_metafield.value | default: slideshow_eyebrow_metafield
  assign slideshow_eyebrow_type = slideshow_eyebrow_metafield.type | default: blank
  assign has_slideshow_description = false
  assign slide_count = 0

  if slideshow_images != blank
    for slideshow_image in slideshow_images
      assign slide_count = slide_count | plus: 1
    endfor
  endif

  if slideshow_description_metafield != blank
    assign has_slideshow_description = true
  endif

  assign image_zoom = section.settings.image_zoom | divided_by: 100.0
  assign fade_zoom_amount = section.settings.fade_zoom_amount | divided_by: 100.0
  assign image_zoom_in_start = image_zoom | minus: fade_zoom_amount | at_least: 1.0
  assign image_zoom_out_start = image_zoom | plus: fade_zoom_amount
-%}

{%- style -%}
  .section-{{ section.id }} {
    --cms-height-mobile: min({{ section.settings.height_mobile_vh }}svh, {{ section.settings.height_mobile_max }}px);
    --cms-height-desktop: min({{ section.settings.height_desktop_vh }}svh, {{ section.settings.height_desktop_max }}px);
    --cms-image-fade-duration: {{ section.settings.image_fade_duration }}ms;
    --cms-image-zoom: {{ image_zoom }};
    --cms-image-zoom-in-start: {{ image_zoom_in_start }};
    --cms-image-zoom-out-start: {{ image_zoom_out_start }};
    --cms-control-color: {{ section.settings.slider_color }};
    --cms-overlay: {{ section.settings.overlay_opacity | divided_by: 100.0 }};
    --cms-overlay-strong: {{ section.settings.overlay_opacity | plus: 18 | at_most: 98 | divided_by: 100.0 }};
    --cms-overlay-soft: {{ section.settings.overlay_opacity | times: 0.55 | divided_by: 100.0 }};
    --cms-content-left-mobile: {{ section.settings.content_horizontal_padding_mobile }}px;
    --cms-content-right-mobile: {{ section.settings.content_horizontal_padding_mobile }}px;
    --cms-content-top-mobile: {{ section.settings.content_top_padding_mobile }}px;
    --cms-content-bottom-mobile: {{ section.settings.content_bottom_padding_mobile }}px;
    --cms-content-left-desktop: {{ section.settings.content_horizontal_padding_desktop }}px;
    --cms-content-right-desktop: {{ section.settings.content_horizontal_padding_desktop }}px;
    --cms-content-top-desktop: {{ section.settings.content_top_padding_desktop }}px;
    --cms-content-bottom-desktop: {{ section.settings.content_bottom_padding_desktop }}px;
    --cms-content-max-width: {{ section.settings.content_max_width }}px;
    --cms-heading-margin-bottom: {{ section.settings.heading_bottom_spacing }}px;
    --cms-copy-margin-bottom: {{ section.settings.copy_bottom_spacing }}px;
    --cms-event-margin-top: {{ section.settings.event_top_spacing }}px;
    --cms-eyebrow-font-family: var(--font-accent-family);
    --cms-eyebrow-font-style: var(--font-accent-style);
    --cms-eyebrow-font-weight: var(--font-accent-weight);
    --cms-eyebrow-size-mobile: {{ section.settings.eyebrow_size_mobile }}px;
    --cms-eyebrow-size-desktop: {{ section.settings.eyebrow_size_desktop }}px;
    --cms-heading-font-family: var(--font-heading-family);
    --cms-heading-font-style: var(--font-heading-style);
    --cms-heading-font-weight: {{ section.settings.heading_font_weight }};
    --cms-heading-size-mobile: {{ section.settings.heading_size_mobile }}px;
    --cms-heading-size-desktop: {{ section.settings.heading_size_desktop }}px;
    --cms-heading-line-height: {{ section.settings.heading_line_height | divided_by: 100.0 }};
    --cms-heading-letter-spacing: {{ section.settings.heading_letter_spacing | divided_by: 100.0 }}em;
    --cms-heading-color: {{ section.settings.heading_color }};
    --cms-text-font-family: var(--font-body-family);
    --cms-text-font-style: var(--font-body-style);
    --cms-text-font-weight: {{ section.settings.body_text_font_weight }};
    --cms-text-size-mobile: {{ section.settings.body_text_size_mobile }}px;
    --cms-text-size-desktop: {{ section.settings.body_text_size_desktop }}px;
    --cms-text-line-height: {{ section.settings.body_text_line_height | divided_by: 100.0 }};
    --cms-text-color: {{ section.settings.body_text_color }};
    --cms-event-color: {{ section.settings.event_color }};
    --cms-event-font-family: var(--font-accent-family);
    --cms-event-font-style: var(--font-accent-style);
    --cms-event-font-weight: var(--font-accent-weight);
    --cms-event-label-size-mobile: {{ section.settings.event_label_size_mobile }}px;
    --cms-event-label-size-desktop: {{ section.settings.event_label_size_desktop }}px;
    --cms-event-text-size-mobile: {{ section.settings.event_text_size_mobile }}px;
    --cms-event-text-size-desktop: {{ section.settings.event_text_size_desktop }}px;
  }
{%- endstyle -%}

<div class="collection-metafield-slideshow section-{{ section.id }}">
  {%- if slide_count > 0 -%}
    <div
      class="swiper cms-swiper"
      data-interval="{{ section.settings.autoplay_interval | times: 1000 }}"
      data-speed="{{ section.settings.transition_speed }}"
      data-autoplay="{{ section.settings.enable_autoplay }}"
    >
      <div class="swiper-wrapper">
        {%- for slideshow_image in slideshow_images -%}
          {%- liquid
            assign image_fade_class = 'cms-image--fade-in'
            assign slide_index = forloop.index
            assign mobile_slideshow_image = blank

            if mobile_slideshow_images != blank
              for mobile_image in mobile_slideshow_images
                if forloop.index == slide_index
                  assign mobile_slideshow_image = mobile_image
                  break
                endif
              endfor
            endif

            assign slide_remainder = forloop.index | modulo: 2
            if slide_remainder == 0
              assign image_fade_class = 'cms-image--fade-out'
            endif
          -%}
          <div class="swiper-slide cms-slide" data-index="{{ forloop.index0 }}">
            <picture>
              {%- if mobile_slideshow_image != blank -%}
                <source media="(max-width: 749px)" srcset="{{ mobile_slideshow_image | image_url: width: 1100 }}">
              {%- endif -%}
              {{ slideshow_image | image_url: width: 2400 | image_tag: loading: 'lazy', class: image_fade_class }}
            </picture>
          </div>
        {%- endfor -%}
      </div>
    </div>

    {%- if section.settings.show_controls and slide_count > 1 -%}
      <div class="cms-controls">
        <div class="cms-progress" aria-hidden="true"><span></span></div>
        <button class="cms-toggle" type="button" aria-label="Pause slideshow" aria-pressed="false">
          <svg class="cms-pause-icon" viewBox="0 0 16 16" aria-hidden="true" focusable="false">
            <path d="M5 3h2v10H5V3Zm4 0h2v10H9V3Z" fill="currentColor"/>
          </svg>
          <svg class="cms-play-icon" viewBox="0 0 16 16" aria-hidden="true" focusable="false">
            <path d="M5 3.5 12 8l-7 4.5v-9Z" fill="currentColor"/>
          </svg>
        </button>
      </div>
    {%- endif -%}
  {%- else -%}
        <div class="cms-slide cms-slide--empty" aria-hidden="true"></div>
  {%- endif -%}

  <div class="cms-content">
    {%- if slideshow_eyebrow_metafield != blank -%}
      {%- if slideshow_eyebrow_type == 'rich_text_field' -%}
        <div class="cms-eyebrow cms-eyebrow--richtext">{{ slideshow_eyebrow_metafield | metafield_tag }}</div>
      {%- else -%}
        <span class="cms-eyebrow">{{ slideshow_eyebrow }}</span>
      {%- endif -%}
    {%- endif -%}

    {%- if collection.title != blank -%}
      {%- if section.index == 1 -%}
        <h1 class="cms-heading">{{ collection.title }}</h1>
      {%- else -%}
        <h2 class="cms-heading">{{ collection.title }}</h2>
      {%- endif -%}
    {%- endif -%}

    {%- if has_slideshow_description -%}
      <div class="cms-copy rte">{{ slideshow_description_metafield | metafield_tag }}</div>
    {%- endif -%}

    {%- unless section.settings.event_label == blank and section.settings.event_text == blank -%}
      <div class="cms-event">
        {%- if section.settings.event_label != blank -%}
          <span class="cms-event-label">{{ section.settings.event_label }}</span>
        {%- endif -%}
        {%- if section.settings.event_text != blank -%}
          <span class="cms-event-text">{{ section.settings.event_text }}</span>
        {%- endif -%}
      </div>
    {%- endunless -%}
  </div>
</div>

{% schema %}
