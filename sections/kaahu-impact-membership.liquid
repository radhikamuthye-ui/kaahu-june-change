      "options": [
        {
          "value": "1 / 1",
          "label": "Square"
        },
        {
          "value": "4 / 5",
          "label": "Portrait"
        },
        {
          "value": "3 / 2",
          "label": "Landscape"
        },
        {
          "value": "16 / 9",
          "label": "Widescreen"
        }
      ],
      "default": "4 / 5"
    },
    {
      "type": "select",
      "id": "image_fit",
      "label": "Media fit",
      "options": [
        {
          "value": "cover",
          "label": "Cover"
        },
        {
          "value": "contain",
          "label": "Contain"
        }
      ],
      "default": "cover"
    },
    {
      "type": "select",
      "id": "image_position",
      "label": "Media position",
      "options": [
        {
          "value": "center",
          "label": "Center"
        },
        {
          "value": "top",
          "label": "Top"
        },
        {
          "value": "bottom",
          "label": "Bottom"
        },
        {
          "value": "left",
          "label": "Left"
        },
        {
          "value": "right",
          "label": "Right"
