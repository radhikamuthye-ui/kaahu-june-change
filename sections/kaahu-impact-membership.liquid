    {
      "type": "text",
      "id": "eyebrow",
      "label": "Eyebrow",
      "default": "1% OF SALES FOR THE PLANET"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "A proud member of 1% for the Planet."
    },
    {
      "type": "richtext",
      "id": "body",
      "label": "Body",
      "default": "<p>1% of all sales goes straight to environmental nonprofits — restoring ecosystems, protecting waterways, and supporting the communities that grow our fibres.</p>"
    },
    {
      "type": "header",
      "content": "Media"
    },
    {
      "type": "select",
      "id": "media_type",
      "label": "Media type",
      "options": [
        {
          "value": "image",
          "label": "Image"
        },
        {
          "value": "video",
          "label": "Video"
        }
      ],
      "default": "image"
    },
    {
      "type": "image_picker",
      "id": "image",
      "label": "Image"
    },
    {
      "type": "video",
      "id": "video",
      "label": "Shopify-hosted video"
    },
    {
      "type": "url",
      "id": "mp4_url",
      "label": "MP4 URL",
      "info": "Optional fallback for an MP4 file URL if you are not using a Shopify-hosted video."
    },
    {
      "type": "image_picker",
      "id": "poster_image",
      "label": "Poster image"
    },
    {
      "type": "checkbox",
      "id": "video_autoplay",
      "label": "Autoplay video",
      "default": true
    },
    {
      "type": "checkbox",
      "id": "video_muted",
      "label": "Mute video",
      "default": true
    },
    {
      "type": "checkbox",
      "id": "video_loop",
      "label": "Loop video",
      "default": true
    },
    {
      "type": "checkbox",
      "id": "video_controls",
      "label": "Show video controls",
      "default": false
    },
    {
      "type": "select",
