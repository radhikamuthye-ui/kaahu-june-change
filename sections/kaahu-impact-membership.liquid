{{ 'section-kaahu-impact-membership.css' | asset_url | stylesheet_tag }}

{%- liquid
  assign image_width = section.settings.media_width | times: 20
  assign heading_tag = 'h2'
  if section.index == 1
    assign heading_tag = 'h1'
  endif
-%}

{%- style -%}
  .section-{{ section.id }} {
    --kim-section-bg: {{ section.settings.section_background_color }};
    --kim-container-bg: {{ section.settings.container_background_color }};
    --kim-content-bg: {{ section.settings.content_background_color }};
    --kim-eyebrow-color: {{ section.settings.eyebrow_color }};
    --kim-heading-color: {{ section.settings.heading_color }};
    --kim-body-color: {{ section.settings.body_color }};
    --kim-button-bg: {{ section.settings.button_background_color }};
    --kim-button-text: {{ section.settings.button_text_color }};
    --kim-button-border: {{ section.settings.button_border_color }};
    --kim-button-hover-bg: {{ section.settings.button_hover_background_color }};
    --kim-button-hover-text: {{ section.settings.button_hover_text_color }};
    --kim-button-hover-border: {{ section.settings.button_hover_border_color }};
    --kim-button-height: {{ section.settings.button_height | default: 46 }}px;
    --kim-button-x-padding: {{ section.settings.button_x_padding | default: 28 }}px;
    --kim-button-top-spacing: {{ section.settings.button_top_spacing | default: 28 }}px;
    --kim-button-size-mobile: {{ section.settings.button_size_mobile | default: 14 }}px;
    --kim-button-size-desktop: {{ section.settings.button_size_desktop | default: 14 }}px;
    --kim-button-weight: {{ section.settings.button_font_weight | default: 700 }};
    --kim-button-letter-spacing: {{ section.settings.button_letter_spacing | default: 8 | divided_by: 100.0 }}em;
    --kim-max-width: {{ section.settings.container_max_width }}px;
    --kim-section-padding-top: {{ section.settings.padding_top }}px;
    --kim-section-padding-bottom: {{ section.settings.padding_bottom }}px;
    --kim-container-padding-mobile: {{ section.settings.container_padding_mobile }}px;
    --kim-container-padding-desktop: {{ section.settings.container_padding_desktop }}px;
    --kim-gap-mobile: {{ section.settings.gap_mobile }}px;
    --kim-gap-desktop: {{ section.settings.gap_desktop }}px;
    --kim-radius: {{ section.settings.border_radius }}px;
    --kim-media-width: {{ section.settings.media_width }}%;
    --kim-content-width: {{ section.settings.content_width }}%;
    --kim-media-radius: {{ section.settings.media_border_radius }}px;
    --kim-media-fit: {{ section.settings.image_fit }};
    --kim-media-position: {{ section.settings.image_position }};
    --kim-eyebrow-size: {{ section.settings.eyebrow_font_size }}px;
    --kim-eyebrow-weight: {{ section.settings.eyebrow_font_weight }};
    --kim-eyebrow-letter-spacing: {{ section.settings.eyebrow_letter_spacing | divided_by: 100.0 }}em;
    --kim-heading-size-mobile: {{ section.settings.heading_font_size_mobile }}px;
    --kim-heading-size-desktop: {{ section.settings.heading_font_size_desktop }}px;
    --kim-heading-weight: {{ section.settings.heading_font_weight }};
    --kim-heading-line-height: {{ section.settings.heading_line_height | divided_by: 100.0 }};
    --kim-body-size-mobile: {{ section.settings.body_font_size_mobile }}px;
    --kim-body-size-desktop: {{ section.settings.body_font_size_desktop }}px;
    --kim-body-weight: {{ section.settings.body_font_weight }};
    --kim-body-line-height: {{ section.settings.body_line_height | divided_by: 100.0 }};
  }
{%- endstyle -%}

<section class="kaahu-impact-membership section-{{ section.id }}">
  <div class="kaahu-impact-membership__inner">
    <div class="kaahu-impact-membership__container kaahu-impact-membership__container--desktop-{{ section.settings.desktop_alignment }} kaahu-impact-membership__container--mobile-{{ section.settings.mobile_alignment }}">
      <div class="kaahu-impact-membership__media" style="aspect-ratio: {{ section.settings.media_aspect_ratio }};">
        {%- if section.settings.media_type == 'video' -%}
          {%- if section.settings.video != blank -%}
            {{
              section.settings.video
              | video_tag:
                image_size: '1400x',
                autoplay: section.settings.video_autoplay,
                loop: section.settings.video_loop,
                muted: section.settings.video_muted,
                controls: section.settings.video_controls,
                class: 'kaahu-impact-membership__video'
            }}
          {%- elsif section.settings.mp4_url != blank -%}
            <video
              class="kaahu-impact-membership__video"
              {% if section.settings.video_autoplay %}autoplay{% endif %}
              {% if section.settings.video_loop %}loop{% endif %}
              {% if section.settings.video_muted %}muted{% endif %}
              {% if section.settings.video_controls %}controls{% endif %}
              {% if section.settings.poster_image != blank %}poster="{{ section.settings.poster_image | image_url: width: 1400 }}"{% endif %}
              playsinline
            >
              <source src="{{ section.settings.mp4_url }}" type="video/mp4">
            </video>
          {%- elsif section.settings.poster_image != blank -%}
            {{ section.settings.poster_image | image_url: width: 1400 | image_tag: loading: 'lazy', class: 'kaahu-impact-membership__image' }}
          {%- else -%}
            <div class="kaahu-impact-membership__placeholder">
              {% render 'media-placeholder-lifestyle', style: 3 %}
            </div>
          {%- endif -%}
        {%- elsif section.settings.image != blank -%}
          {{ section.settings.image | image_url: width: image_width | image_tag: loading: 'lazy', class: 'kaahu-impact-membership__image' }}
        {%- else -%}
          <div class="kaahu-impact-membership__placeholder">
            {% render 'media-placeholder-lifestyle', style: 3 %}
          </div>
        {%- endif -%}
      </div>

      <div class="kaahu-impact-membership__content">
        {%- if section.settings.eyebrow != blank -%}
          <div class="kaahu-impact-membership__eyebrow">{{ section.settings.eyebrow }}</div>
        {%- endif -%}

        {%- if section.settings.heading != blank -%}
          <{{ heading_tag }} class="kaahu-impact-membership__heading">{{ section.settings.heading }}</{{ heading_tag }}>
        {%- endif -%}

        {%- if section.settings.body != blank -%}
          <div class="kaahu-impact-membership__body rte">{{ section.settings.body }}</div>
        {%- endif -%}

        {%- if section.settings.show_button and section.settings.button_text != blank -%}
          <a class="kaahu-impact-membership__button kaahu-impact-membership__button--{{ section.settings.button_style }}" href="{{ section.settings.button_link | default: '#' }}">
            {{ section.settings.button_text }}
          </a>
        {%- endif -%}
      </div>
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Kaahu impact membership",
  "tag": "section",
  "class": "section",
  "disabled_on": {
    "groups": ["header", "footer"],
    "templates": ["password", "cart"]
  },
  "settings": [
    {
      "type": "header",
      "content": "Content"
