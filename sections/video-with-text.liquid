{{ 'component-image-with-text.css' | asset_url | stylesheet_tag }}

{%- style -%}
.section-{{ section.id }} .section-inner {
  padding-top: {{ section.settings.top_padding | times: 0.8 }}px;
  padding-bottom: {{ section.settings.bottom_padding | times: 0.8 }}px;  
}

.section-{{ section.id }} .image-with-text--text {
  padding-top: {{ section.settings.txt_padding_top_mobile }}px;
  padding-bottom: {{ section.settings.txt_padding_bottom_mobile }}px;  
}

@media only screen and (min-width: 750px) {
  .section-{{ section.id }} .section-inner {
    padding-top: {{ section.settings.top_padding }}px;
    padding-bottom: {{ section.settings.bottom_padding }}px;
  }  
}

@media only screen and (min-width: 950px) {
  .section-{{ section.id }} .image-with-text--text {
    padding-top: {{ section.settings.txt_vertical_padding }}px;
    padding-bottom: {{ section.settings.txt_vertical_padding }}px;
  }
}
  
{% if section.settings.video_alignment == 'right' %}
.section-{{ section.id }} .image-with-text--image {
  order: 2;
}  
{% endif %}

{% if section.settings.txt_alignment == 'center' %}
.section-{{ section.id }} .image-with-text--inset-image {
  margin: 0 auto;
}
{% endif %}

@media only screen and (min-width: 950px) {
  .iwt-dt-img-position--right .iwt-vborder .image-cover-container::after {
    content: "";
    position: absolute;
    height: calc(100% + {{ section.settings.top_padding | times: 2 }}px);
    width: 1px;
    background: rgba(0,0,0,var(--section-border-opacity));
    top: -{{ section.settings.top_padding }}px;
    left: -{{ section.settings.card_spacing | divided_by: 2 }}px;
  }
  .iwt-dt-img-position--left .iwt-vborder .image-cover-container::after {
    content: "";
    position: absolute;
    height: calc(100% + {{ section.settings.top_padding | times: 2 }}px);
    width: 1px;
    background: rgba(0,0,0,var(--section-border-opacity));
    top: -{{ section.settings.top_padding }}px;
    left: auto;
    right: -{{ section.settings.card_spacing | divided_by: 2 }}px;
  }
  .iwt-vborder.iwt-vborder-color-light .image-cover-container::after {
    background: rgba(255,255,255,var(--section-border-opacity));
  }
}

{%- endstyle -%}

{% if section.settings.card_spacing == 0 %}
{% assign card_space = 'grid-card-spacing-zero' %}
{% endif %}
{% if section.settings.card_spacing == 10 %}
{% assign card_space = 'grid-card-spacing-ten' %}
{% endif %}
{% if section.settings.card_spacing == 20 %}
{% assign card_space = 'grid-card-spacing-twenty' %}
{% endif %}
{% if section.settings.card_spacing == 30 %}
{% assign card_space = 'grid-card-spacing-thirty' %}
{% endif %}
{% if section.settings.card_spacing == 40 %}
{% assign card_space = 'grid-card-spacing-fourty' %}
{% endif %}
{% if section.settings.card_spacing == 50 %}
{% assign card_space = 'grid-card-spacing-fifty' %}
{% endif %}
{% if section.settings.card_spacing == 60 %}
{% assign card_space = 'grid-card-spacing-sixty' %}
{% endif %}
{% if section.settings.card_spacing == 70 %}
{% assign card_space = 'grid-card-spacing-seventy' %}
{% endif %}
{% if section.settings.card_spacing == 80 %}
{% assign card_space = 'grid-card-spacing-eighty' %}
{% endif %}
{% if section.settings.card_spacing == 90 %}
{% assign card_space = 'grid-card-spacing-ninety' %}
{% endif %}
{% if section.settings.card_spacing == 100 %}
{% assign card_space = 'grid-card-spacing-hundred' %}
{% endif %}
{% if section.settings.card_spacing == 110 %}
{% assign card_space = 'grid-card-spacing-hundred-ten' %}
{% endif %}
{% if section.settings.card_spacing == 120 %}
{% assign card_space = 'grid-card-spacing-hundred-twenty' %}
{% endif %}

{% assign video_class = 'standard-video' %}

{% assign mute_setting = false %}
{% assign controls_setting = true %}
{% assign loop_setting = section.settings.enable_video_looping %}
  
{% if section.settings.autoplay %}
  {% assign mute_setting = true %}
  {% assign controls_setting = false %}
  {% assign video_class = 'autoplaying-video' %}
{% endif %}

<div class="section-container section-image-with-text iwt-{{ section.settings.section_size }} iwt-dt-layout-{{ section.settings.dt_image_width }} section-{{ section.id }} color-scheme-{{ section.settings.text_color }} color-scheme-{{ section.settings.bg_color }}">

{% if section.settings.top_border %}
<hr class="section-border section-border-color-{{ section.settings.border_color }} section-border-width-{{ section.settings.border_width }}">
{% endif %}  
  
<div class="section-inner{% if section.settings.border_vertical %} iwt-vborder iwt-vborder-color-{{ section.settings.border_color }}{% endif %}">
<div class="image-with-text-content-container{% if section.settings.card_spacing > 0 or section.settings.inner_padding > 0 %} std-page-padding{% endif %} {{ section.settings.content_width | escape }} {{ card_space }}">

<div class="image-with-text--image image-ratio-{{ section.settings.image_ratio }} {{ video_class }}">
{% if section.settings.video_url != null %}
{% assign video_id = 'vid-' | append: section.id %}
<div class="image-cover-container">
<div class="image-cover-wrapper autoplaying-video">
  {{
    section.settings.video_url
    | video_tag:
      id: video_id,
      image_size: '1600x',
      autoplay: false,
      loop: loop_setting,
      controls: controls_setting,
      muted: mute_setting,
      preload: 'none'
  }} 
</div>
</div>  
{% else %}
<div class="image-cover-container">
<div class="image-cover-wrapper">
{% render 'media-placeholder-scenic', style: 1 %}
</div>
</div>
{% endif %}
</div>

<div class="image-with-text--text align-{{ section.settings.txt_alignment }} vertical-align--{{ section.settings.txt_vertical_alignment }} iwt-text-width--{{ section.settings.text_width }} iwt-text-hoz-position--{{ section.settings.text_horizontal_position }}">
<div class="image-with-text--content">
{% if section.settings.secondary_image %}
<div class="image-with-text--inset-image inset-image-{{ section.settings.secondary_image_scale }}">
{{ section.settings.secondary_image | image_url: width: 800 | image_tag: loading: 'lazy', widths: '180, 280, 400, 600, 800', sizes: '(min-width: 750px) 400px, 60vw' }}
</div> 
{% endif %}

{% for block in section.blocks %}
  {% case block.type %}
    {% when 'caption' %}
    <div class="section-label" {{ block.shopify_attributes }}>{{ block.settings.caption }}</div>
    {% when 'heading' %}
    <h2 class="{{ block.settings.heading_size | escape }}" {{ block.shopify_attributes }}>{{ block.settings.heading }}</h2>
    {% when 'text' %}
    <div class="rte text-{{ block.settings.text_size }}" {{ block.shopify_attributes }}>
      {{ block.settings.description }}
    </div>
    {% when 'button' %}
    <div class="image-with-text-footer button-width--{{ block.settings.button_width_mobile }} section-footer-{{ block.settings.button_colour }}" {{ block.shopify_attributes }}>
    {% if block.settings.btn_style == 'solid' %}
	  <a href="{{ block.settings.btn_link }}" role="link" class="button button--solid">{{ block.settings.btn_txt }}</a>
    {% endif %}
    {% if block.settings.btn_style == 'outline' %}
	  <a href="{{ block.settings.btn_link }}" role="link" class="button button--outline">{{ block.settings.btn_txt }}</a>
    {% endif %}
    {% if block.settings.btn_style == 'link' %}
	  <a href="{{ block.settings.btn_link }}" role="link" class="link--underlined">{{ block.settings.btn_txt }}</a>
    {% endif %}
    </div>
  {% endcase %}
{% endfor %}

</div>
</div>
  
</div>
</div>  

{% if section.settings.bottom_border %}
<hr class="section-border section-border-color-{{ section.settings.border_color }} section-border-width-{{ section.settings.border_width }}">
{% endif %}
  
</div>

