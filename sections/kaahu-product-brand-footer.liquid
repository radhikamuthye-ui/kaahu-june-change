{{ 'section-kaahu-product-brand-footer.css' | asset_url | stylesheet_tag }}

{%- style -%}
  .section-{{ section.id }} {
    --kpbf-page-bg: {{ section.settings.page_background_color }};
    --kpbf-bg: {{ section.settings.background_color }};
    --kpbf-logo: {{ section.settings.logo_color }};
    --kpbf-text: {{ section.settings.text_color }};
    --kpbf-accent: {{ section.settings.accent_color }};
    --kpbf-link: {{ section.settings.link_color }};
    --kpbf-padding-desktop: {{ section.settings.padding_desktop }}px;
    --kpbf-padding-mobile: {{ section.settings.padding_mobile }}px;
    --kpbf-logo-size-desktop: {{ section.settings.logo_size_desktop }}px;
    --kpbf-logo-size-mobile: {{ section.settings.logo_size_mobile }}px;
    --kpbf-tagline-size-desktop: {{ section.settings.tagline_size_desktop }}px;
    --kpbf-tagline-size-mobile: {{ section.settings.tagline_size_mobile }}px;
  }
{%- endstyle -%}

<section class="kaahu-product-brand-footer section-{{ section.id }}">
  <div class="kaahu-product-brand-footer__brand">
    {%- if section.settings.logo_text != blank -%}
      <div class="kaahu-product-brand-footer__logo">{{ section.settings.logo_text }}</div>
    {%- endif -%}
    {%- if section.settings.tagline != blank -%}
      <div class="kaahu-product-brand-footer__tagline">{{ section.settings.tagline }}</div>
    {%- endif -%}
    {%- if section.blocks.size > 0 -%}
      <nav class="kaahu-product-brand-footer__links" aria-label="Product footer links">
        {%- for block in section.blocks -%}
          {%- if block.settings.text != blank and block.settings.link != blank -%}
            <a href="{{ block.settings.link }}" {{ block.shopify_attributes }}>{{ block.settings.text }}</a>
          {%- endif -%}
        {%- endfor -%}
      </nav>
    {%- endif -%}
  </div>
</section>

{% schema %}
{
  "name": "Kaahu product footer",
  "tag": "section",
  "class": "section",
  "settings": [
    { "type": "color", "id": "page_background_color", "label": "Page background", "default": "#ffffff" },
    { "type": "color", "id": "background_color", "label": "Brand band background", "default": "#aa627d" },
    { "type": "color", "id": "logo_color", "label": "Logo color", "default": "#ffffff" },
    { "type": "color", "id": "text_color", "label": "Text color", "default": "#ffffff" },
    { "type": "color", "id": "accent_color", "label": "Tagline color", "default": "#e6b13a" },
    { "type": "color", "id": "link_color", "label": "Link color", "default": "#f4dce6" },
    { "type": "text", "id": "logo_text", "label": "Logo text", "default": "KAAHU" },
    { "type": "text", "id": "tagline", "label": "Tagline", "default": "Be Kind · Be Pure · Be Whole" },
    { "type": "range", "id": "padding_desktop", "label": "Desktop padding", "min": 40, "max": 180, "step": 4, "unit": "px", "default": 80 },
    { "type": "range", "id": "padding_mobile", "label": "Mobile padding", "min": 32, "max": 120, "step": 4, "unit": "px", "default": 56 },
    { "type": "range", "id": "logo_size_desktop", "label": "Logo size desktop", "min": 18, "max": 52, "step": 1, "unit": "px", "default": 28 },
    { "type": "range", "id": "logo_size_mobile", "label": "Logo size mobile", "min": 16, "max": 40, "step": 1, "unit": "px", "default": 24 },
    { "type": "range", "id": "tagline_size_desktop", "label": "Tagline size desktop", "min": 14, "max": 34, "step": 1, "unit": "px", "default": 19 },
    { "type": "range", "id": "tagline_size_mobile", "label": "Tagline size mobile", "min": 13, "max": 28, "step": 1, "unit": "px", "default": 17 }
  ],
  "blocks": [
    {
      "type": "link",
      "name": "Link",
      "settings": [
        { "type": "text", "id": "text", "label": "Text", "default": "Our Promise" },
        { "type": "url", "id": "link", "label": "Link" }
      ]
    }
  ],
  "presets": [
    { "name": "Kaahu product brand footer" }
  ]
}
{% endschema %}
