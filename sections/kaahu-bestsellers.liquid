<section class="kaahu-bestsellers section-{{ section.id }}">
  <div class="kaahu-bestsellers__inner">
    <div class="kaahu-bestsellers__header">
      <div>
        {%- if section.settings.eyebrow != blank -%}
          <p class="kaahu-bestsellers__eyebrow">{{ section.settings.eyebrow }}</p>
        {%- endif -%}
        {%- if section.settings.heading != blank -%}
          {%- if section.index == 1 -%}
            <h1 class="kaahu-bestsellers__heading">{{ section.settings.heading }}</h1>
          {%- else -%}
            <h2 class="kaahu-bestsellers__heading">{{ section.settings.heading }}</h2>
          {%- endif -%}
        {%- endif -%}
      </div>

      {%- if section.settings.show_button and section.settings.button_label != blank -%}
        {%- liquid
          assign button_url = section.settings.button_link
          if button_url == blank and section.settings.collection != blank
            assign button_url = section.settings.collection.url
          endif
        -%}
        <a class="kaahu-bestsellers__button" href="{{ button_url | default: '#' }}">
          <span>{{ section.settings.button_label }}</span>
          {%- if section.settings.show_button_arrow -%}
            <svg viewBox="0 0 24 24" aria-hidden="true" focusable="false">
              <path d="M5 12h13m-5-6 6 6-6 6" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"/>
            </svg>
          {%- endif -%}
        </a>
      {%- endif -%}
    </div>

    {%- assign product_limit = section.settings.products_to_show -%}
    <ul class="kaahu-bestsellers__grid" role="list">
      {%- if section.settings.collection != blank -%}
        {%- for product in section.settings.collection.products limit: product_limit -%}
          {%- liquid
            assign image_override_block = blank
            for block in section.blocks
              if block.type == 'image_override'
                assign override_position = block.settings.card_position | plus: 0
                if block.settings.product != blank and block.settings.product.handle == product.handle
                  assign image_override_block = block
                  break
                elsif block.settings.product == blank and override_position == forloop.index
                  assign image_override_block = block
                endif
              endif
            endfor
          -%}
          {%- render 'kaahu-bestseller-card',
            product: product,
            section: section,
            index: forloop.index,
            image_override_block: image_override_block
          -%}
        {%- endfor -%}
      {%- else -%}
        {%- for index in (1..product_limit) -%}
          {%- render 'kaahu-bestseller-card',
            section: section,
            index: forloop.index,
            placeholder: true
          -%}
        {%- endfor -%}
      {%- endif -%}
    </ul>
  </div>
</section>

