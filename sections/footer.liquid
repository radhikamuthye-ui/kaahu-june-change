{{ 'section-footer.css' | asset_url | stylesheet_tag }}
{% if section.settings.payment_enable %}
{{ 'component-list-payment.css' | asset_url | stylesheet_tag }}
{% endif %}

{% if localization.available_languages.size > 1 %}
<script src="{{ 'market-selector.js' | asset_url }}" defer="defer"></script>
{% endif %}

{% assign social_media_exists = false %}

{% if settings.social_instagram_link != blank or settings.social_facebook_link != blank or settings.social_twitter_link != blank or settings.social_youtube_link != blank or settings.social_vimeo_link != blank or settings.social_tiktok_link != blank or settings.social_snapchat_link != blank or settings.social_pinterest_link != blank or settings.social_spotify_link != blank or settings.social_strava_link != blank or settings.social_linkedin_link != blank %}
  {% assign social_media_exists = true %}
{% endif %}

{% assign numb_blocks = section.blocks.size %}
{% assign count = 0 %}
{% for block in section.blocks %}
{% if block.settings.block_width == 'full_width' %}
{% assign count = count | plus: 1 %}
{% endif %}
{% endfor %}

{% assign flexbasisnumb = numb_blocks | minus: count %}

{%- style -%}
:root {
  --footer-column-gap-desktop: {{ section.settings.footer_horizontal_spacing_desktop }}px;
  --footer-block-h4-size: {{ settings.h4_size_mobile | at_most: settings.body_font_size_mobile | plus: 1 }}px;
  --footer-block-h3-size: {{ settings.h4_size_mobile | at_most: settings.body_font_size_mobile | plus: 2 }}px;
  --footer-column-heading-margin: {{ section.settings.footer_heading_margin | default: 10 }}px;
  --footer-link-vertical-spacing-mobile: {{ section.settings.footer_link_vertical_spacing | at_least: 6 | at_most: 8 }}px;
  --footer-link-vertical-spacing: {{ section.settings.footer_link_vertical_spacing | default: 4 }}px;
}
{% if flexbasisnumb > 1 %}
  .footer-block-column {
    width: 100%;
  }
{% endif %}  
{% if flexbasisnumb == 2 %}
.footer-blocks-container {
  grid-template-columns: repeat(2,1fr);
}
.footer-block-fw {
  grid-column: 1 / span 2;
}
{% endif %}
{% if flexbasisnumb == 3 %}
.footer-blocks-container {
  grid-template-columns: repeat(3,1fr);
}
.footer-block-fw {
  grid-column: 1 / span 3;
}
{% endif %}
{% if flexbasisnumb == 4 %}
.footer-blocks-container {
  grid-template-columns: repeat(4,1fr);
}
.footer-block-fw {
  grid-column: 1 / span 4;
}
{% endif %}
{% if flexbasisnumb == 5 %}
.footer-blocks-container {
  grid-template-columns: repeat(5,1fr);
}
.footer-block-fw {
  grid-column: 1 / span 5;
}
{% endif %}

{% if flexbasisnumb == 6 %}
.footer-blocks-container {
  grid-template-columns: repeat(3,1fr);
}
.footer-block-fw {
  grid-column: 1 / span 3;
}
@media only screen and (min-width: 1025px) {
  .footer-blocks-container {
    grid-template-columns: repeat(6,1fr);
  }
  .footer-block-fw {
    grid-column: 1 / span 6;
  }
}
{% endif %}

.site-footer {
  padding: {{ section.settings.footer_padding_vertical | times: 0.8 | round }}px 0 15px 0;
}

{% if section.settings.main_footer_border > 4 and section.settings.main_footer_border_color == 'dark' %}
.site-footer {
  border-top: 1px solid rgba(0,0,0,{{ section.settings.main_footer_border | divided_by: 100.0 }});
}
{% endif %}

{% if section.settings.main_footer_border > 4 and section.settings.main_footer_border_color == 'light' %}
.site-footer {
  border-top: 1px solid rgba(255,255,255,{{ section.settings.main_footer_border | divided_by: 100.0 }});
}
{% endif %}

.footer-blocks-container {
  padding-bottom: {{ section.settings.footer_padding_bottom | times: 0.8 | round }}px;
}

@media only screen and (min-width: 750px) {
  .site-footer {
    padding: {{ section.settings.footer_padding_vertical }}px 0 15px 0;
  }
  .footer-blocks-container {
    column-gap: {{ section.settings.footer_horizontal_spacing_desktop }}px;
    padding-bottom: {{ section.settings.footer_padding_bottom }}px;
  }  
}

@media only screen and (min-width: 1025px) {
  .footer-blocks-container {
    column-gap: {{ section.settings.footer_horizontal_spacing_desktop }}px;
  }  
}
  
{%- endstyle -%}

{% if true %}
<footer
  id="{{ section.id }}"
  class="site-footer kaahu-footer"
  style="
    --kf-bg: {{ section.settings.kaahu_footer_background }};
    --kf-text: {{ section.settings.kaahu_footer_text }};
    --kf-link: {{ section.settings.kaahu_footer_link }};
    --kf-link-hover: {{ section.settings.kaahu_footer_link_hover }};
    --kf-divider: {{ section.settings.kaahu_footer_divider }};
    --kf-max-width: {{ section.settings.kaahu_footer_max_width }}px;
    --kf-padding-top-mobile: {{ section.settings.kaahu_footer_padding_top_mobile }}px;
    --kf-padding-bottom-mobile: {{ section.settings.kaahu_footer_padding_bottom_mobile }}px;
    --kf-padding-top-desktop: {{ section.settings.kaahu_footer_padding_top_desktop }}px;
    --kf-padding-bottom-desktop: {{ section.settings.kaahu_footer_padding_bottom_desktop }}px;
    --kf-column-gap-desktop: {{ section.settings.kaahu_footer_column_gap_desktop }}px;
    --kf-column-gap-tablet: {{ section.settings.kaahu_footer_column_gap_tablet }}px;
    --kf-row-gap-mobile: {{ section.settings.kaahu_footer_row_gap_mobile }}px;
    --kf-heading-size: {{ section.settings.kaahu_footer_heading_size }}px;
    --kf-heading-weight: {{ section.settings.kaahu_footer_heading_weight }};
    --kf-heading-letter-spacing: {{ section.settings.kaahu_footer_heading_letter_spacing | divided_by: 100.0 }}em;
    --kf-heading-transform: {{ section.settings.kaahu_footer_heading_transform }};
    --kf-heading-link-gap: {{ section.settings.kaahu_footer_heading_link_gap }}px;
    --kf-link-size-mobile: {{ section.settings.kaahu_footer_link_size_mobile }}px;
    --kf-link-size-desktop: {{ section.settings.kaahu_footer_link_size_desktop }}px;
    --kf-link-weight: {{ section.settings.kaahu_footer_link_weight }};
    --kf-link-line-height: {{ section.settings.kaahu_footer_link_line_height | divided_by: 100.0 }};
    --kf-link-spacing: {{ section.settings.kaahu_footer_link_spacing }}px;
    --kf-newsletter-heading-size-mobile: {{ section.settings.kaahu_newsletter_heading_size_mobile }}px;
    --kf-newsletter-heading-size-desktop: {{ section.settings.kaahu_newsletter_heading_size_desktop }}px;
    --kf-newsletter-heading-weight: {{ section.settings.kaahu_newsletter_heading_weight }};
    --kf-newsletter-heading-line-height: {{ section.settings.kaahu_newsletter_heading_line_height | divided_by: 100.0 }};
    --kf-newsletter-heading-form-gap: {{ section.settings.kaahu_newsletter_heading_form_gap }}px;
    --kf-newsletter-heading-color: {{ section.settings.kaahu_newsletter_heading_color }};
    --kf-newsletter-form-width: {{ section.settings.kaahu_newsletter_form_width }}px;
    --kf-newsletter-input-height: {{ section.settings.kaahu_newsletter_input_height }}px;
    --kf-form-bg: {{ section.settings.kaahu_newsletter_form_background }};
    --kf-form-border: {{ section.settings.kaahu_newsletter_form_border }};
    --kf-form-radius: {{ section.settings.kaahu_newsletter_form_radius }}px;
    --kf-button-bg: {{ section.settings.kaahu_newsletter_button_background }};
    --kf-button-color: {{ section.settings.kaahu_newsletter_button_color }};
    --kf-button-hover-bg: {{ section.settings.kaahu_newsletter_button_hover_background }};
    --kf-logo-size: {{ section.settings.kaahu_footer_logo_size }}px;
    --kf-logo-font-size: {{ section.settings.kaahu_footer_logo_font_size }}px;
    --kf-brand-gap: {{ section.settings.kaahu_footer_brand_gap }}px;
    --kf-tagline-size: {{ section.settings.kaahu_footer_tagline_size }}px;
    --kf-tagline-color: {{ section.settings.kaahu_footer_tagline_color }};
    --kf-instagram-size: {{ section.settings.kaahu_footer_instagram_size }}px;
    --kf-instagram-color: {{ section.settings.kaahu_footer_instagram_color }};
    --kf-copyright-size: {{ section.settings.kaahu_footer_copyright_size }}px;
    --kf-copyright-color: {{ section.settings.kaahu_footer_copyright_color }};
    --kf-bottom-gap-mobile: {{ section.settings.kaahu_footer_bottom_gap_mobile }}px;
    --kf-bottom-gap-desktop: {{ section.settings.kaahu_footer_bottom_gap_desktop }}px;
    --kf-bottom-padding-top: {{ section.settings.kaahu_footer_bottom_padding_top }}px;
    --kf-bottom-row-gap: {{ section.settings.kaahu_footer_bottom_row_gap }}px;
  "
>
  <div class="kaahu-footer__inner{% unless section.settings.kaahu_footer_full_width %} page-width{% endunless %}">
    <div class="kaahu-footer__main" aria-label="Footer navigation">
      {%- for block in section.blocks -%}
        {%- if block.type == 'kaahu_footer_column' -%}
          <nav class="kaahu-footer__column" aria-label="{{ block.settings.heading | escape }}" {{ block.shopify_attributes }}>
            {%- if block.settings.heading != blank -%}
              <h2 class="kaahu-footer__heading">{{ block.settings.heading }}</h2>
            {%- endif -%}
            <ul class="kaahu-footer__links" role="list">
              {%- for i in (1..8) -%}
                {%- assign label_key = 'link_' | append: i | append: '_label' -%}
                {%- assign url_key = 'link_' | append: i | append: '_url' -%}
                {%- assign new_tab_key = 'link_' | append: i | append: '_new_tab' -%}
                {%- assign link_label = block.settings[label_key] -%}
                {%- assign link_url = block.settings[url_key] -%}
                {%- assign link_new_tab = block.settings[new_tab_key] -%}
                {%- if link_label != blank -%}
                  <li>
                    <a href="{{ link_url | default: '#' }}"{% if link_new_tab %} target="_blank" rel="noopener noreferrer"{% endif %}>{{ link_label }}</a>
                  </li>
                {%- endif -%}
              {%- endfor -%}
            </ul>
          </nav>
        {%- endif -%}
      {%- endfor -%}

      {%- if section.settings.kaahu_newsletter_show -%}
        <div class="kaahu-footer__newsletter">
          {%- if section.settings.kaahu_newsletter_heading != blank -%}
            <h2 class="kaahu-footer__newsletter-heading">{{ section.settings.kaahu_newsletter_heading }}</h2>
          {%- endif -%}
          {%- form 'customer', id: 'KaahuFooterNewsletter', class: 'kaahu-footer__form' -%}
            <input type="hidden" name="contact[tags]" value="newsletter">
            <div class="kaahu-footer__field">
              <label class="visually-hidden" for="KaahuFooterNewsletterEmail--{{ section.id }}">{{ section.settings.kaahu_newsletter_placeholder }}</label>
              <input
                id="KaahuFooterNewsletterEmail--{{ section.id }}"
                type="email"
                name="contact[email]"
                value="{{ form.email }}"
                placeholder="{{ section.settings.kaahu_newsletter_placeholder | escape }}"
                autocorrect="off"
                autocapitalize="off"
                autocomplete="email"
                required
                {% if form.errors %}
                  autofocus
                  aria-invalid="true"
                  aria-describedby="KaahuFooterNewsletterError--{{ section.id }}"
                {% elsif form.posted_successfully? %}
                  aria-describedby="KaahuFooterNewsletterSuccess--{{ section.id }}"
                {% endif %}
              >
              <button type="submit" aria-label="{{ section.settings.kaahu_newsletter_submit_label | escape }}">
                {%- if section.settings.kaahu_newsletter_submit_text != blank -%}
                  <span>{{ section.settings.kaahu_newsletter_submit_text }}</span>
                {%- else -%}
                  {% render 'icon-arrow' %}
                {%- endif -%}
              </button>
            </div>
            {%- if form.errors -%}
              <small class="kaahu-footer__form-message" id="KaahuFooterNewsletterError--{{ section.id }}">
                {% render 'icon-error' %}{{ form.errors.translated_fields.email | capitalize }} {{ form.errors.messages.email }}
              </small>
            {%- endif -%}
            {%- if form.posted_successfully? -%}
              <div class="kaahu-footer__form-message kaahu-footer__form-message--success" id="KaahuFooterNewsletterSuccess--{{ section.id }}" tabindex="-1" autofocus>{{ 'newsletter.success' | t }}</div>
            {%- endif -%}
          {%- endform -%}
          {%- if section.settings.kaahu_newsletter_consent_before != blank -%}
            <p class="kaahu-footer__consent">
              {{ section.settings.kaahu_newsletter_consent_before }}
              {%- if section.settings.kaahu_newsletter_privacy_label != blank -%}
                <a href="{{ section.settings.kaahu_newsletter_privacy_link | default: '#' }}">{{ section.settings.kaahu_newsletter_privacy_label }}</a>
              {%- endif -%}
              {{ section.settings.kaahu_newsletter_consent_between }}
              {%- if section.settings.kaahu_newsletter_terms_label != blank -%}
                <a href="{{ section.settings.kaahu_newsletter_terms_link | default: '#' }}">{{ section.settings.kaahu_newsletter_terms_label }}</a>
              {%- endif -%}
              {{ section.settings.kaahu_newsletter_consent_after }}
            </p>
          {%- endif -%}
        </div>
      {%- endif -%}
    </div>

    <div class="kaahu-footer__bottom">
      <div class="kaahu-footer__brand">
        {%- if section.settings.kaahu_footer_show_logo -%}
          {%- if section.settings.kaahu_footer_logo != blank -%}
            {%- assign kaahu_footer_logo_width = section.settings.kaahu_footer_logo_size | times: 2 -%}
            {{ section.settings.kaahu_footer_logo | image_url: width: kaahu_footer_logo_width | image_tag: loading: 'lazy', class: 'kaahu-footer__logo-image', alt: shop.name | escape }}
          {%- elsif section.settings.kaahu_footer_logo_text != blank -%}
            <span class="kaahu-footer__logo-text">{{ section.settings.kaahu_footer_logo_text }}</span>
          {%- endif -%}
        {%- endif -%}
        {%- if section.settings.kaahu_footer_tagline != blank -%}
          <span class="kaahu-footer__tagline">{{ section.settings.kaahu_footer_tagline }}</span>
        {%- endif -%}
      </div>

      {%- if section.settings.kaahu_footer_show_instagram and section.settings.kaahu_footer_instagram_link != blank -%}
        <a class="kaahu-footer__instagram" href="{{ section.settings.kaahu_footer_instagram_link }}" aria-label="Instagram" target="_blank" rel="noopener noreferrer">
          {% render 'icon-instagram' %}
        </a>
      {%- endif -%}

      {%- if section.settings.kaahu_footer_copyright != blank -%}
        <div class="kaahu-footer__copyright">{{ section.settings.kaahu_footer_copyright }}</div>
      {%- endif -%}
    </div>
  </div>
</footer>
{% else %}

<div id="{{ section.id }}" class="site-footer text-{{ section.settings.footer_font_size }} footer-heading-size-{{ section.settings.footer_heading_size }} footer-heading-style-{{ section.settings.footer_heading_style }} footer-heading-opacity-{{ section.settings.footer_heading_opacity }} color-scheme-{{ section.settings.text_color }} color-scheme-{{ section.settings.bg_color }} footer-font-case--{{ section.settings.footer_font_case }}">

<div class="footer-blocks-container page-width">
{% for block in section.blocks %}
{% case block.type %}
{% when 'icons' %}
<style>
  .footer-icons-grid {
    padding-top: {{ block.settings.block_padding_top }}px;
    padding-bottom: {{ block.settings.block_padding_bottom }}px;
  }
</style>
<div class="{% if block.settings.block_width == 'full_width' %}footer-block-fw{% else %}footer-block-column{% endif %} footer-icons-block mobile-align-{{ block.settings.alignment_mobile }} align-{{ block.settings.alignment }}" {{ block.shopify_attributes }}>
  {% if block.settings.heading != blank %}<div class="footer-block-heading h4">{{ block.settings.heading }}</div>{% endif %}
  <div class="footer-icons-grid">
    {% if block.settings.icon_one != blank %}
      {% assign icon_one_render_size = block.settings.icon_one_size | times: 2 %}
      <div style="width: {{ block.settings.icon_one_size }}px" class="icon-wrapper">
        {% if block.settings.icon_one_url != blank %}<a href="{{ block.settings.icon_one_url }}">{% endif %}
        {{ block.settings.icon_one | image_url: width: icon_one_render_size | image_tag: loading: 'lazy' }}
        {% if block.settings.icon_one_url != blank %}</a>{% endif %}
      </div>
    {% endif %}
    {% if block.settings.icon_two != blank %}
      {% assign icon_two_render_size = block.settings.icon_two_size | times: 2 %}
      <div style="width: {{ block.settings.icon_two_size }}px" class="icon-wrapper">
        {% if block.settings.icon_two_url != blank %}<a href="{{ block.settings.icon_two_url }}">{% endif %}
        {{ block.settings.icon_two | image_url: width: icon_two_render_size | image_tag: loading: 'lazy' }}
        {% if block.settings.icon_two_url != blank %}</a>{% endif %}
      </div>
    {% endif %}
    {% if block.settings.icon_three != blank %}
      {% assign icon_three_render_size = block.settings.icon_three_size | times: 2 %}
      <div style="width: {{ block.settings.icon_three_size }}px" class="icon-wrapper">
        {% if block.settings.icon_three_url != blank %}<a href="{{ block.settings.icon_three_url }}">{% endif %}
        {{ block.settings.icon_three | image_url: width: icon_three_render_size | image_tag: loading: 'lazy' }}
        {% if block.settings.icon_three_url != blank %}</a>{% endif %}
      </div>
    {% endif %}
    {% if block.settings.icon_four != blank %}
      {% assign icon_four_render_size = block.settings.icon_four_size | times: 2 %}
      <div style="width: {{ block.settings.icon_four_size }}px" class="icon-wrapper">
        {% if block.settings.icon_four_url != blank %}<a href="{{ block.settings.icon_four_url }}">{% endif %}
        {{ block.settings.icon_four | image_url: width: icon_four_render_size | image_tag: loading: 'lazy' }}
        {% if block.settings.icon_four_url != blank %}</a>{% endif %}
      </div>
    {% endif %}
  </div>
</div>
{% when 'logo' %}
{% unless block.settings.logo_full_width %}
<style>
    .footer-logo-block img {
    width: {{ block.settings.logo_size }}px;
    max-width: 100%;
    height: auto;
  }
</style>
{% endunless %}
<style>
  .footer-logo-block {
    opacity: {{ block.settings.logo_opacity }}%;
    padding-top: {{ block.settings.logo_padding_top }}px;
    padding-bottom: {{ block.settings.logo_padding_bottom }}px;
  }
</style>
<div class="{% if block.settings.block_width == 'full_width' %}footer-block-fw{% else %}footer-block-column{% endif %} footer-logo-block footer-image-block-{{ block.settings.image_size }}{% if block.settings.alignment == 'center' %} align-center{% endif %}" {{ block.shopify_attributes }}>
  {% if block.settings.logo %}
  {%- assign logo_alt = block.settings.logo.alt | default: shop.name -%}
  {% assign logo_render_size = block.settings.logo_size | times: 2 %}
  {% if block.settings.logo.width > 2999 %}
  {% assign logo_full_width_render_size = 3000 %}
  {% else %}
  {% assign logo_full_width_render_size = block.settings.logo.width %}  
  {% endif %}
  {% if block.settings.logo_full_width %}
    {{ block.settings.logo | image_url: width: logo_full_width_render_size | image_tag: loading: 'lazy', alt: logo_alt }}
  {% else %}
    {{ block.settings.logo | image_url: width: logo_render_size | image_tag: loading: 'lazy', alt: logo_alt }}
  {% endif %}
  {% endif %}
</div>
 
{% when 'link_list' %}
  <div class="footer-block-linklist-column{% if block.settings.heading != blank and block.settings.list_type_mobile == 'accordion' %} footer-block-linklist-column-expanding{% endif %} footer-block-column{% if block.settings.alignment == 'center' %} align-center{% endif %}{% if block.settings.block_width == 'full_width' %} footer-block-fw{% endif %}{% if block.settings.list_layout == 'horizontal' %} footer-block-hoz-list{% endif %} footer-block-list-layout-mobile-{{ block.settings.list_layout_mobile }}" {{ block.shopify_attributes }}>
    {% if block.settings.heading != blank %}
    <div class="footer-block-heading footer-linklist-heading h4">{{ block.settings.heading | escape }}
    {% if block.settings.list_type_mobile == 'accordion' %}
    <span class="footer-block-heading-icon-open">{% if settings.accordion_icon == 'plus' %}{% render 'icon-plus' %}{% else %}{% render 'icon-caret' %}{% endif %}</span>
    <span class="footer-block-heading-icon-close">{% if settings.accordion_icon == 'plus' %}{% render 'icon-minus' %}{% else %}{% render 'icon-caret' %}{% endif %}</span>
    {% endif %}
    </div>
    {% endif %}
    <div class="footer-block-linklist-ul{% if block.settings.heading != blank and block.settings.list_type_mobile == 'accordion' %} footer-block-linklist-ul-expanding{% endif %}">
    <ul role="list">
      {% for link in block.settings.menu.links %}
      <li><a href="{{ link.url }}">{{ link.title }}</a></li>  
      {% endfor %}
    </ul>
    </div>
  </div>
  
{% when 'text' %}
<div class="footer-block-column footer-block-column--text {{ block.settings.text_size }} ftb-mobile-align-{{ block.settings.alignment_mobile }} align-{{ block.settings.alignment }}{% if block.settings.block_width == 'full_width' %} footer-block-fw{% endif %}" {{ block.shopify_attributes }}>
  {% if block.settings.heading != blank %}<div class="footer-block-heading h4">{{ block.settings.heading | escape }}</div>{% endif %}
  <span class="rte">{{ block.settings.subtext }}</span>
</div>

{% when 'newsletter_signup' %}

<style>
  @media only screen and (max-width: 749px) {
    .site-footer .footer-block-newsletter {
      padding-top: {{ block.settings.padding_top }}px;
      padding-bottom: {{ block.settings.padding_bottom }}px;
    }    
  }
</style>
  
{% if block.settings.block_width == 'full_width' %}
<style>
  .site-footer .footer-block-newsletter {
    padding-top: {{ block.settings.padding_top }}px;
    padding-bottom: {{ block.settings.padding_bottom }}px;
  }
</style>
{% endif %}
{% if block.settings.newsletter_style == 'standard' %}
<style>
.site-footer .newsletter-form__field-wrapper .field {
  background: rgba(255,255,255,{{ block.settings.border_opacity | divided_by: 100.0 }});
  color: rgba(var(--color-foreground-rgb),0.7);
  border: 0;
}
.site-footer .footer-block-newsletter-style-standard .newsletter-form__field-wrapper .field:focus-within {
  background: rgba(255,255,255,{{ block.settings.border_opacity | plus: 30 | at_most: 100 | divided_by: 100.0 }});
}
.site-footer .newsletter-form__field-wrapper .field__button {
  color: rgba(var(--color-foreground-rgb),0.7);
}
</style>
{% endif %}

<style>
.footer-block-newsletter-style-minimal .newsletter-form__field-wrapper .field {
  border-bottom: 1px solid rgba(var(--color-foreground-rgb),{{ block.settings.border_opacity | divided_by: 100.0 }});
}
.color-scheme-fg-01 .footer-block-newsletter-style-minimal .newsletter-form__field-wrapper .field {
  border-bottom: 1px solid rgba(var(--color-accent-one-rgb),{{ block.settings.border_opacity | divided_by: 100.0 }});
}
.color-scheme-fg-02 .footer-block-newsletter-style-minimal .newsletter-form__field-wrapper .field {
  border-bottom: 1px solid rgba(var(--color-accent-two-rgb),{{ block.settings.border_opacity | divided_by: 100.0 }});
}
.color-scheme-fg-03 .footer-block-newsletter-style-minimal .newsletter-form__field-wrapper .field {
  border-bottom: 1px solid rgba(var(--color-accent-three-rgb),{{ block.settings.border_opacity | divided_by: 100.0 }});
}
.color-scheme-fg-04 .footer-block-newsletter-style-minimal .newsletter-form__field-wrapper .field {
  border-bottom: 1px solid rgba(var(--color-accent-four-rgb),{{ block.settings.border_opacity | divided_by: 100.0 }});
}
.color-scheme-fg-05 .footer-block-newsletter-style-minimal .newsletter-form__field-wrapper .field {
  border-bottom: 1px solid rgba(var(--color-accent-five-rgb),{{ block.settings.border_opacity | divided_by: 100.0 }});
}
</style>

  
{% if block.settings.newsletter_style == 'outline' %}
<style>
.site-footer .footer-block-newsletter-style-outline .newsletter-form__field-wrapper .field {
  background: none !important;
