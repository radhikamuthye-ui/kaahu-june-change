{% assign header_transparent = false %}
{% assign header_semi_transparent = false %}
{% assign header_color_scheme_singular = false %}

{% if settings.bar_bg_col == settings.dd_bg_col %}
{% assign header_color_scheme_singular = true %}
{% endif %}

{% if template == 'index' and section.settings.trans_hp %}
{% assign header_transparent = true %}
{% endif %}

{% if settings.bar_bg_col.alpha < 1 %}
{% assign header_semi_transparent = true %}  
{% endif %}

{% assign language_selector_header = section.settings.enable_language_selector %}
{% assign language_selector_drawer = section.settings.enable_language_selector %}

{% assign total_char_count = 0 %}
{% assign nb_base_height = section.settings.nav_bar_height_mobile %}
{% assign nb_base_height_dt = section.settings.nav_bar_height %}

{% assign logo_max_height = section.settings.nav_bar_height_mobile %}
{% assign logo_max_height_dt = section.settings.nav_bar_height %}

{% assign requires_stack = false %}

{% if section.settings.logo_dt_position == 'top_center' or section.settings.logo_dt_position == 'top_left' %}
{% assign requires_stack = true %}
{% endif %}

{% if section.settings.desktop_nav_position == 'fly-out' %}
{% assign requires_stack = false %}
{% endif %}

{% if requires_stack %}
{% assign nb_base_height_dt = nb_base_height_dt | plus: 40 %}
{% endif %}

{% assign menu_calc_font_scale = section.settings.nav_font_size_desktop | times: 0.75 | round: 0 %}

{% for link in section.settings.main_menu.links %}
  {% assign char_count = link.title | size %}
  {% assign total_char_count = total_char_count | plus: char_count %}
  {% assign main_menu_width = total_char_count | times: menu_calc_font_scale %}
{% endfor %}

{% assign main_menu_link_count = section.settings.main_menu.links.size %}

{% assign mm_total_gap = main_menu_link_count | times: section.settings.desktop_primary_menu_spacing %}

{% assign main_menu_width = main_menu_width | plus: mm_total_gap %}

{% assign shopping_tools_width = 50 %}
{% assign sm_total_char_count = 0 %}

{% for link in section.settings.secondary_menu_desktop.links limit: 2 %}
  {% assign sm_char_count = link.title | size | times: 12 %}
  {% assign sm_total_char_count = sm_total_char_count | plus: sm_char_count %}
{% endfor %}

{% assign shopping_tools_width = shopping_tools_width | plus: sm_total_char_count %}

{% if section.settings.search_enable %}
  {% assign shopping_tools_width = shopping_tools_width | plus: 50 %}  
{% endif %}

{% if shop.customer_accounts_enabled and section.settings.account_enable %}
  {% assign shopping_tools_width = shopping_tools_width | plus: 50 %}
{% endif %}

{% if section.settings.enable_international and localization.available_countries.size > 1 %}
  {% assign shopping_tools_width = shopping_tools_width | plus: 65 %}
{% endif %}

{% if section.settings.enable_language_selector and localization.available_languages.size > 1 %}
  {% assign shopping_tools_width = shopping_tools_width | plus: 65 %}
{% endif %}

{% if section.settings.cart_ui == 'word' %}
  {% assign shopping_tools_width = shopping_tools_width | plus: 60 %}
{% endif %}

{% if shop.customer_accounts_enabled and section.settings.account_enable and section.settings.account_ui == 'word' %}
  {% assign shopping_tools_width = shopping_tools_width | plus: 60 %}
{% endif %}

{% if section.settings.search_enable and section.settings.search_ui == 'word'%}
  {% assign shopping_tools_width = shopping_tools_width | plus: 60 %}  
{% endif %}

{% assign menu_width_estimate = main_menu_width | plus: shopping_tools_width %}

{% if section.settings.header_hoz_width == 'fit-margins' or section.settings.header_bar_width == 'page-margins' %}
  {% assign header_margin_total_width = settings.page_margin_desktop | times: 2 %}
  {% assign menu_width_estimate = menu_width_estimate | plus: header_margin_total_width %}
{% endif %}

{% assign link_list_breakpoint = 'bp-standard' %}

{% comment %} MENU BREAKPOINT - LOGO LEFT {%endcomment %}
{% comment %} BREAKPOINT FACTORS IN FONT SIZE, EXISTENCE OF SECONDARY MENU, MARKET SELECTOR, LANGUAGE SELECTOR AND WORD-BASED SHOPPING TOOLS {% endcomment %}
{% if section.settings.logo_dt_position == 'left' and section.settings.desktop_nav_position == 'inline' %}

    {% if main_menu_width > 500 and section.settings.logo_size_dt > 190 %}
    {% assign link_list_breakpoint = 'bp-wide' %}
    {% endif %}

    {% if menu_width_estimate > 800 %}
    {% assign link_list_breakpoint = 'bp-wide' %}
    {% endif %}

    {% if main_menu_width > 500 and section.settings.logo_size_dt > 290 %}
    {% assign link_list_breakpoint = 'bp-extra-wide' %}
    {% endif %}

    {% if menu_width_estimate > 900 %}
    {% assign link_list_breakpoint = 'bp-extra-wide' %}
    {% endif %}

    {% if menu_width_estimate > 1000 %}
    {% assign link_list_breakpoint = 'bp-extra-extra-wide' %}
    {% endif %}

    {% if menu_width_estimate > 1200 %}
    {% assign link_list_breakpoint = 'bp-null' %}
    {% endif %}

{% endif %}
{% comment %} // END MENU BREAKPOINT - LOGO LEFT {%endcomment %}

{% comment %} MENU BREAKPOINT - LOGO CENTER {% endcomment %}
{% comment %} BREAKPOINT FACTORS IN LOGO SIZE AND FONT SIZE {% endcomment %}
{% if section.settings.logo_dt_position == 'center' and section.settings.desktop_nav_position == 'inline' %}

    {% if main_menu_width > 300 %}
    {% assign link_list_breakpoint = 'bp-wide' %}
    {% endif %}

    {% if main_menu_width > 400 and section.settings.logo_size_dt > 250 %}
    {% assign link_list_breakpoint = 'bp-extra-wide' %}
    {% endif %}

    {% if main_menu_width > 500 %}
    {% assign link_list_breakpoint = 'bp-extra-wide' %}
    {% endif %}

    {% if main_menu_width > 600 %}
    {% assign link_list_breakpoint = 'bp-extra-extra-wide' %}
    {% endif %}

    {% if main_menu_width > 600 %}
    {% assign link_list_breakpoint = 'bp-null' %}
    {% endif %}

{% endif %}
{% comment %} // END MENU BREAKPOINT - LOGO CENTER {% endcomment %}

{% if section.settings.desktop_nav_breakpoint == 'small' %}
  {% assign link_list_breakpoint = 'bp-standard' %}
{% endif %}

{% if section.settings.desktop_nav_breakpoint == 'medium' %}
  {% assign link_list_breakpoint = 'bp-wide' %}
{% endif %}

{% if section.settings.desktop_nav_breakpoint == 'large' %}
  {% assign link_list_breakpoint = 'bp-extra-wide' %}
{% endif %}

{% if section.settings.desktop_nav_breakpoint == 'xl' %}
  {% assign link_list_breakpoint = 'bp-extra-extra-wide' %}
{% endif %}


{% assign equal_selector = false %}
{% if section.settings.search_enable and section.settings.search_ui == 'word' %}
{% assign equal_selector = true %}  
{% endif %}

{% assign navcornerradius = 'none' %}
{% if section.settings.header_corner_radius > 0 and section.settings.header_corner_radius < 30 %}
{% assign navcornerradius = 'true' %}
{% endif %}
{% if section.settings.header_corner_radius > 30 %}
{% assign navcornerradius = 'large' %}
{% endif %}

{% assign half_nb_base_height_dt = nb_base_height_dt | divided_by: 2 %}

{% assign cart_label = 'shopify.checkout.general.cart' | t %}
{% assign cart_label_length = cart_label | size %}

{%- style -%}
  :root {
    --site-header-height-mobile: {{ nb_base_height }}px;
    --site-header-height-desktop: {{ nb_base_height_dt }}px;
    --site-header-transparent-color: 255,255,255;
    --site-header-primary-menu-spacing: {{ section.settings.desktop_primary_menu_spacing | divided_by: 2 }}px;
    --site-header-drawer-margin-mobile: {{ section.settings.header_drawer_margin }}px;
    --site-header-drawer-margin-desktop: {{ section.settings.header_drawer_margin_desktop }}px;
    --site-header-close-button-padding: {{ section.settings.header_drawer_margin | plus: 1 | at_least: 16 }}px;
    --site-header-search-dropdown-corner-radius: {{ section.settings.header_corner_radius | at_most: half_nb_base_height_dt }}px;
    --site-header-border-opacity: {{ section.settings.header_border_opacity | divided_by: 100.0 }};
    --site-header-drawer-menu-border-opacity: 0.15;
    --site-header-cart-qty-font-size: {{ section.settings.cart_ui_font_size }}px;
    --site-header-cart-bubble-color: {{ section.settings.cart_bubble_color_text }};
    --site-header-cart-bubble-bg: {{ section.settings.cart_bubble_color_bg }};
    --kaahu-menu-panel-width: {{ section.settings.kaahu_menu_panel_width | default: 860 }}px;
    --kaahu-menu-panel-left: {{ section.settings.kaahu_menu_panel_left | default: 80 }}px;
    --kaahu-story-panel-width: {{ section.settings.kaahu_story_panel_width | default: 430 }}px;
    --kaahu-story-panel-right: {{ section.settings.kaahu_story_panel_right | default: 72 }}px;
    --kaahu-menu-panel-top-gap: {{ section.settings.kaahu_menu_panel_top_gap | default: 0 }}px;
    --kaahu-menu-panel-radius: {{ section.settings.kaahu_menu_panel_radius | default: 16 }}px;
    --kaahu-menu-panel-padding-x: {{ section.settings.kaahu_menu_panel_padding_x | default: 54 }}px;
    --kaahu-menu-panel-padding-y: {{ section.settings.kaahu_menu_panel_padding_y | default: 36 }}px;
    --kaahu-menu-column-gap: {{ section.settings.kaahu_menu_column_gap | default: 74 }}px;
    --kaahu-menu-row-gap: {{ section.settings.kaahu_menu_row_gap | default: 18 }}px;
    --kaahu-menu-top-font-size: {{ section.settings.kaahu_menu_top_font_size | default: section.settings.nav_font_size_desktop }}px;
    --kaahu-menu-top-letter-spacing: {{ section.settings.kaahu_menu_top_letter_spacing | default: 18 | divided_by: 100.0 }}em;
    --kaahu-menu-top-font-weight: {{ section.settings.kaahu_menu_top_font_weight | default: 600 }};
    --kaahu-menu-dropdown-font-size: {{ section.settings.kaahu_menu_dropdown_font_size | default: section.settings.font_size_dropdown }}px;
    --kaahu-menu-dropdown-letter-spacing: {{ section.settings.kaahu_menu_dropdown_letter_spacing | default: 14 | divided_by: 100.0 }}em;
    --kaahu-menu-dropdown-font-weight: {{ section.settings.kaahu_menu_dropdown_font_weight | default: 600 }};
    --kaahu-menu-heading-font-size: {{ section.settings.kaahu_menu_heading_font_size | default: section.settings.font_size_dropdown_category_heading }}px;
    --kaahu-menu-heading-letter-spacing: {{ section.settings.kaahu_menu_heading_letter_spacing | default: 16 | divided_by: 100.0 }}em;
    --kaahu-menu-heading-font-weight: {{ section.settings.kaahu_menu_heading_font_weight | default: 600 }};
    --kaahu-menu-heading-color: {{ section.settings.kaahu_menu_heading_color | default: '#d7b44d' }};
    --kaahu-menu-link-color: {{ section.settings.kaahu_menu_link_color | default: settings.dd_txt_col }};
  }

  {% if section.settings.trans_header_color == 'inherit' %}
  :root {
    --site-header-transparent-color: {{ settings.bar_fg_col.red }}, {{ settings.bar_fg_col.green }}, {{ settings.bar_fg_col.blue }};
  }
  {% endif %}

  {% if section.settings.desktop_primary_menu_spacing > 34 %}
  :root {
    --site-header-inline-dropdown-offset: 0px;
  }
  {% else %}
  :root {
    --site-header-inline-dropdown-offset: -10px;
  }    
  {% endif %}  

  {% unless header_transparent or header_semi_transparent %}
  body:has(.header-bar--full) .content-for-layout {
    padding-top: {{ nb_base_height }}px; 
  }
  body:has(.header-bar--full):has(.full-width-announcement-bar) .content-for-layout {
    padding-top: {{ nb_base_height | plus: 35 }}px; 
  }
  @media only screen and (min-width: 1025px) {
    body:has(.header-bar--full) .content-for-layout {
      padding-top: {{ nb_base_height_dt }}px; 
    }    
    body:has(.header-bar--full):has(.full-width-announcement-bar) .content-for-layout {
      padding-top: {{ nb_base_height_dt | plus: 35 }}px; 
    }
  }
  {% endunless %}

  .nav-ul--primary {
    font-size: {{ section.settings.nav_font_size_mobile }}px;
  }
  .hdr-item-market-selector, .hdr-item-language-selector {
    font-size: {{ section.settings.nav_font_size_desktop | at_most: 13 }}px;
  }
  .nav-drawer--secondary-menu, .mob-drawer-market-selector, .header-drawer-language-selector {
    font-size: {{ section.settings.nav_font_size_mobile_secondary_menu }}px;
  }
  .drawer-market-selector-bullet {
    font-size: {{ section.settings.nav_font_size_mobile_secondary_menu | minus: 2 }}px;
  }
  {% if section.settings.nav_font_case == 'caps' %}
  .nav-ul--primary, .hdr-nav-desktop, .header-bar-inner, .nav-secondary-fo-back-button, .hdr-st-item-label, .mob-parent-accordion-button {
    text-transform: uppercase;
  }
  {% if section.settings.dropdown_font_case == 'normal' %}
  .mob-secondary-level-ul, .dd-nav-dd-contents {
    text-transform: none;
  }
  {% endif %}
  {% endif %}
  .header-bar-inner {
    border-radius: {{ section.settings.header_corner_radius | at_most: half_nb_base_height_dt }}px;
  }
  {% if section.settings.header_bar_width == 'page-margins' and half_nb_base_height_dt > 32 and section.settings.logo_dt_position == 'top_left' %}
  .header-bar-inner {
    border-radius: {{ section.settings.header_corner_radius | at_most: 32 }}px;
  }
  .dd-panel-full-width {
    border-radius: {{ section.settings.header_corner_radius | at_most: 32 }}px !important;
  }
  {% endif %}
  {% if section.settings.header_bar_width == 'page-margins' and half_nb_base_height_dt > 32 and section.settings.logo_dt_position == 'top_center' %}
  .header-bar-inner {
    border-radius: {{ section.settings.header_corner_radius | at_most: 32 }}px;
  }  
  .dd-panel-full-width {
    border-radius: {{ section.settings.header_corner_radius | at_most: 32 }}px !important;
  }
  {% endif %}
  .header-bar-inner {
    height: {{ nb_base_height }}px;
    border-bottom: 1px solid rgba(0,0,0,{{ section.settings.header_border_opacity | divided_by: 100.0 }});
  }
  .header-bar--page-margins .header-bar-inner {
    border: 1px solid rgba(0,0,0,{{ section.settings.header_border_opacity | divided_by: 100.0 }});
  }
  .site-header-bottom-border {
    opacity: {{ section.settings.header_border_opacity | divided_by: 100.0 }};
  }

  {% if section.settings.header_bar_width == 'full' %}
  .header-bar-inner {
    box-shadow: 0px 6px 7px -3px rgba(0,0,0,{{ section.settings.header_shadow_opacity | divided_by: 200.0 }});
  }
  {% else %}
  .header-bar-inner {
    box-shadow: 0px 0px 8px 0px rgba(0,0,0,{{ section.settings.header_shadow_opacity | divided_by: 200.0 }});
  }    
  {% endif %}
  body:not(:has(.dd-panel-adaptive-width)):not(:has(.header-bar--page-margins)) .header-bar-inner.hovered {
    box-shadow: none !important;
  }
  .header-nav-desktop-dd-panel {
    border: 1px solid rgba(0,0,0,{{ section.settings.header_border_opacity | divided_by: 100.0 }});
    box-shadow: 0px 6px 7px -3px rgba(0,0,0,{{ section.settings.header_shadow_opacity | divided_by: 200.0 }});
  }
  {% if section.settings.header_dropdown_panel_width == 'dd-panel-adaptive-width' or section.settings.header_bar_width == 'page-margins' %}
  .header-nav-desktop-dd-panel {
    border: 1px solid rgba(0,0,0,{{ section.settings.header_border_opacity | divided_by: 100.0 }});
  }  
  .header-nav-desktop-dd-panel.dd-panel-full-width {
    border-top: 0;
  }
  {% endif %}
  {% if section.settings.header_shadow_opacity > 1 %}
  .header-bar-inner {
    transition: 0.05s linear;
  }  
  {% endif %}

  .header-mobile-logo .header--logo {
    width: {{ section.settings.logo_size }}px;
    height: {{ logo_max_height | minus: 10 }}px;
  }

  .header-mobile-logo .header--logo img {
    height: {{ logo_max_height | minus: 10 }}px;
  }
  
  {% if section.settings.logo_size > logo_max_height %}
  .header-mobile-logo .header--logo.hl-ratio-portrait, .header-mobile-logo .header--logo.hl-ratio-square {
    width: auto;
    height: {{ logo_max_height | minus: 10 }}px;
  }
  .header-mobile-logo .header--logo.hl-ratio-portrait img, .header-mobile-logo .header--logo.hl-ratio-square img {
    width: auto;
    height: {{ logo_max_height | minus: 10 }}px;
  }  
  {% endif %}
  
  @media only screen and (min-width: 1025px) {
    .header-bar-inner {
      height: {{ nb_base_height_dt }}px;
    }
    .header-bar-inner-top {
      height: {{ nb_base_height_dt | minus: 40 }}px;
    }
    .hdr-nav-desktop, .header-bar--shopping-tools {
      font-size: {{ section.settings.nav_font_size_desktop }}px;
    }
    .dd-nav-dd-contents, .nav-ul--primary {
      font-size: {{ section.settings.font_size_dropdown }}px;
    }
    .nav-drawer--secondary-menu {
      font-size: {{ section.settings.font_size_dropdown | at_most: 16 }}px;
    }
    .dd-nav-dd-contents .dd-nav-column-heading {
      font-size: {{ section.settings.font_size_dropdown_category_heading }}px;
    }
  }

  {% if section.settings.search_enable and section.settings.logo_mobile_position == 'center' %}
  @media only screen and (max-width: 450px) {
    .header-mobile-logo .header--logo {
      max-width: 140px;
    }
  }
  {% endif %}

  {% if section.settings.search_enable and section.settings.search_ui == 'word' %}
  @media only screen and (max-width: 450px) {
    .header-mobile-logo .header--logo {
      max-width: 80px;
    }
  }
  {% endif %}
  
  @media only screen and (min-width: 1025px) {
    .header-desktop-logo .header--logo {
      width: {{ section.settings.logo_size_dt }}px;
      height: {{ logo_max_height_dt | minus: 10 }}px;
    }
    .header-desktop-logo .header--logo img {
      width: {{ section.settings.logo_size_dt }}px;
      height: {{ logo_max_height_dt | minus: 10 }}px;
    }    
  }
  
  {% if section.settings.logo_size_dt > logo_max_height_dt %}
  @media only screen and (min-width: 1025px) {
    .header-desktop-logo .header--logo.hl-ratio-portrait, .header--logo.hl-ratio-square {
      width: auto;
      height: {{ logo_max_height_dt | minus: 10 }}px;
    }
    .header-desktop-logo .header--logo.hl-ratio-portrait img, .header-desktop-logo .header--logo.hl-ratio-square img {
      width: auto;
      height: {{ logo_max_height_dt | minus: 10 }}px;
    }  
  }
  {% endif %}
  
  {% if header_transparent or header_semi_transparent %}
  body:has(.header-bar--full) .content-for-layout {
    padding-top: 0; 
  }
  .landing-screen-section.banner-style-fullscreen, 
  .shopify-design-mode .banner-style-fullscreen {
    height: 100vh !important;
  }
  body:has(.full-width-announcement-bar) .landing-screen-section.banner-style-fullscreen, 
  .shopify-design-mode .banner-style-fullscreen {
    height: calc(100vh - 35px) !important; 
  }
  body:has(.hab-index-1.full-width-announcement-bar) .content-for-layout {
    padding-top: 35px; 
  }
  .shopify-design-mode body:has(.full-width-announcement-bar) .content-for-layout {
    padding-top: 35px; 
  }
  body:has(.hab-index-2.full-width-announcement-bar) .content-for-layout {
    padding-top: 0;
  }
  .hdr-trans-hp .header-bar-inner {
    background: none !important;
    color: rgb(var(--site-header-transparent-color));
    border: 0;
    border-bottom: 1px solid rgba(var(--site-header-transparent-color),{{ section.settings.header_border_opacity | divided_by: 100.0 }});
    box-shadow: none;
  }
  .hdr-trans-hp.header-bar--page-margins .header-bar-inner {
    border: 1px solid rgba(var(--site-header-transparent-color),{{ section.settings.header_border_opacity | divided_by: 100.0 }});
