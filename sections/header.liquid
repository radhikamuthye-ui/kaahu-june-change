    visibility: visible;
    opacity: 1;
  }
  .header-bar-inner.hovered {
    background: var(--color-menu-bar-background) !important;
    color: var(--color-menu-text) !important;
    border-bottom: 1px solid rgba(0,0,0,{{ section.settings.header_border_opacity | divided_by: 100.0 }});
