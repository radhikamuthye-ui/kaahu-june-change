{{ 'section-rich-text.css' | asset_url | stylesheet_tag }}

{% assign bg_img_filter = section.settings.bg_image_blur | divided_by: 2 %}
{% assign bg_img_darkness = section.settings.bg_image_darken | divided_by: 100.0 %}

{% assign heading_html_tag = 'h2' %}
{% if section.index == 1 %}
{% assign heading_html_tag = 'h1' %}  
{% endif %}

{%- style -%}  
  .section-{{ section.id }} {
  	background: {{ section.settings.bg_color }};  
  }
  .section-{{ section.id }} .section-inner {
    padding-top: {{ section.settings.padding_top | times: 0.8 | round: 0 }}px;
    padding-bottom: {{ section.settings.padding_bottom | times: 0.8 | round: 0 }}px;
  }
  .section-{{ section.id }} .rich-text-section-bg-image-overlay {
    background: rgba(0,0,0,{{ bg_img_darkness }});
  }
  {% if section.settings.bg_image_blur > 0 %}
  .section-{{ section.id }} .rich-text-section-bg-image img {
    filter: blur({{ bg_img_filter }}px);
    width: 110%;
    height: 110%;
    left: -5%;
    top: -5%;
  }
  {% endif %}
  {% if section.settings.content_alignment == 'left' %}
  .section-{{ section.id }} .rich-text-content {
    justify-content: flex-start;
  }
  {% endif %}
  {% if section.settings.content_alignment == 'right' %}
  .section-{{ section.id }} .rich-text-content {
    justify-content: flex-end;
  }
  {% endif %}

  @media screen and (min-width: 750px) {
    .section-{{ section.id }} .section-inner {
      padding-top: {{ section.settings.padding_top }}px;
      padding-bottom: {{ section.settings.padding_bottom }}px;
    }
  }

{%- endstyle -%}

<div class="section-rich-text content-container section-{{ section.id }} color-scheme-{{ section.settings.bg_color }}">

{% if section.settings.top_border %}
<hr class="section-border section-border-color-{{ section.settings.border_color }} section-border-width-{{ section.settings.border_width }}">
{% endif %}
  
<div class="section-inner">
  
  <div class="rich-text-content {{ section.settings.content_width }} content-horizontal-position--{{ section.settings.content_horizontal_position }} color-scheme-{{ section.settings.text_color }}">
    <div class="rich-text__blocks">
      {%- for block in section.blocks -%}
        {%- case block.type -%}     
          
          {%- when 'countdown' -%}
          <div class="rich-text__countdown align-{{ block.settings.alignment }}" {{ block.shopify_attributes }}>

          <div class="countdown-container" id="countdown-wrapper"
               data-store-time="{{ 'now' | date: '%Y-%m-%dT%H:%M:%S' }}"
               data-year="{{ block.settings.target_year }}"
               data-month="{{ block.settings.target_month }}"
               data-day="{{ block.settings.target_day }}"
               data-hour="{{ block.settings.target_hour }}"
               data-minute="{{ block.settings.target_minute }}">
            <div class="countdown-timer{% if block.settings.show_seconds %} countdown-timer--seconds{% endif %}{% if block.settings.show_digit_colons %} countdown-timer--digit-colons{% endif %}{% if block.settings.show_digit_labels %} countdown-timer--digit-labels{% endif %}" id="countdown">
              <div class="countdown-days">
                <span class="value text-{{ block.settings.number_size }}"></span>
                <span class="digit-label text-small">{{ block.settings.label_days }}</span>
              </div>
              {% if block.settings.show_digit_colons %}<span class="digit-colon dc-days text-{{ block.settings.number_size }}">:</span>{% endif %}
              <div class="countdown-hours">
                <span class="value text-{{ block.settings.number_size }}"></span>
                <span class="digit-label text-small">{{ block.settings.label_hours }}</span>
              </div>
              {% if block.settings.show_digit_colons %}<span class="digit-colon dc-hours text-{{ block.settings.number_size }}">:</span>{% endif %}
              <div class="countdown-minutes">
                <span class="value text-{{ block.settings.number_size }}"></span>
                <span class="digit-label text-small">{{ block.settings.label_mins }}</span>
              </div>
              {% if block.settings.show_seconds %}
              {% if block.settings.show_digit_colons %}<span class="digit-colon dc-minutes text-{{ block.settings.number_size }}">:</span>{% endif %}
              <div class="countdown-seconds">
                <span class="value text-{{ block.settings.number_size }}"></span>
                <span class="digit-label text-small">{{ block.settings.label_secs }}</span>
              </div>
              {% endif %}
            </div>
            <div class="countdown-timer-expired-message">
              {{ block.settings.completion_text }}
              {% if block.settings.completion_button_text != blank %}
                <div class="countdown-timer-expired-message--button">
                  <a class="button {{ block.settings.completion_button_style }}" href="{{ block.settings.completion_button_url }}">{{ block.settings.completion_button_text }}</a>
                </div>
              {% endif %}
            </div>
          </div>
          
          <script>
          document.addEventListener("DOMContentLoaded", function() {
            const sectionId = "{{ section.id }}";
            const wrapper = document.querySelector(`.section-${sectionId} .countdown-container`);

            /* Store-rendered time -> offset */
            const storeTimeStr = wrapper?.dataset.storeTime;
            const storeTime = storeTimeStr ? new Date(storeTimeStr) : null;
            const localTime = new Date();
            const timeOffset = storeTime ? (storeTime.getTime() - localTime.getTime()) : 0;

            /* Target time parts */
            const year   = parseInt(wrapper?.dataset.year, 10);
            const month  = parseInt(wrapper?.dataset.month, 10) - 1; // 0-based
            const day    = parseInt(wrapper?.dataset.day, 10);
            const hour   = parseInt(wrapper?.dataset.hour || '0', 10);
            const minute = parseInt(wrapper?.dataset.minute || '0', 10);

            /* Build times */
            const storeTargetTime = new Date(year, month, day, hour, minute);
            const adjustedTargetTime = new Date(storeTargetTime.getTime() - timeOffset);

            /* Scoped elements */
            const daysWrap  = wrapper?.querySelector('.countdown-days');
            const daysVal   = wrapper?.querySelector('.countdown-days .value');
            const daysColon = wrapper?.querySelector('.dc-days');
            const hoursEl   = wrapper?.querySelector('.countdown-hours .value');
            const minutesEl = wrapper?.querySelector('.countdown-minutes .value');
            const secondsEl = wrapper?.querySelector('.countdown-seconds .value');

            let timer = null;

            function updateCountdown() {
              const now = new Date();
              const diff = adjustedTargetTime - now;

              if (diff <= 0) {
                wrapper?.classList.add('ct-expired');
                if (timer) clearInterval(timer);
                return;
              }

              const days    = Math.floor(diff / 86400000);
              const hours   = Math.floor((diff / 3600000) % 24);
              const minutes = Math.floor((diff / 60000) % 60);
              const seconds = Math.floor((diff / 1000) % 60);

              if (daysVal)   daysVal.textContent   = String(days);
              if (hoursEl)   hoursEl.textContent   = String(hours).padStart(2, '0');
              if (minutesEl) minutesEl.textContent = String(minutes).padStart(2, '0');
              if (secondsEl) secondsEl.textContent = String(seconds).padStart(2, '0');

              if (daysWrap)  daysWrap.style.display  = days === 0 ? 'none' : 'inline-block';
              if (daysColon) daysColon.style.display = days === 0 ? 'none' : 'inline-block';
            }

            updateCountdown();
            timer = setInterval(updateCountdown, 1000);
          });
          </script> 
          </div>        

          {%- when 'image' -%}
          {% assign image_width = 480 %}
          {% if block.settings.image_size == 'rt-img-micro' %}
          {% assign image_width = 180 %}
          {% endif %}
          {% if block.settings.image_size == 'rt-img-sml' %}
          {% assign image_width = 240 %}
          {% endif %}
          {% if block.settings.image_size == 'rt-img-large' %}
          {% assign image_width = 800 %}
          {% endif %}
          {% if block.settings.image_size == 'rt-img-full' %}
          {% assign image_width = 2400 %}
          {% endif %}
          {% style %}
          .section-{{ section.id }} .rich-text__image img {
            border-radius: {{ block.settings.image_corner_radius }}%;
          }
          {% endstyle %}
            <div class="rich-text__image {{ block.settings.image_size }} align-{{ block.settings.alignment }}" {{ block.shopify_attributes }}>
              {% unless block.settings.image == blank %}
              {{ block.settings.image | image_url: width: image_width | image_tag: loading: 'lazy' }}
              {% endunless %}
              {% if block.settings.image == blank %}
              {% render 'media-placeholder-product', sequence_number: 3 %}  
              {% endif %}
            </div>
        {%- when 'heading' -%}
            <{{ heading_html_tag }} class="{{ block.settings.heading_size }} align-{{ block.settings.alignment }}" {{ block.shopify_attributes }}>
              {{ block.settings.heading }}
            </{{ heading_html_tag }}>
          {%- when 'caption' -%}
            {% style %}
              .section-{{ section.id }} .caption {
                opacity: {{ block.settings.opacity }}%;
              }
            {% endstyle %}
            <p class="rich-text__caption caption section-label align-{{ block.settings.alignment }}" {{ block.shopify_attributes }}>
              {{ block.settings.caption | escape }}
            </p>
          {%- when 'text' -%}
            <div class="rich-text__text rte {{ block.settings.text_size }} {{ block.settings.text_indent }} align-{{ block.settings.alignment }}" {{ block.shopify_attributes }}>
              {{ block.settings.text }}
            </div>
          {%- when 'button' -%}
            {% assign color_scheme = block.settings.btn_color_scheme %}
            {% assign button_layout = block.settings.btn_layout %}
          
            <div class="rich-text__buttons{% if block.settings.btn_one_show and block.settings.btn_two_show and block.settings.btn_one_txt != blank and block.settings.btn_two_txt != blank %} buttons-layout-{{ button_layout }}{% endif %} button-color-scheme--{{ color_scheme }} align-{{ block.settings.alignment }}" {{ block.shopify_attributes }}>
            {% if block.settings.btn_one_show and block.settings.btn_one_style contains 'button' %}
            <a href="{{ block.settings.btn_one_link }}" class="button {{ block.settings.btn_one_style }}">{{ block.settings.btn_one_txt }}</a>  
            {% endif %}
            {% if block.settings.btn_one_show and block.settings.btn_one_style contains 'link' %}
            <a href="{{ block.settings.btn_one_link }}" class="link--underlined">{{ block.settings.btn_one_txt }}</a>  
            {% endif %}
            {% if block.settings.btn_two_show and block.settings.btn_two_style contains 'button' %}
            <a href="{{ block.settings.btn_two_link }}" class="button {{ block.settings.btn_two_style }}">{{ block.settings.btn_two_txt }}</a> 
            {% endif %}
            {% if block.settings.btn_two_show and block.settings.btn_two_style contains 'link' %}
            <a href="{{ block.settings.btn_two_link }}" class="link--underlined">{{ block.settings.btn_two_txt }}</a> 
            {% endif %}
            </div>
        {%- endcase -%}
      {%- endfor -%}
    </div>
  </div>

{% if section.settings.bg_image != blank %}
<div class="rich-text-section-bg-image">
<div class="rich-text-section-bg-image-overlay"></div>
{{ section.settings.bg_image | image_url: width: 2400 | image_tag: loading: 'lazy' }}  
</div>  
{% endif %}
  
</div>

{% if section.settings.bottom_border %}
<hr class="section-border section-border-color-{{ section.settings.border_color }} section-border-width-{{ section.settings.border_width }}">
{% endif %}
  
</div>

