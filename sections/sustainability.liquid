<style>
  .kaahu-sus {
    --sus-ground: var(--color-background, #f7f5ee);
    --sus-band: var(--color-bg-two, #efeadd);
    --sus-ink: var(--color-foreground, #232a22);
    --sus-muted: rgba(var(--color-foreground-rgb, 35, 42, 34), .72);
    --sus-accent: var(--color-accent-one, #354a38);
    --sus-warm: var(--color-amber, #a9762a);
    --sus-line: rgba(var(--color-foreground-rgb, 35, 42, 34), .16);
    --sus-max-width: {{ section.settings.content_width }}px;
    --sus-y: {{ section.settings.section_spacing_mobile }}px;
    background: var(--sus-ground);
    color: var(--sus-ink);
    font-family: var(--font-body-family);
    font-style: var(--font-body-style);
    font-weight: var(--font-body-weight);
    font-size: var(--font-body-base-size-mobile);
    line-height: var(--base-line-height);
  }

  .kaahu-sus * {
    box-sizing: border-box;
  }

  .kaahu-sus .sus-wrap {
    max-width: var(--sus-max-width);
  }

  .kaahu-sus .sus-narrow {
    max-width: min(70rem, var(--sus-max-width));
  }

  .kaahu-sus .sus-block {
    padding-top: var(--sus-y);
    padding-bottom: var(--sus-y);
  }

  .kaahu-sus .sus-band {
    background: var(--sus-band);
    border-top: 1px solid var(--sus-line);
    border-bottom: 1px solid var(--sus-line);
  }

  .kaahu-sus .sus-rule {
    width: 54px;
    height: 1px;
    background: var(--sus-warm);
    border: 0;
    margin: 0 0 28px;
  }

  .kaahu-sus .sus-eyebrow {
    margin: 0 0 14px;
    color: var(--sus-warm);
    font-family: var(--font-accent-family);
    font-size: var(--font-caption-size-mobile);
    font-style: var(--font-accent-style);
    font-weight: var(--font-accent-weight);
    letter-spacing: .12em;
    line-height: 1.2;
    text-transform: uppercase;
  }

  .kaahu-sus h1,
  .kaahu-sus h2,
  .kaahu-sus h3,
  .kaahu-sus p {
    margin-top: 0;
  }

  .kaahu-sus h1,
  .kaahu-sus h2,
  .kaahu-sus h3 {
    color: var(--sus-accent);
  }

  .kaahu-sus .sus-hero h1 {
    max-width: 15ch;
    color: var(--sus-ink);
  }

  .kaahu-sus .sus-copy,
  .kaahu-sus .sus-richtext,
  .kaahu-sus .sus-lede {
    color: var(--sus-muted);
  }

  .kaahu-sus .sus-lede {
    max-width: 52rem;
    font-size: 1.08em;
  }

  .kaahu-sus .sus-richtext > *:last-child,
  .kaahu-sus .sus-copy > *:last-child {
    margin-bottom: 0;
  }

  .kaahu-sus a {
    color: var(--sus-accent);
    text-underline-offset: .18em;
  }

  .kaahu-sus a:hover {
    color: var(--sus-warm);
  }

  .kaahu-sus :focus-visible {
    outline: 2px solid var(--sus-warm);
    outline-offset: 3px;
  }

  .kaahu-sus .sus-frame {
    position: relative;
    overflow: hidden;
    border: 1px solid var(--sus-line);
    border-radius: var(--media-radius-small, 8px);
    background: var(--sus-band);
  }

  .kaahu-sus .sus-frame img {
    display: block;
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .kaahu-sus .sus-frame-wide {
    aspect-ratio: 16 / 8;
  }

  .kaahu-sus .sus-frame-tile,
  .kaahu-sus .sus-frame-port {
    aspect-ratio: 4 / 5;
  }

  .kaahu-sus .sus-illus {
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .kaahu-sus .sus-illus img {
    width: 46%;
    height: auto;
    object-fit: contain;
  }

  .kaahu-sus .sus-stack {
    display: grid;
    gap: 28px;
  }

  .kaahu-sus .sus-hero-media {
    margin-top: 16px;
  }

  .kaahu-sus .sus-grid {
    display: grid;
    gap: 36px;
  }

  .kaahu-sus .sus-card-copy {
    padding-top: 20px;
  }

  .kaahu-sus .sus-kicker,
  .kaahu-sus .sus-lead,
  .kaahu-sus .sus-sign,
  .kaahu-sus .sus-row-label {
    color: var(--sus-accent);
    font-family: var(--font-heading-family);
    font-style: italic;
    font-weight: var(--font-heading-weight);
  }

  .kaahu-sus .sus-kicker {
    margin-bottom: 6px;
  }

  .kaahu-sus .sus-lead,
  .kaahu-sus .sus-sign {
    font-size: 1.18em;
    line-height: 1.45;
  }

  .kaahu-sus .sus-chips {
    display: flex;
    flex-wrap: wrap;
    gap: 8px;
    margin-top: 18px;
  }

  .kaahu-sus .sus-chip {
    border: 1px solid var(--sus-line);
    border-radius: var(--button-radius, 999px);
    padding: 6px 12px;
    background: rgba(255, 255, 255, .45);
    color: var(--sus-accent);
    font-family: var(--font-accent-family);
    font-size: var(--font-caption-size-mobile);
    line-height: 1.2;
  }

  .kaahu-sus .sus-split {
    display: grid;
    gap: 32px;
    align-items: center;
  }

  .kaahu-sus .sus-rows {
    border-top: 1px solid var(--sus-line);
  }

  .kaahu-sus .sus-row {
    display: grid;
    gap: 10px;
    padding: 26px 0;
    border-bottom: 1px solid var(--sus-line);
  }

  .kaahu-sus .sus-row-label {
    font-size: 1.12em;
    line-height: 1.3;
  }

  .kaahu-sus .sus-give,
  .kaahu-sus .sus-close {
    text-align: center;
  }

  .kaahu-sus .sus-mark {
    width: 84px;
    height: 84px;
    margin: 0 auto 24px;
    border-radius: 50%;
    overflow: hidden;
    background: var(--sus-accent);
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .kaahu-sus .sus-mark img {
    display: block;
    width: 100%;
    height: 100%;
    object-fit: contain;
    padding: 14px;
  }

  .kaahu-sus .sus-last {
    border-top: 1px solid var(--sus-line);
  }

  .kaahu-sus .sus-progress {
    background: var(--sus-accent);
    color: var(--sus-ground);
  }

  .kaahu-sus .sus-progress h2,
  .kaahu-sus .sus-progress .sus-lead,
  .kaahu-sus .sus-progress .sus-copy {
    color: inherit;
  }

  .kaahu-sus .sus-progress .sus-eyebrow {
    color: var(--sus-warm);
  }

  .kaahu-sus .sus-list {
    display: grid;
    gap: 0;
    margin: 0;
    padding: 0;
    list-style: none;
  }

  .kaahu-sus .sus-list li {
    position: relative;
    padding: 18px 0 18px 32px;
    border-top: 1px solid rgba(255, 255, 255, .18);
  }

  .kaahu-sus .sus-list li:last-child {
    border-bottom: 1px solid rgba(255, 255, 255, .18);
  }

  .kaahu-sus .sus-list li::before {
    content: "";
    position: absolute;
    top: 24px;
    left: 0;
    width: 11px;
    height: 11px;
    border: 2px solid var(--sus-warm);
    border-radius: 50%;
  }

  .kaahu-sus .sus-reveal {
    opacity: 0;
    transform: translateY(12px);
    animation: kaahu-rise .65s cubic-bezier(.2, .7, .2, 1) forwards;
  }

  .kaahu-sus .sus-reveal:nth-child(2) {
    animation-delay: .08s;
  }

  .kaahu-sus .sus-reveal:nth-child(3) {
    animation-delay: .16s;
  }

  .kaahu-sus .sus-reveal:nth-child(4) {
    animation-delay: .24s;
  }

  @keyframes kaahu-rise {
    to {
      opacity: 1;
      transform: none;
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .kaahu-sus .sus-reveal {
      opacity: 1;
      transform: none;
      animation: none;
    }
  }

  @media (min-width: 750px) {
    .kaahu-sus {
      --sus-y: {{ section.settings.section_spacing_desktop }}px;
      font-size: var(--font-body-base-size-tablet);
    }

    .kaahu-sus .sus-grid {
      grid-template-columns: repeat(2, minmax(0, 1fr));
      gap: 48px;
    }

    .kaahu-sus .sus-split {
      grid-template-columns: repeat(2, minmax(0, 1fr));
      gap: 56px;
    }

    .kaahu-sus .sus-row {
      grid-template-columns: 220px minmax(0, 1fr);
      gap: 40px;
      padding: 30px 0;
    }
  }

  @media (min-width: 1025px) {
    .kaahu-sus {
      font-size: var(--font-body-base-size-desktop);
    }

    .kaahu-sus .sus-eyebrow,
    .kaahu-sus .sus-chip {
      font-size: var(--font-caption-size-desktop);
    }
  }

  @media (max-width: 749px) {
    .kaahu-sus .sus-frame-wide {
      aspect-ratio: 4 / 3;
    }
  }
</style>

{%- assign hero_eyebrow = section.settings.hero_eyebrow | default: 'Sustainability at Kaahu' -%}
{%- assign hero_heading = section.settings.hero_heading | default: 'What you carry should reflect what you value.' -%}
{%- assign hero_text = section.settings.hero_text | default: 'So we account for it at every stage. Here is what that means, in plain terms, including the parts we have not finished yet.' -%}

<div class="kaahu-sus">
  <header class="sus-hero sus-block">
    <div class="page-width sus-wrap sus-stack">
      <div>
        <p class="sus-eyebrow sus-reveal">{{ hero_eyebrow }}</p>
        <hr class="sus-rule sus-reveal" aria-hidden="true">
        <h1 class="sus-reveal">{{ hero_heading }}</h1>
        <p class="sus-lede sus-reveal">{{ hero_text }}</p>
      </div>
      <div class="sus-hero-media sus-reveal">
        <div class="sus-frame sus-frame-wide">
          {% if section.settings.hero_image %}
            <img src="{{ section.settings.hero_image | image_url: width: 1600 }}" alt="{{ section.settings.hero_image.alt | default: 'A Kaahu bag in everyday life' }}" width="{{ section.settings.hero_image.width }}" height="{{ section.settings.hero_image.height }}">
          {% else %}
            <img src="https://cdn.shopify.com/s/files/1/0709/9046/3195/files/20241021-DSC01765.jpg?v=1781672547" alt="A Kaahu bag in everyday life" width="1600" height="800">
          {% endif %}
        </div>
      </div>
    </div>
  </header>

  <section class="sus-block">
    <div class="page-width-narrow sus-narrow">
      <div class="sus-richtext">
        {% if section.settings.intro_text != blank %}
          {{ section.settings.intro_text }}
        {% else %}
          <p>Kaahu is shaped by the Hawaiian principle of <em>M&#257;lama</em> &mdash; to care for one&rsquo;s people, and for the land, air, and water that hold them. That care decides what we make, and how.</p>
          <p>We choose natural fibers, low-impact methods, and partners who meet real standards. And we would rather move slowly than overstate.</p>
        {% endif %}
      </div>
    </div>
  </section>

  <div class="sus-band">
    <section class="sus-block">
      <div class="page-width sus-wrap sus-stack">
        <div>
          <p class="sus-eyebrow">{{ section.settings.materials_eyebrow | default: 'Materials' }}</p>
          <h2>{{ section.settings.materials_heading | default: 'Two fibers, chosen for what they conserve.' }}</h2>
        </div>
        <div class="sus-grid">
          <article>
            <div class="sus-frame sus-frame-tile">
              {% if section.settings.cotton_image %}
                <img src="{{ section.settings.cotton_image | image_url: width: 1200 }}" alt="{{ section.settings.cotton_image.alt | default: 'Cotton boll on the plant' }}" width="{{ section.settings.cotton_image.width }}" height="{{ section.settings.cotton_image.height }}" loading="lazy">
              {% else %}
                <img src="https://cdn.shopify.com/s/files/1/0709/9046/3195/files/cotton_flower.png?v=1781663097" alt="Cotton boll on the plant" width="1200" height="1500" loading="lazy">
              {% endif %}
            </div>
            <div class="sus-card-copy">
              <p class="sus-kicker">{{ section.settings.cotton_kicker | default: 'Certified organic cotton' }}</p>
              <h3>{{ section.settings.cotton_heading | default: 'Grown gently, from the seed up.' }}</h3>
              <p class="sus-copy">{{ section.settings.cotton_text | default: 'No synthetic pesticides, no GM seeds, and certified to the Global Organic Textile Standard. It uses up to 91% less water than conventional cotton.' }}</p>
              <div class="sus-chips">
                {%- assign cotton_chips = section.settings.cotton_chips | default: 'GOTS-certified,Up to 91% less water' | split: ',' -%}
                {% for chip in cotton_chips %}
                  <span class="sus-chip">{{ chip | strip }}</span>
                {% endfor %}
              </div>
            </div>
          </article>
          <article>
            <div class="sus-frame sus-frame-tile sus-illus">
              <img src="https://cdn.shopify.com/s/files/1/0709/9046/3195/files/Jute.svg?v=1778783129" alt="Bengal jute fiber" width="512" height="512">
            </div>
            <div class="sus-card-copy">
              <p class="sus-kicker">{{ section.settings.jute_kicker | default: 'Bengal jute' }}</p>
              <h3>{{ section.settings.jute_heading | default: 'One of the lowest-impact fibers there is.' }}</h3>
              <p class="sus-copy">{{ section.settings.jute_text | default: 'Rain-fed, harvested within six months, and gentle on the soil it grows in: a fiber with a quiet strength we fell for.' }}</p>
              <div class="sus-chips">
                {%- assign jute_chips = section.settings.jute_chips | default: 'Rain-fed,6-month harvest,Builds soil health' | split: ',' -%}
                {% for chip in jute_chips %}
                  <span class="sus-chip">{{ chip | strip }}</span>
                {% endfor %}
              </div>
            </div>
          </article>
        </div>
      </div>
    </section>
  </div>

  <section class="sus-block">
    <div class="page-width sus-wrap sus-split">
      <div>
        <div class="sus-frame sus-frame-port">
          {% if section.settings.craft_image %}
            <img src="{{ section.settings.craft_image | image_url: width: 1200 }}" alt="{{ section.settings.craft_image.alt | default: 'Artisan craft and heritage textile work' }}" width="{{ section.settings.craft_image.width }}" height="{{ section.settings.craft_image.height }}" loading="lazy">
          {% else %}
            <img src="https://cdn.shopify.com/s/files/1/0709/9046/3195/files/Heritage.jpg?v=1778784669" alt="Artisan craft and heritage textile work" width="1200" height="1500" loading="lazy">
          {% endif %}
        </div>
      </div>
      <div>
        <p class="sus-eyebrow">{{ section.settings.craft_eyebrow | default: 'Hands & lineage' }}</p>
        <p class="sus-lead">{{ section.settings.craft_lead | default: 'Made by people, and named as such.' }}</p>
        <p class="sus-copy">{{ section.settings.craft_text | default: 'Small mills and artisan cooperatives carry the work forward: jute looms in Bengal, cotton spinning in Gujarat. One bag even carries a note in Bengali script, written by our own family.' }}</p>
        <div class="sus-chips">
          {%- assign craft_chips = section.settings.craft_chips | default: 'Bengal looms,Gujarat spinning' | split: ',' -%}
          {% for chip in craft_chips %}
            <span class="sus-chip">{{ chip | strip }}</span>
          {% endfor %}
        </div>
      </div>
    </div>
  </section>

  <div class="sus-band">
    <section class="sus-block">
      <div class="page-width sus-wrap sus-stack">
        <div>
          <p class="sus-eyebrow">{{ section.settings.making_eyebrow | default: 'How it is made' }}</p>
          <h2>{{ section.settings.making_heading | default: 'Held to a standard, every step.' }}</h2>
        </div>
        <div class="sus-rows">
          <div class="sus-row">
            <div class="sus-row-label">{{ section.settings.row_one_label | default: 'Dyes & water' }}</div>
            <div>
              <p class="sus-copy">{{ section.settings.row_one_text | default: 'GOTS-approved low-impact dyes. Several partner mills run closed-loop systems that recycle process water rather than discharge it.' }}</p>
              <div class="sus-chips">
                {%- assign row_one_chips = section.settings.row_one_chips | default: 'GOTS-approved dyes,Closed-loop water' | split: ',' -%}
                {% for chip in row_one_chips %}
                  <span class="sus-chip">{{ chip | strip }}</span>
                {% endfor %}
              </div>
            </div>
          </div>
          <div class="sus-row">
            <div class="sus-row-label">{{ section.settings.row_two_label | default: 'Fair, safe labor' }}</div>
            <div>
              <p class="sus-copy">{{ section.settings.row_two_text | default: 'We work only with SEDEX-audited suppliers: fair pay in local terms, safe conditions, no forced labor. If a facility falls short, we move on, even when it costs more.' }}</p>
              <div class="sus-chips">
                {%- assign row_two_chips = section.settings.row_two_chips | default: 'SEDEX-audited,ISO 14001:2015' | split: ',' -%}
                {% for chip in row_two_chips %}
                  <span class="sus-chip">{{ chip | strip }}</span>
                {% endfor %}
              </div>
            </div>
          </div>
        </div>
      </div>
    </section>
  </div>

  <section class="sus-block sus-give">
    <div class="page-width-narrow sus-narrow">
      <div class="sus-mark">
        <img src="https://cdn.shopify.com/s/files/1/0709/9046/3195/files/1_white_small_f9740041-dc0f-40c0-86f3-ca1ff3c9be95.png?v=1781041085" alt="1% for the Planet" width="84" height="84">
      </div>
      <p class="sus-eyebrow">{{ section.settings.giving_eyebrow | default: 'Giving back' }}</p>
      <h2>{{ section.settings.giving_heading | default: 'One percent of revenue. Not profit.' }}</h2>
      <div class="sus-richtext">
        {% if section.settings.giving_text != blank %}
          {{ section.settings.giving_text }}
        {% else %}
          <p>We are a member of <a href="https://www.onepercentfortheplanet.org/" target="_blank" rel="noopener">1% for the Planet</a>, so a portion of every purchase goes to vetted environmental organizations. The network has directed over $672 million to climate and conservation work across more than 110 countries.</p>
        {% endif %}
      </div>
    </div>
  </section>

  <section class="sus-block sus-last">
    <div class="page-width-narrow sus-narrow">
      <p class="sus-eyebrow">{{ section.settings.last_eyebrow | default: 'Built to last' }}</p>
      <p class="sus-lead">{{ section.settings.last_lead | default: 'Sustainability without durability is just slower waste.' }}</p>
      <p class="sus-copy">{{ section.settings.last_text | default: 'So we design for real life and for repair: choosing materials for resilience and hardware for strength. Fewer, better things, made to be used rather than shelved.' }}</p>
    </div>
  </section>

  <section class="sus-block sus-progress">
    <div class="page-width sus-wrap">
      <p class="sus-eyebrow">{{ section.settings.progress_eyebrow | default: 'In progress' }}</p>
      <h2>{{ section.settings.progress_heading | default: 'What we are still working on.' }}</h2>
      <p class="sus-copy">{{ section.settings.progress_text | default: 'We do not claim perfection. A few things are underway, and we would rather name them than hide them.' }}</p>
      <ul class="sus-list">
        {%- assign progress_items = section.settings.progress_items | default: 'Moving more partner mills onto renewable energy.|Finalizing verified NGO partnerships for reforestation and mangrove restoration across South Asia: measurable, not symbolic.|Lowering water, energy, and chemical use further, one mill at a time.' | split: '|' -%}
        {% for item in progress_items %}
          <li>{{ item | strip }}</li>
        {% endfor %}
      </ul>
    </div>
  </section>

  <section class="sus-block sus-close">
    <div class="page-width-narrow sus-narrow">
      <div class="sus-richtext">
        {% if section.settings.close_text != blank %}
          {{ section.settings.close_text }}
        {% else %}
          <p>Have a question we have not answered? Write to <a href="mailto:care@kaahu.us">care@kaahu.us</a>. We will tell you what we know, and what we are still learning.</p>
        {% endif %}
      </div>
      <p class="sus-sign">{{ section.settings.close_signoff | default: 'Because what you carry should reflect what you believe.' }}</p>
    </div>
  </section>

  <div class="sus-block">
    <div class="page-width sus-wrap">
      <div class="sus-frame sus-frame-wide">
        {% if section.settings.closing_image %}
          <img src="{{ section.settings.closing_image | image_url: width: 1600 }}" alt="{{ section.settings.closing_image.alt | default: 'Kaahu bag on a walk in nature' }}" width="{{ section.settings.closing_image.width }}" height="{{ section.settings.closing_image.height }}" loading="lazy">
        {% else %}
          <img src="https://cdn.shopify.com/s/files/1/0709/9046/3195/files/Seraph_feather_75640f40-c730-471d-abae-3fb1ddfd5318.jpg?v=1777861927" alt="Kaahu bag on a walk in nature" width="1600" height="800" loading="lazy">
        {% endif %}
      </div>
    </div>
  </div>
</div>

