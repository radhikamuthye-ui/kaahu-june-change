{{ 'section-kaahu-product-reviews.css' | asset_url | stylesheet_tag }}

{%- style -%}
  .section-{{ section.id }} {
    --kpr-bg: {{ section.settings.background_color }};
    --kpr-max-width: {{ section.settings.max_width }}px;
    --kpr-padding-top-desktop: {{ section.settings.padding_top_desktop }}px;
    --kpr-padding-bottom-desktop: {{ section.settings.padding_bottom_desktop }}px;
    --kpr-padding-top-mobile: {{ section.settings.padding_top_mobile }}px;
    --kpr-padding-bottom-mobile: {{ section.settings.padding_bottom_mobile }}px;
    --kpr-heading: {{ section.settings.heading_color }};
    --kpr-text: {{ section.settings.text_color }};
    --kpr-muted: {{ section.settings.muted_color }};
    --kpr-star: {{ section.settings.star_color }};
    --kpr-olive: {{ section.settings.olive_color }};
    --kpr-border: {{ section.settings.border_color }};
    --kpr-card-bg: {{ section.settings.card_background_color }};
    --kpr-button-text: {{ section.settings.button_text_color }};
    --kpr-button-border: {{ section.settings.button_border_color }};
    --kpr-heading-size-desktop: {{ section.settings.heading_size_desktop }}px;
    --kpr-heading-size-mobile: {{ section.settings.heading_size_mobile }}px;
  }
{%- endstyle -%}

<section class="kaahu-product-reviews section-{{ section.id }}">
  <div class="kaahu-product-reviews__inner">
    {%- if section.settings.heading != blank -%}
      <h2 class="kaahu-product-reviews__heading">{{ section.settings.heading }}</h2>
    {%- endif -%}

    {%- if section.settings.show_summary -%}
      <div class="kaahu-product-reviews__summary">
        <div class="kaahu-product-reviews__score">
          <strong>{{ section.settings.rating }}</strong>
          <div class="kaahu-product-reviews__stars" aria-label="{{ section.settings.rating }} out of 5 stars">★★★★★</div>
          <div class="kaahu-product-reviews__count">{{ section.settings.review_count_text }}</div>
        </div>
        <div class="kaahu-product-reviews__bars" aria-hidden="true">
          {%- for index in (1..5) reversed -%}
            <div class="kaahu-product-reviews__bar">
              <span>{{ index }}</span>
              <span class="kaahu-product-reviews__track"><span class="kaahu-product-reviews__fill" style="width: {% if index == 5 %}100{% else %}0{% endif %}%"></span></span>
            </div>
          {%- endfor -%}
        </div>
      </div>
    {%- endif -%}

    <div class="kaahu-product-reviews__cards">
      {%- for block in section.blocks -%}
        <article class="kaahu-product-reviews__card" {{ block.shopify_attributes }}>
          <div class="kaahu-product-reviews__card-head">
            <div class="kaahu-product-reviews__stars" aria-label="{{ block.settings.rating }} out of 5 stars">
              {%- for index in (1..5) -%}{%- if index <= block.settings.rating -%}★{%- else -%}☆{%- endif -%}{%- endfor -%}
            </div>
            {%- if block.settings.verified_text != blank -%}<div class="kaahu-product-reviews__verified">{{ block.settings.verified_text }}</div>{%- endif -%}
          </div>
          {%- if block.settings.heading != blank -%}<h3>{{ block.settings.heading }}</h3>{%- endif -%}
          {%- if block.settings.text != blank -%}<div class="kaahu-product-reviews__quote rte">{{ block.settings.text }}</div>{%- endif -%}
          {%- if block.settings.byline != blank -%}<div class="kaahu-product-reviews__byline">{{ block.settings.byline }}</div>{%- endif -%}
        </article>
      {%- endfor -%}
    </div>

    {%- if section.settings.button_text != blank and section.settings.button_link != blank -%}
      <a class="kaahu-product-reviews__button" href="{{ section.settings.button_link }}">{{ section.settings.button_text }} →</a>
    {%- endif -%}
  </div>
</section>

{% schema %}
{
  "name": "Kaahu product reviews",
  "tag": "section",
  "class": "section",
  "settings": [
    { "type": "color", "id": "background_color", "label": "Background", "default": "#ffffff" },
    { "type": "range", "id": "max_width", "label": "Max width", "min": 960, "max": 1600, "step": 20, "unit": "px", "default": 1320 },
    { "type": "range", "id": "padding_top_desktop", "label": "Desktop top padding", "min": 0, "max": 180, "step": 4, "unit": "px", "default": 56 },
    { "type": "range", "id": "padding_bottom_desktop", "label": "Desktop bottom padding", "min": 0, "max": 180, "step": 4, "unit": "px", "default": 72 },
    { "type": "range", "id": "padding_top_mobile", "label": "Mobile top padding", "min": 0, "max": 120, "step": 4, "unit": "px", "default": 44 },
    { "type": "range", "id": "padding_bottom_mobile", "label": "Mobile bottom padding", "min": 0, "max": 120, "step": 4, "unit": "px", "default": 52 },
    { "type": "text", "id": "heading", "label": "Heading", "default": "What Our Customers Say" },
    { "type": "range", "id": "heading_size_desktop", "label": "Heading desktop", "min": 28, "max": 72, "step": 1, "unit": "px", "default": 42 },
    { "type": "range", "id": "heading_size_mobile", "label": "Heading mobile", "min": 24, "max": 48, "step": 1, "unit": "px", "default": 34 },
    { "type": "checkbox", "id": "show_summary", "label": "Show rating summary", "default": true },
    { "type": "text", "id": "rating", "label": "Rating", "default": "5.0" },
    { "type": "text", "id": "review_count_text", "label": "Review count text", "default": "5 reviews" },
    { "type": "text", "id": "button_text", "label": "Button text", "default": "Read all 5 reviews" },
    { "type": "url", "id": "button_link", "label": "Button link" },
    { "type": "color", "id": "heading_color", "label": "Heading color", "default": "#1d1b17" },
    { "type": "color", "id": "text_color", "label": "Text color", "default": "#65615a" },
    { "type": "color", "id": "muted_color", "label": "Muted color", "default": "#938e84" },
    { "type": "color", "id": "star_color", "label": "Star color", "default": "#e0a52a" },
    { "type": "color", "id": "olive_color", "label": "Verified color", "default": "#414A29" },
    { "type": "color", "id": "border_color", "label": "Border", "default": "#ece8e0" },
    { "type": "color", "id": "card_background_color", "label": "Card background", "default": "#fffdf9" },
    { "type": "color", "id": "button_text_color", "label": "Button text", "default": "#1d1b17" },
    { "type": "color", "id": "button_border_color", "label": "Button border", "default": "#1d1b17" }
  ],
  "blocks": [
    {
      "type": "review",
      "name": "Review",
      "settings": [
        { "type": "range", "id": "rating", "label": "Rating", "min": 1, "max": 5, "step": 1, "default": 5 },
        { "type": "text", "id": "verified_text", "label": "Verified text", "default": "✓ Verified" },
        { "type": "text", "id": "heading", "label": "Heading", "default": "Sleek, durable, turns heads" },
        { "type": "richtext", "id": "text", "label": "Text", "default": "<p>Durable material, stays clean and looks very sleek. Used it on the beach, shopping and going out to eat — it does everything.</p>" },
        { "type": "richtext", "id": "byline", "label": "Byline", "default": "<p><strong>Kremena F.</strong> · West Chester, PA</p>" }
      ]
    }
  ],
  "presets": [
    { "name": "Kaahu product reviews" }
  ]
}
{% endschema %}
