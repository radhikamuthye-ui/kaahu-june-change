    },
    {
      "type": "range",
      "id": "cta_gap_mobile",
      "min": 20,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "Space above CTA mobile",
      "default": 40
    },
    {
      "type": "text",
      "id": "button_one_text",
      "label": "First button text",
      "default": "Tag Us @houseofkaahu"
    },
    {
      "type": "url",
      "id": "button_one_link",
      "label": "First button link"
    },
    {
      "type": "checkbox",
      "id": "button_one_show_icon",
      "label": "First button icon",
      "default": true
    },
    {
      "type": "text",
      "id": "button_two_text",
      "label": "Second button text",
      "default": "Follow @houseofkaahu"
    },
    {
      "type": "url",
      "id": "button_two_link",
      "label": "Second button link"
    },
    {
      "type": "checkbox",
      "id": "button_two_show_icon",
      "label": "Second button icon",
      "default": true
    },
