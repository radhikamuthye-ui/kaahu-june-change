      "default": 19
    },
    {
      "type": "color",
      "id": "cta_headline_color",
      "label": "CTA headline color",
      "default": "#24221f"
    },
    {
      "type": "range",
      "id": "cta_gap_desktop",
      "min": 24,
      "max": 140,
      "step": 4,
      "unit": "px",
