{{ 'section-kaahu-value-cards.css' | asset_url | stylesheet_tag }}

{%- style -%}
  .section-{{ section.id }} {
    --kvc-bg: {{ section.settings.background_color }};
    --kvc-card-bg: {{ section.settings.card_background_color }};
    --kvc-card-border: {{ section.settings.card_border_color }};
    --kvc-heading-color: {{ section.settings.heading_color }};
    --kvc-eyebrow-color: {{ section.settings.eyebrow_color }};
    --kvc-title-color: {{ section.settings.card_title_color }};
    --kvc-body-color: {{ section.settings.card_body_color }};
    --kvc-subheading-color: {{ section.settings.subheading_color }};
    --kvc-icon-bg: {{ section.settings.icon_background_color }};
    --kvc-icon-color: {{ section.settings.icon_color }};
    --kvc-padding-top-mobile: {{ section.settings.padding_top | times: 0.68 | round }}px;
    --kvc-padding-bottom-mobile: {{ section.settings.padding_bottom | times: 0.72 | round }}px;
    --kvc-padding-top-desktop: {{ section.settings.padding_top }}px;
    --kvc-padding-bottom-desktop: {{ section.settings.padding_bottom }}px;
    --kvc-page-width: {{ section.settings.page_width }}px;
    --kvc-icon-size-mobile: {{ section.settings.icon_size_mobile }}px;
    --kvc-icon-size-desktop: {{ section.settings.icon_size_desktop }}px;
    --kvc-icon-image-scale: {{ section.settings.icon_image_scale | divided_by: 100.0 }};
    --kvc-icon-bottom-spacing-mobile: {{ section.settings.icon_bottom_spacing_mobile }}px;
    --kvc-icon-bottom-spacing-desktop: {{ section.settings.icon_bottom_spacing_desktop }}px;
    --kvc-card-min-height-mobile: {{ section.settings.card_min_height_mobile }}px;
    --kvc-card-min-height-desktop: {{ section.settings.card_min_height_desktop }}px;
    --kvc-card-padding-mobile: {{ section.settings.card_padding_mobile }}px;
    --kvc-card-padding-desktop: {{ section.settings.card_padding_desktop }}px;
    --kvc-card-radius: {{ section.settings.card_radius }}px;
    --kvc-header-cards-gap-mobile: {{ section.settings.header_cards_gap_mobile }}px;
    --kvc-header-cards-gap-desktop: {{ section.settings.header_cards_gap_desktop }}px;
    --kvc-grid-gap-mobile: {{ section.settings.grid_gap_mobile }}px;
    --kvc-grid-gap-desktop: {{ section.settings.grid_gap_desktop }}px;
  }
{%- endstyle -%}

<section
  class="kaahu-value-cards section-{{ section.id }}"
  style="
    --kvc-bg: {{ section.settings.background_color }};
    --kvc-card-bg: {{ section.settings.card_background_color }};
    --kvc-card-border: {{ section.settings.card_border_color }};
    --kvc-heading-color: {{ section.settings.heading_color }};
    --kvc-eyebrow-color: {{ section.settings.eyebrow_color }};
    --kvc-title-color: {{ section.settings.card_title_color }};
    --kvc-body-color: {{ section.settings.card_body_color }};
    --kvc-subheading-color: {{ section.settings.subheading_color }};
    --kvc-icon-bg: {{ section.settings.icon_background_color }};
    --kvc-icon-color: {{ section.settings.icon_color }};
    --kvc-padding-top-mobile: {{ section.settings.padding_top | times: 0.68 | round }}px;
    --kvc-padding-bottom-mobile: {{ section.settings.padding_bottom | times: 0.72 | round }}px;
    --kvc-padding-top-desktop: {{ section.settings.padding_top }}px;
    --kvc-padding-bottom-desktop: {{ section.settings.padding_bottom }}px;
    --kvc-page-width: {{ section.settings.page_width }}px;
    --kvc-icon-size-mobile: {{ section.settings.icon_size_mobile }}px;
    --kvc-icon-size-desktop: {{ section.settings.icon_size_desktop }}px;
    --kvc-icon-image-scale: {{ section.settings.icon_image_scale | divided_by: 100.0 }};
    --kvc-icon-bottom-spacing-mobile: {{ section.settings.icon_bottom_spacing_mobile }}px;
    --kvc-icon-bottom-spacing-desktop: {{ section.settings.icon_bottom_spacing_desktop }}px;
    --kvc-card-min-height-mobile: {{ section.settings.card_min_height_mobile }}px;
    --kvc-card-min-height-desktop: {{ section.settings.card_min_height_desktop }}px;
    --kvc-card-padding-mobile: {{ section.settings.card_padding_mobile }}px;
    --kvc-card-padding-desktop: {{ section.settings.card_padding_desktop }}px;
    --kvc-card-radius: {{ section.settings.card_radius }}px;
    --kvc-header-cards-gap-mobile: {{ section.settings.header_cards_gap_mobile }}px;
    --kvc-header-cards-gap-desktop: {{ section.settings.header_cards_gap_desktop }}px;
    --kvc-grid-gap-mobile: {{ section.settings.grid_gap_mobile }}px;
    --kvc-grid-gap-desktop: {{ section.settings.grid_gap_desktop }}px;
  "
>
  <div class="kaahu-value-cards__inner">
    <div class="kaahu-value-cards__header">
      {%- if section.settings.eyebrow != blank -%}
        <div class="kaahu-value-cards__eyebrow">
          <span class="kaahu-value-cards__eyebrow-mark" aria-hidden="true">
            <svg viewBox="0 0 16 16" focusable="false">
              <path d="M12.9 2.2c-2.9.2-5.2 1.1-6.9 2.8-1.6 1.6-2.4 3.7-2.2 6.3 2.6.2 4.7-.6 6.3-2.2 1.7-1.7 2.6-4 2.8-6.9Zm-6.6 7.5c.5-1.7 1.6-3.1 3.4-4.4" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"/>
            </svg>
          </span>
          <span>{{ section.settings.eyebrow }}</span>
        </div>
      {%- endif -%}

      {%- if section.settings.heading != blank -%}
        <h2 class="kaahu-value-cards__heading">{{ section.settings.heading }}</h2>
      {%- endif -%}

      {%- if section.settings.subheading != blank -%}
        <div class="kaahu-value-cards__subheading rte">{{ section.settings.subheading }}</div>
      {%- endif -%}
    </div>

    <div class="kaahu-value-cards__grid">
      {%- for block in section.blocks -%}
        <article class="kaahu-value-cards__card" {{ block.shopify_attributes }}>
          <div class="kaahu-value-cards__icon-wrap">
            {%- if block.settings.icon != blank -%}
              {{ block.settings.icon | image_url: width: 320 | image_tag: loading: 'lazy', class: 'kaahu-value-cards__icon-image', alt: block.settings.title | escape }}
            {%- else -%}
              <span class="kaahu-value-cards__icon-fallback kaahu-value-cards__icon-fallback--{{ block.settings.fallback_icon }}" aria-hidden="true">
                {%- case block.settings.fallback_icon -%}
                  {%- when 'leaf' -%}
                    <svg viewBox="0 0 64 64" focusable="false">
                      <circle cx="32" cy="32" r="30" fill="currentColor" opacity=".12"/>
                      <path d="M45 14c-10 1-18 5-23 12-5 6-6 14-3 24 10-1 18-5 23-12 5-6 6-14 3-24Z" fill="none" stroke="currentColor" stroke-width="3" stroke-linejoin="round"/>
                      <path d="M22 43c5-10 11-16 19-21M30 34l-8-2M35 29l1-8" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round"/>
                    </svg>
                  {%- when 'cotton' -%}
                    <svg viewBox="0 0 64 64" focusable="false">
                      <circle cx="32" cy="32" r="30" fill="currentColor" opacity=".12"/>
                      <path d="M24 39c-6 0-10-4-10-9 0-5 4-9 9-9 1-5 5-8 10-8s9 3 10 8c5 0 9 4 9 9s-4 9-10 9H24Z" fill="none" stroke="currentColor" stroke-width="3" stroke-linejoin="round"/>
                      <path d="M32 39v11M23 48h18" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round"/>
                    </svg>
                  {%- when 'planet' -%}
                    <svg viewBox="0 0 64 64" focusable="false">
                      <circle cx="32" cy="32" r="30" fill="currentColor" opacity=".12"/>
                      <circle cx="32" cy="32" r="18" fill="none" stroke="currentColor" stroke-width="3"/>
                      <path d="M17 29c5 1 8 0 10-3 2-2 5-2 8 0 3 3 6 3 11 2M25 47c0-5 2-8 6-9 5-2 8 0 10 4" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round"/>
                    </svg>
                  {%- else -%}
                    <svg viewBox="0 0 64 64" focusable="false">
                      <circle cx="32" cy="32" r="30" fill="currentColor" opacity=".12"/>
                      <path d="M32 15c9 5 15 13 15 22 0 8-6 14-15 14s-15-6-15-14c0-9 6-17 15-22Z" fill="none" stroke="currentColor" stroke-width="3" stroke-linejoin="round"/>
                      <path d="M24 36c5 0 10-4 16-12M26 43c6-1 11-5 15-12" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round"/>
                    </svg>
                {%- endcase -%}
              </span>
            {%- endif -%}
          </div>

          {%- if block.settings.title != blank -%}
            <h3 class="kaahu-value-cards__title">{{ block.settings.title }}</h3>
          {%- endif -%}

          {%- if block.settings.body != blank -%}
            <div class="kaahu-value-cards__body rte">{{ block.settings.body }}</div>
          {%- endif -%}
        </article>
      {%- endfor -%}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Kaahu value cards",
  "tag": "section",
  "class": "section",
  "disabled_on": {
    "groups": ["header", "footer"],
    "templates": ["password", "cart"]
  },
  "settings": [
    {
      "type": "header",
      "content": "Text"
    },
    {
      "type": "text",
      "id": "eyebrow",
      "label": "Eyebrow",
      "default": "MADE WITH INTENTION"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Beauty that gives back."
    },
    {
      "type": "richtext",
      "id": "subheading",
      "label": "Subheading",
      "default": "<p>Every Kaahu piece is made to give back — to the planet and to the craft that raised us.</p>"
    },
    {
      "type": "header",
      "content": "Layout"
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 40,
      "max": 220,
      "step": 4,
      "unit": "px",
      "label": "Top padding",
      "default": 144
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 40,
      "max": 200,
      "step": 4,
      "unit": "px",
      "label": "Bottom padding",
      "default": 76
    },
    {
      "type": "range",
      "id": "page_width",
      "min": 1000,
      "max": 1700,
      "step": 20,
      "unit": "px",
      "label": "Content width",
      "default": 1420
    },
    {
      "type": "range",
      "id": "header_cards_gap_mobile",
      "min": 12,
      "max": 96,
      "step": 2,
      "unit": "px",
      "label": "Space between text and cards on mobile",
      "default": 36
    },
    {
      "type": "range",
      "id": "header_cards_gap_desktop",
      "min": 16,
      "max": 120,
      "step": 2,
      "unit": "px",
      "label": "Space between text and cards on desktop",
      "default": 48
    },
    {
      "type": "range",
      "id": "grid_gap_mobile",
      "min": 12,
      "max": 48,
      "step": 2,
      "unit": "px",
      "label": "Card gap on mobile/tablet",
      "default": 20
    },
    {
      "type": "range",
      "id": "grid_gap_desktop",
      "min": 16,
      "max": 56,
      "step": 2,
      "unit": "px",
      "label": "Card gap on desktop",
      "default": 26
    },
    {
      "type": "header",
      "content": "Cards"
    },
    {
      "type": "range",
      "id": "card_min_height_mobile",
      "min": 160,
      "max": 520,
      "step": 10,
      "unit": "px",
      "label": "Card minimum height on mobile",
      "default": 300
    },
    {
      "type": "range",
      "id": "card_min_height_desktop",
      "min": 120,
      "max": 620,
      "step": 10,
      "unit": "px",
      "label": "Card minimum height on desktop",
      "default": 360
    },
    {
      "type": "range",
      "id": "card_padding_mobile",
      "min": 12,
      "max": 64,
      "step": 2,
      "unit": "px",
      "label": "Card padding on mobile",
      "default": 32
    },
    {
      "type": "range",
      "id": "card_padding_desktop",
      "min": 12,
      "max": 80,
      "step": 2,
      "unit": "px",
      "label": "Card padding on desktop",
      "default": 44
    },
    {
      "type": "range",
      "id": "card_radius",
      "min": 0,
      "max": 36,
      "step": 2,
      "unit": "px",
      "label": "Card corner radius",
      "default": 18
    },
    {
      "type": "header",
      "content": "Icons"
    },
    {
      "type": "range",
      "id": "icon_size_mobile",
      "min": 56,
      "max": 140,
      "step": 2,
      "unit": "px",
      "label": "Icon size on mobile",
      "default": 88
    },
    {
      "type": "range",
      "id": "icon_size_desktop",
      "min": 64,
      "max": 160,
      "step": 2,
      "unit": "px",
      "label": "Icon size on desktop",
      "default": 96
    },
    {
      "type": "range",
      "id": "icon_image_scale",
      "min": 80,
      "max": 240,
      "step": 5,
      "unit": "%",
      "label": "Image scale inside icon",
      "info": "Increase this when uploaded icon files have extra whitespace around the artwork.",
      "default": 100
    },
    {
      "type": "range",
      "id": "icon_bottom_spacing_mobile",
      "min": 16,
      "max": 56,
      "step": 2,
      "unit": "px",
      "label": "Space below icon on mobile",
      "default": 28
    },
    {
      "type": "range",
      "id": "icon_bottom_spacing_desktop",
      "min": 18,
      "max": 72,
      "step": 2,
      "unit": "px",
      "label": "Space below icon on desktop",
      "default": 36
    },
    {
      "type": "header",
      "content": "Colors"
    },
    {
      "type": "color",
      "id": "background_color",
      "label": "Background",
      "default": "#fbfaf7"
    },
    {
      "type": "color",
      "id": "card_background_color",
      "label": "Card background",
      "default": "#fffdf9"
    },
    {
      "type": "color",
      "id": "card_border_color",
      "label": "Card border",
      "default": "#e8e1d6"
    },
    {
      "type": "color",
      "id": "heading_color",
      "label": "Heading",
      "default": "#24221f"
    },
    {
      "type": "color",
      "id": "eyebrow_color",
      "label": "Eyebrow",
      "default": "#b46483"
    },
    {
      "type": "color",
      "id": "subheading_color",
      "label": "Subheading",
      "default": "#77716b"
    },
    {
      "type": "color",
      "id": "card_title_color",
      "label": "Card title",
      "default": "#414A29"
    },
    {
      "type": "color",
      "id": "card_body_color",
      "label": "Card body",
      "default": "#7a746d"
    },
    {
      "type": "color",
      "id": "icon_background_color",
      "label": "Fallback icon background",
      "default": "#edf0d8"
    },
    {
      "type": "color",
      "id": "icon_color",
      "label": "Fallback icon color",
      "default": "#414A29"
    }
  ],
  "blocks": [
    {
      "type": "card",
      "name": "Value card",
      "limit": 4,
      "settings": [
        {
          "type": "image_picker",
          "id": "icon",
          "label": "Icon image"
        },
        {
          "type": "select",
          "id": "fallback_icon",
          "label": "Fallback icon",
          "options": [
            {
              "value": "tree",
              "label": "Heritage tree"
            },
            {
              "value": "leaf",
              "label": "Jute leaf"
            },
            {
              "value": "cotton",
              "label": "Cotton"
            },
            {
              "value": "planet",
              "label": "Planet"
            }
          ],
          "default": "tree"
        },
        {
          "type": "text",
          "id": "title",
          "label": "Title",
          "default": "HONOR HERITAGE"
        },
        {
          "type": "richtext",
          "id": "body",
          "label": "Body",
          "default": "<p>Bengal jute and Bangla script woven into every design — honoring the roots and heritage textiles that inspire us.</p>"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Kaahu value cards",
      "blocks": [
        {
          "type": "card"
        },
        {
          "type": "card"
        },
        {
          "type": "card"
        },
        {
          "type": "card"
        }
      ]
    }
  ]
}
{% endschema %}
