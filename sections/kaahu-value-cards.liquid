{{ 'section-kaahu-value-cards.css' | asset_url | stylesheet_tag }}

{%- style -%}
  .section-{{ section.id }} {
    --kvc-bg: {{ section.settings.background_color }};
    --kvc-card-bg: {{ section.settings.card_background_color }};
    --kvc-card-border: {{ section.settings.card_border_color }};
    --kvc-card-border-width: {{ section.settings.card_border_width }}px;
    --kvc-heading-color: {{ section.settings.heading_color }};
    --kvc-eyebrow-color: {{ section.settings.eyebrow_color }};
    --kvc-subheading-color: {{ section.settings.subheading_color }};
    --kvc-title-color: {{ section.settings.card_title_color }};
    --kvc-body-color: {{ section.settings.card_body_color }};
    --kvc-icon-bg: {{ section.settings.icon_background_color }};
    --kvc-icon-color: {{ section.settings.icon_color }};
    --kvc-page-width: {{ section.settings.page_width }}px;
    --kvc-card-list-width: {{ section.settings.card_list_width }}px;
    --kvc-header-width: {{ section.settings.header_width }}px;
    --kvc-header-align: {{ section.settings.header_alignment }};
    --kvc-edge-padding-mobile: {{ section.settings.edge_padding_mobile }}px;
    --kvc-edge-padding-desktop: {{ section.settings.edge_padding_desktop }}px;
    --kvc-padding-top-mobile: {{ section.settings.padding_top | times: 0.68 | round }}px;
    --kvc-padding-bottom-mobile: {{ section.settings.padding_bottom | times: 0.72 | round }}px;
    --kvc-padding-top-desktop: {{ section.settings.padding_top }}px;
    --kvc-padding-bottom-desktop: {{ section.settings.padding_bottom }}px;
    --kvc-header-cards-gap-mobile: {{ section.settings.header_cards_gap_mobile }}px;
    --kvc-header-cards-gap-desktop: {{ section.settings.header_cards_gap_desktop }}px;
    --kvc-grid-gap-mobile: {{ section.settings.grid_gap_mobile }}px;
    --kvc-grid-gap-desktop: {{ section.settings.grid_gap_desktop }}px;
    --kvc-card-min-height-mobile: {{ section.settings.card_min_height_mobile }}px;
    --kvc-card-min-height-desktop: {{ section.settings.card_min_height_desktop }}px;
    --kvc-card-padding-x-mobile: {{ section.settings.card_padding_x_mobile }}px;
    --kvc-card-padding-y-mobile: {{ section.settings.card_padding_y_mobile }}px;
    --kvc-card-padding-x-desktop: {{ section.settings.card_padding_x_desktop }}px;
    --kvc-card-padding-y-desktop: {{ section.settings.card_padding_y_desktop }}px;
    --kvc-card-column-gap-mobile: {{ section.settings.card_column_gap_mobile }}px;
    --kvc-card-column-gap-desktop: {{ section.settings.card_column_gap_desktop }}px;
    --kvc-card-radius: {{ section.settings.card_radius }}px;
    --kvc-icon-size-mobile: {{ section.settings.icon_size_mobile }}px;
    --kvc-icon-size-desktop: {{ section.settings.icon_size_desktop }}px;
    --kvc-icon-image-scale: {{ section.settings.icon_image_scale | divided_by: 100.0 }};
    --kvc-title-body-gap: {{ section.settings.title_body_gap }}px;
    --kvc-title-size-mobile: {{ section.settings.title_size_mobile }}px;
    --kvc-title-size-desktop: {{ section.settings.title_size_desktop }}px;
    --kvc-title-font-weight: {{ section.settings.title_font_weight }};
    --kvc-title-line-height: {{ section.settings.title_line_height | divided_by: 100.0 }};
    --kvc-title-letter-spacing: {{ section.settings.title_letter_spacing | divided_by: 100.0 }}em;
    --kvc-body-size-mobile: {{ section.settings.body_size_mobile }}px;
    --kvc-body-size-desktop: {{ section.settings.body_size_desktop }}px;
    --kvc-body-font-weight: {{ section.settings.body_font_weight }};
    --kvc-body-line-height: {{ section.settings.body_line_height | divided_by: 100.0 }};
  }
{%- endstyle -%}

<section class="kaahu-value-cards section-{{ section.id }}">
  <div class="kaahu-value-cards__inner">
    {%- if section.settings.eyebrow != blank or section.settings.heading != blank or section.settings.subheading != blank -%}
      <div class="kaahu-value-cards__header">
        {%- if section.settings.eyebrow != blank -%}
          <div class="kaahu-value-cards__eyebrow">{{ section.settings.eyebrow }}</div>
        {%- endif -%}

        {%- if section.settings.heading != blank -%}
          <h2 class="kaahu-value-cards__heading">{{ section.settings.heading }}</h2>
        {%- endif -%}

        {%- if section.settings.subheading != blank -%}
          <div class="kaahu-value-cards__subheading rte">{{ section.settings.subheading }}</div>
        {%- endif -%}
      </div>
    {%- endif -%}

    <div class="kaahu-value-cards__list">
      {%- for block in section.blocks -%}
        <article class="kaahu-value-cards__card" {{ block.shopify_attributes }}>
          <div class="kaahu-value-cards__icon-wrap">
            {%- if block.settings.icon != blank -%}
              {{
                block.settings.icon
                | image_url: width: 320
                | image_tag:
                  loading: 'lazy',
                  class: 'kaahu-value-cards__icon-image',
                  alt: block.settings.title
              }}
            {%- else -%}
              <span class="kaahu-value-cards__icon-fallback kaahu-value-cards__icon-fallback--{{ block.settings.fallback_icon }}" aria-hidden="true">
                {%- case block.settings.fallback_icon -%}
                  {%- when 'leaf' -%}
                    <svg viewBox="0 0 64 64" focusable="false">
                      <circle cx="32" cy="32" r="30" fill="currentColor" opacity=".12"/>
                      <path d="M45 14c-10 1-18 5-23 12-5 6-6 14-3 24 10-1 18-5 23-12 5-6 6-14 3-24Z" fill="none" stroke="currentColor" stroke-width="3" stroke-linejoin="round"/>
                      <path d="M22 43c5-10 11-16 19-21M30 34l-8-2M35 29l1-8" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round"/>
                    </svg>
                  {%- when 'cotton' -%}
                    <svg viewBox="0 0 64 64" focusable="false">
                      <circle cx="32" cy="32" r="30" fill="currentColor" opacity=".12"/>
                      <path d="M24 39c-6 0-10-4-10-9 0-5 4-9 9-9 1-5 5-8 10-8s9 3 10 8c5 0 9 4 9 9s-4 9-10 9H24Z" fill="none" stroke="currentColor" stroke-width="3" stroke-linejoin="round"/>
                      <path d="M32 39v11M23 48h18" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round"/>
                    </svg>
                  {%- when 'planet' -%}
                    <svg viewBox="0 0 64 64" focusable="false">
                      <circle cx="32" cy="32" r="30" fill="currentColor" opacity=".12"/>
                      <circle cx="32" cy="32" r="18" fill="none" stroke="currentColor" stroke-width="3"/>
                      <path d="M17 29c5 1 8 0 10-3 2-2 5-2 8 0 3 3 6 3 11 2M25 47c0-5 2-8 6-9 5-2 8 0 10 4" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round"/>
                    </svg>
                  {%- else -%}
                    <svg viewBox="0 0 64 64" focusable="false">
                      <circle cx="32" cy="32" r="30" fill="currentColor" opacity=".12"/>
                      <path d="M32 15c9 5 15 13 15 22 0 8-6 14-15 14s-15-6-15-14c0-9 6-17 15-22Z" fill="none" stroke="currentColor" stroke-width="3" stroke-linejoin="round"/>
                      <path d="M24 36c5 0 10-4 16-12M26 43c6-1 11-5 15-12" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round"/>
                    </svg>
                {%- endcase -%}
              </span>
            {%- endif -%}
          </div>

          <div class="kaahu-value-cards__content">
            {%- if block.settings.title != blank -%}
              <h3 class="kaahu-value-cards__title">{{ block.settings.title }}</h3>
            {%- endif -%}

            {%- if block.settings.body != blank -%}
              <div class="kaahu-value-cards__body rte">{{ block.settings.body }}</div>
            {%- endif -%}
          </div>
        </article>
      {%- endfor -%}
    </div>
  </div>
</section>

{% schema %}
