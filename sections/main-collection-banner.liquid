{%- liquid
  assign banner_image = section.settings.custom_banner_image | default: collection.image
  assign banner_mobile_image = section.settings.custom_mobile_banner_image | default: banner_image
  assign banner_title = section.settings.custom_heading | default: collection.title
  assign banner_description = section.settings.custom_description | default: collection.description
  assign banner_image_alt = section.settings.custom_image_alt | default: banner_title | escape
  assign content_max_width = section.settings.kaahu_content_max_width | default: 620
  assign content_left_desktop = section.settings.kaahu_content_left_desktop | default: 16
  assign content_offset_y = section.settings.kaahu_content_offset_y | default: 0
  assign description_gap = section.settings.kaahu_description_gap | default: section.settings.title_margin | default: 14
  assign title_size_mobile = section.settings.kaahu_title_size_mobile | default: 42
  assign title_size_desktop = section.settings.kaahu_title_size_desktop | default: 68
  assign description_size_mobile = section.settings.kaahu_description_size_mobile | default: 16
  assign description_size_desktop = section.settings.kaahu_description_size_desktop | default: 18
  assign overlay_opacity = section.settings.kaahu_overlay_opacity | default: 35
  assign is_split = false
  if section.settings.banner_layout == 'split_banner' and banner_image != blank
    assign is_split = true
  endif
  assign is_overlay = false
  if banner_image != blank and section.settings.banner_layout != 'text-only' and is_split == false
    assign is_overlay = true
  endif
  assign image_render_size = 1800
  if banner_image != blank and banner_image.width < 1800
    assign image_render_size = banner_image.width
  endif
-%}

{% style %}
.section-{{ section.id }} {
  --collection-banner-bg: {{ section.settings.bg_col }};
  --collection-banner-text: {{ section.settings.txt_col }};
  --collection-banner-overlay: {{ overlay_opacity | divided_by: 100.0 }};
  --collection-banner-content-max: {{ content_max_width }}px;
  --collection-banner-content-left: {{ content_left_desktop }}%;
  --collection-banner-offset-y: {{ content_offset_y }}px;
  --collection-banner-gap: {{ description_gap }}px;
  --collection-banner-title-mobile: {{ title_size_mobile }}px;
  --collection-banner-title-desktop: {{ title_size_desktop }}px;
  --collection-banner-body-mobile: {{ description_size_mobile }}px;
  --collection-banner-body-desktop: {{ description_size_desktop }}px;
  --collection-banner-eyebrow: {{ section.settings.kaahu_eyebrow_color }};
  --collection-banner-image-position-mobile: {{ section.settings.custom_image_position_mobile }};
  --collection-banner-image-position-desktop: {{ section.settings.custom_image_position_desktop }};
  padding-top: {{ section.settings.top_padding }}px;
  padding-bottom: {{ section.settings.bottom_padding }}px;
  background: var(--collection-banner-bg);
  color: var(--collection-banner-text);
}

.section-{{ section.id }} .collection-banner-simple {
  position: relative;
  overflow: visible;
  background: var(--collection-banner-bg);
}

.section-{{ section.id }} .collection-banner-simple__media,
.section-{{ section.id }} .collection-banner-simple__media picture,
.section-{{ section.id }} .collection-banner-simple__media img {
  display: block;
  width: 100%;
  height: 100%;
}

.section-{{ section.id }} .collection-banner-simple__media img {
  object-fit: cover;
  object-position: var(--collection-banner-image-position-mobile);
}

.section-{{ section.id }} .collection-banner-simple__content {
  box-sizing: border-box;
  width: 100%;
  max-width: var(--collection-banner-content-max);
  color: var(--collection-banner-text);
  text-align: {{ section.settings.txt_alignment }};
}

.section-{{ section.id }} .collection-banner-simple__eyebrow {
  margin: 0 0 20px;
  color: var(--collection-banner-eyebrow);
  font-family: var(--font-body-family);
  font-size: 12px;
  font-weight: 700;
  letter-spacing: .32em;
  line-height: 1.3;
  text-transform: uppercase;
  text-shadow: 0 1px 10px rgba(0, 0, 0, .45);
}

.section-{{ section.id }} .collection-banner-simple__heading {
  margin: 0;
  color: inherit;
  font-family: var(--font-heading-family);
  font-size: var(--collection-banner-title-mobile);
  font-weight: var(--font-heading-weight);
  line-height: .95;
  letter-spacing: 0;
  text-shadow: 0 2px 26px rgba(0, 0, 0, .38);
}

.section-{{ section.id }} .collection-banner-simple__body {
  margin-top: var(--collection-banner-gap);
  color: inherit;
  font-size: var(--collection-banner-body-mobile);
  line-height: 1.55;
  text-shadow: 0 1px 12px rgba(0, 0, 0, .36);
}

.section-{{ section.id }} .collection-banner-simple__body > *:first-child {
  margin-top: 0;
}

.section-{{ section.id }} .collection-banner-simple__body > *:last-child {
  margin-bottom: 0;
}

.section-{{ section.id }} .collection-banner-simple--overlay {
  display: flex;
  align-items: center;
  min-height: 480px;
  padding-top: calc(64px + var(--collection-banner-offset-y));
  padding-bottom: 64px;
}

.section-{{ section.id }} .collection-banner-simple--overlay .collection-banner-simple__media {
  position: absolute;
  inset: 0;
}

.section-{{ section.id }} .collection-banner-simple--overlay::after {
  content: "";
  position: absolute;
  inset: 0;
  background: rgba(21, 18, 13, var(--collection-banner-overlay));
  pointer-events: none;
}

.section-{{ section.id }} .collection-banner-simple--overlay .collection-banner-simple__content {
  position: relative;
  z-index: 1;
  margin-left: max(var(--page-margin-mobile), 24px);
  margin-right: max(var(--page-margin-mobile), 24px);
}

.section-{{ section.id }} .collection-banner-simple--split {
  display: grid;
  color: var(--collection-banner-text);
}

.section-{{ section.id }} .collection-banner-simple--split .collection-banner-simple__media {
  min-height: 260px;
}

.section-{{ section.id }} .collection-banner-simple--split .collection-banner-simple__content {
  padding: calc(var(--page-margin-mobile) + var(--collection-banner-offset-y)) var(--page-margin-mobile) var(--page-margin-mobile);
}

.section-{{ section.id }} .collection-banner-simple--text {
  padding: 60px var(--page-margin-mobile);
}

.section-{{ section.id }} .collection-banner-simple--text .collection-banner-simple__content,
.section-{{ section.id }} .align-center {
  margin-left: auto;
  margin-right: auto;
}

@media only screen and (min-width: 750px) {
  .section-{{ section.id }} .collection-banner-simple--overlay {
    min-height: 500px;
  }
}

@media only screen and (min-width: 900px) {
  .section-{{ section.id }} .collection-banner-simple--split {
    grid-template-columns: repeat(2, minmax(0, 1fr));
    align-items: stretch;
  }

  .section-{{ section.id }} .collection-banner-simple--split .collection-banner-simple__media {
    min-height: 34vw;
    order: {% if section.settings.cards_img_position == 'left' %}1{% else %}2{% endif %};
  }

  .section-{{ section.id }} .collection-banner-simple--split .collection-banner-simple__content {
    display: flex;
    flex-direction: column;
    justify-content: center;
    order: {% if section.settings.cards_img_position == 'left' %}2{% else %}1{% endif %};
    padding: calc(3rem + var(--collection-banner-offset-y)) var(--page-margin-desktop) 3rem;
  }
}

@media only screen and (min-width: 1025px) {
  .section-{{ section.id }} .collection-banner-simple--overlay {
    min-height: 500px;
  }

  .section-{{ section.id }} .collection-banner-simple--overlay .collection-banner-simple__content {
    margin-left: var(--collection-banner-content-left);
    margin-right: auto;
  }

  .section-{{ section.id }} .collection-banner-simple__heading {
    font-size: var(--collection-banner-title-desktop);
  }

  .section-{{ section.id }} .collection-banner-simple__body {
    font-size: var(--collection-banner-body-desktop);
  }

  .section-{{ section.id }} .collection-banner-simple__media img {
    object-position: var(--collection-banner-image-position-desktop);
  }
}

@media only screen and (min-width: 1350px) {
  .section-{{ section.id }} .collection-banner-simple--overlay {
    min-height: 550px;
  }
}

@media only screen and (min-width: 1600px) {
  .section-{{ section.id }} .collection-banner-simple--overlay {
    min-height: 600px;
  }
}
{% endstyle %}

<div class="collection-banner-wrapper section-{{ section.id }} collection-template-{{ template.suffix | default: template.name | handle }} collection-banner-{{ section.settings.banner_layout }} cbw-image-ratio--{{ section.settings.stacked_img_ratio }} text-width--{{ section.settings.text_width }}">
  <div class="collection-banner-simple{% if is_split %} collection-banner-simple--split{% elsif is_overlay %} collection-banner-simple--overlay{% else %} collection-banner-simple--text{% endif %}">
    {%- if banner_image != blank -%}
      <div class="collection-banner-simple__media">
        <picture>
          {%- if banner_mobile_image != blank -%}
            <source media="(max-width: 749px)" srcset="{{ banner_mobile_image | image_url: width: 900 }}">
          {%- endif -%}
          {{ banner_image | image_url: width: image_render_size | image_tag: loading: 'eager', fetchpriority: 'high', alt: banner_image_alt }}
        </picture>
      </div>
    {%- endif -%}

    <div class="collection-banner-simple__content align-{{ section.settings.txt_alignment }}">
      {%- if section.settings.kaahu_eyebrow != blank -%}
        <div class="collection-banner-simple__eyebrow">{{ section.settings.kaahu_eyebrow }}</div>
      {%- endif -%}

      {%- if banner_title != blank -%}
        <h1 class="collection-banner-simple__heading {{ section.settings.title_size }}">{{ banner_title | escape }}</h1>
      {%- endif -%}

      {%- if section.settings.description_enable and banner_description != blank -%}
        <div class="collection-banner-simple__body {{ section.settings.description_size }} cd-indent-{{ section.settings.text_indent }}">
          {{ banner_description }}
        </div>
      {%- endif -%}
    </div>
  </div>
</div>

