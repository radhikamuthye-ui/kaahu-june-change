{{ 'component-collection-hero.css' | asset_url | stylesheet_tag }}

{%- liquid
  assign banner_image = section.settings.custom_banner_image | default: collection.image
  assign banner_mobile_image = section.settings.custom_mobile_banner_image | default: banner_image
  assign banner_title = section.settings.custom_heading | default: collection.title
  assign banner_description = section.settings.custom_description | default: collection.description
  assign banner_image_alt = section.settings.custom_image_alt | default: banner_title | escape
-%}

{% style %}
.collection-banner-wrapper {
  padding-top: {{ section.settings.top_padding }}px;
  padding-bottom: {{ section.settings.bottom_padding }}px;
}
  
.collection-banner-card-banner {
  color: {{ section.settings.txt_col }};
  background: {{ section.settings.bg_col }};
}
.collection-banner-card-banner h1 {
  color: {{ section.settings.txt_col }};
}

.collection-std-description-below, .collection-title-bb {
  padding-top: {{ section.settings.description_padding }}px;
}

.collection-title-ab {
  padding-bottom: {{ section.settings.description_padding }}px;
}

.collection-banner h1 {
  margin-bottom: {{ section.settings.title_margin }}px;
}

.section-{{ section.id }} {
  --kaahu-collection-hero-title-size-mobile: {{ section.settings.kaahu_title_size_mobile }}px;
  --kaahu-collection-hero-title-size-desktop: {{ section.settings.kaahu_title_size_desktop }}px;
  --kaahu-collection-hero-description-size-mobile: {{ section.settings.kaahu_description_size_mobile }}px;
  --kaahu-collection-hero-description-size-desktop: {{ section.settings.kaahu_description_size_desktop }}px;
  --kaahu-collection-hero-overlay-opacity: {{ section.settings.kaahu_overlay_opacity | divided_by: 100.0 }};
  --kaahu-collection-hero-content-max-width: {{ section.settings.kaahu_content_max_width }}px;
  --kaahu-collection-hero-content-left: {{ section.settings.kaahu_content_left_desktop }}%;
  --kaahu-collection-hero-content-offset-y: {{ section.settings.kaahu_content_offset_y }}px;
  --kaahu-collection-hero-description-gap: {{ section.settings.kaahu_description_gap }}px;
  --kaahu-collection-hero-image-position-desktop: {{ section.settings.custom_image_position_desktop }};
  --kaahu-collection-hero-image-position-mobile: {{ section.settings.custom_image_position_mobile }};
  --kaahu-collection-hero-eyebrow-color: {{ section.settings.kaahu_eyebrow_color }};
  --kaahu-collection-hero-breadcrumb-color: {{ section.settings.kaahu_breadcrumb_color }};
}

{% if section.settings.cards_img_position == 'left' %}
@media only screen and (min-width: 900px) {
  .collection-card-banner--image-card {
    order: 1
  }
  .collection-card-banner--text-card {
    order: 2
  }
}
{% endif %}

{% if section.settings.image_padding == 'page_margin' %}
  .collection-card-banner--image-card {
    padding: var(--page-margin-mobile);
  }
  .collection-card-banner--image-card img {
    border-radius: var(--media-radius);
  }
  @media only screen and (min-width: 1025px) {
    .collection-card-banner--image-card {
      padding: var(--page-margin-desktop) calc(var(--grid-desktop-horizontal-spacing) * 0.5) var(--page-margin-desktop) var(--page-margin-desktop);
    }    
  }
  {% if section.settings.cards_img_position == 'right' %}
  @media only screen and (min-width: 1025px) {
    .collection-card-banner--image-card {
      padding: var(--page-margin-desktop) var(--page-margin-desktop) var(--page-margin-desktop) calc(var(--grid-desktop-horizontal-spacing) * 0.5);
    }
    .collection-card-banner--text-card {
      padding: var(--page-margin-desktop) calc(var(--grid-desktop-horizontal-spacing) * 0.5) var(--page-margin-desktop) var(--page-margin-desktop);
    }
  }
  {% endif %}    
{% endif %}

{% endstyle %}

<div class="collection-banner-wrapper collection-template-{{ template.suffix | default: template.name | handle }} collection-banner-{{ section.settings.banner_layout }} cbw-image-ratio--{{ section.settings.stacked_img_ratio }} text-width--{{ section.settings.text_width }}">

{% if section.settings.banner_layout == 'split_banner' and banner_image %}

<div class="collection-banner-card-banner{% if section.settings.image_padding == 'page_margin' %} collection-banner-card-banner--inset{% else %} collection-banner-card-banner--fb{% endif %} banner-grid-spacing--{{ section.settings.grid_spacing }}">
<div class="collection-card-banner--image-card ccbi-{{ section.settings.cards_img_ratio }}">
{% if banner_image %}{{ banner_image | image_url: width: 1800 | image_tag: loading: 'eager', fetchpriority: 'high', alt: banner_image_alt }}{% endif %}
</div>
<div class="collection-card-banner--text-card">
<div class="align-{{ section.settings.txt_alignment }}">
  {%- if section.settings.kaahu_eyebrow != blank -%}<div class="collection-banner-eyebrow">{{ section.settings.kaahu_eyebrow }}</div>{%- endif -%}
  <h1 class="{{ section.settings.title_size }}">{{ banner_title }}</h1>
  {% if section.settings.description_enable and banner_description != blank %}
  <span class="{{ section.settings.description_size }} cd-indent-{{ section.settings.text_indent }}">{{ banner_description }}</span>
  {% endif %}
</div>
</div>
</div>

{% endif %}

{% if section.settings.banner_layout == 'stacked-image-last' and banner_image %}
<div class="collection-title-ab align-{{ section.settings.txt_alignment }} page-width">
  {%- if section.settings.kaahu_eyebrow != blank -%}<div class="collection-banner-eyebrow">{{ section.settings.kaahu_eyebrow }}</div>{%- endif -%}
  <h1 class="{{ section.settings.title_size }}">{{ banner_title }}</h1>
  {% if section.settings.description_enable and banner_description != blank %}
  <div class="collection-title-ab-description cd-indent-{{ section.settings.text_indent }}">{{ banner_description }}</div>
  {% endif %}
</div>
{% endif %}

{% if section.settings.banner_layout != 'split_banner' and section.settings.banner_layout != 'text-only' and banner_image %}
<div class="collection-banner {{ section.settings.banner_width }} cb-height-mobile--{{ section.settings.banner_height_mobile }} collection-banner-{{ section.settings.banner_height }}">
{% if section.settings.banner_layout contains 'overlay' %}
<div class="collection-banner-title page-width align-{{ section.settings.txt_alignment }}">
{%- if section.settings.show_kaahu_breadcrumbs -%}
  <nav class="collection-banner-breadcrumb" aria-label="Breadcrumb">
    {%- if section.settings.breadcrumb_home_text != blank -%}
      <a href="{{ routes.root_url }}">{{ section.settings.breadcrumb_home_text }}</a>
    {%- endif -%}
    {%- if section.settings.breadcrumb_middle_text != blank -%}
      <span aria-hidden="true">/</span>
      {%- if section.settings.breadcrumb_middle_link != blank -%}
        <a href="{{ section.settings.breadcrumb_middle_link }}">{{ section.settings.breadcrumb_middle_text }}</a>
      {%- else -%}
        <span>{{ section.settings.breadcrumb_middle_text }}</span>
      {%- endif -%}
    {%- endif -%}
    {%- if section.settings.breadcrumb_current_text != blank -%}
      <span aria-hidden="true">/</span>
      <span aria-current="page">{{ section.settings.breadcrumb_current_text }}</span>
    {%- endif -%}
  </nav>
{%- endif -%}
{%- if section.settings.kaahu_eyebrow != blank -%}<div class="collection-banner-eyebrow">{{ section.settings.kaahu_eyebrow }}</div>{%- endif -%}
<h1 class="{{ section.settings.title_size }}">{{ banner_title | escape }}</h1>

{% if section.settings.description_enable and banner_description != blank %}
{% unless section.settings.banner_layout == 'overlay-db' %}
<div class="collection-banner-description {{ section.settings.description_size }} align-{{ section.settings.txt_alignment }} cd-indent-{{ section.settings.text_indent }}">
{{ banner_description }}
</div>
{% endunless %}
{% endif %}
  
</div>
{% endif %}
{% if banner_image %}

{% if banner_image.width > 2777 %}
{% assign image_render_size = 2800 %}
{% else %}
{% assign image_render_size = banner_image.width %}
{% endif %}

<div class="collection-banner-bg-img">
  <picture>
    {%- if banner_mobile_image != blank -%}
      <source media="(max-width: 749px)" srcset="{{ banner_mobile_image | image_url: width: 900 }}">
    {%- endif -%}
    {{ banner_image | image_url: width: image_render_size | image_tag: loading: 'eager', fetchpriority: 'high', alt: banner_image_alt }}
  </picture>
</div>
{% endif %}
</div>
{% endif %}

{% if section.settings.banner_layout == 'overlay-db' and banner_image and section.settings.description_enable and banner_description != blank %}
<div class="collection-std-description {{ section.settings.description_size }} collection-std-description-below align-{{ section.settings.txt_alignment }} page-width cd-indent-{{ section.settings.text_indent }}">
{{ banner_description }}
</div> 
{% endif %}

{% if section.settings.banner_layout == 'stacked-image-first' and banner_image %}
<div class="collection-title-bb page-width align-{{ section.settings.txt_alignment }}">
{%- if section.settings.kaahu_eyebrow != blank -%}<div class="collection-banner-eyebrow">{{ section.settings.kaahu_eyebrow }}</div>{%- endif -%}
<h1>{{ banner_title | escape }}</h1>

{% if banner_description != blank and section.settings.description_enable %}
<div class="collection-std-description {{ section.settings.description_size }} align-{{ section.settings.txt_alignment }} cd-indent-{{ section.settings.text_indent }}">
{{ banner_description }}
</div>  
{% endif %}
</div>
{% endif %}

{% if section.settings.banner_layout == 'text-only' or banner_image == blank  %} 
<div class="collection-banner-std page-width{% if section.settings.banner_layout != 'text-only' and banner_image == blank %} collection-banner-no-image{% endif %}">
<div class="collection-banner-std-title align-{{ section.settings.txt_alignment }}">
{%- if section.settings.kaahu_eyebrow != blank -%}<div class="collection-banner-eyebrow">{{ section.settings.kaahu_eyebrow }}</div>{%- endif -%}
<h1 class="{{ section.settings.title_size }}">{{ banner_title | escape }}</h1>
</div>
{% if section.settings.description_enable and banner_description != blank %}
<div class="collection-std-description {{ section.settings.description_size }} align-{{ section.settings.txt_alignment }} cd-indent-{{ section.settings.text_indent }}">
{{ banner_description }}
</div>
{% endif %}
</div>
{% endif %}

</div>

{% schema %}
{
  "name": "t:sections.main-collection-banner.name",
  "class": "section",
  "settings": [
    {
      "type": "paragraph",
      "content": "t:sections.main-collection-banner.settings.paragraph.content"
    },
    {
      "type": "header",
      "content": "Layout"
    },
    {
      "type": "select",
      "id": "banner_layout",
      "label": "t:sections.main-collection-banner.settings.banner_type.label",
      "options": [
        {
          "value": "overlay",
          "label": "t:sections.main-collection-banner.settings.banner_type.options__1.label"
        },
        {
          "value": "overlay-db",
          "label": "t:sections.main-collection-banner.settings.banner_type.options__2.label"
        },
        {
          "value": "stacked-image-first",
          "label": "t:sections.main-collection-banner.settings.banner_type.options__3.label"
        },
        {
          "value": "stacked-image-last",
          "label": "t:sections.main-collection-banner.settings.banner_type.options__4.label"
        },
        {
          "value": "split_banner",
          "label": "t:sections.main-collection-banner.settings.banner_type.options__5.label"
        },
        {
          "value": "text-only",
          "label": "t:sections.main-collection-banner.settings.banner_type.options__6.label"
        }
      ],
      "default": "overlay"
    },
    {
      "type": "select",
      "id": "banner_height_mobile",
      "visible_if": "{{ section.settings.banner_layout == 'overlay' or section.settings.banner_layout == 'overlay-db' }}",
      "label": "t:sections.main-collection-banner.settings.banner_height_mobile.label",
      "options": [
        {
          "value": "slim",
          "label": "t:sections.all.size.small"
        },
        {
          "value": "default",
          "label": "t:sections.all.size.medium"
        },
        {
          "value": "large",
          "label": "t:sections.all.size.large"
        },
        {
          "value": "fullscreen",
          "label": "t:sections.all.size.fullscreen"
        }
      ],
      "default": "default"
    },
    {
      "type": "select",
      "id": "banner_height",
      "visible_if": "{{ section.settings.banner_layout == 'overlay' or section.settings.banner_layout == 'overlay-db' }}",
      "label": "t:sections.main-collection-banner.settings.banner_height.label",
      "options": [
        {
          "value": "slim",
          "label": "t:sections.all.size.small"
        },
        {
          "value": "default",
          "label": "t:sections.all.size.medium"
        },
        {
          "value": "large",
          "label": "t:sections.all.size.large"
        },
        {
          "value": "fullscreen",
          "label": "t:sections.all.size.fullscreen"
        }
      ],
      "default": "default"
    },
    {
      "type": "select",
      "id": "stacked_img_ratio",
      "visible_if": "{{ section.settings.banner_layout == 'stacked-image-first' or section.settings.banner_layout == 'stacked-image-last' }}",
      "label": "t:sections.all.ratio.image_ratio",
      "options": [
        {
          "value": "landscape_32x9",
          "label": "24:9"
        },
        {
          "value": "landscape_21x9",
          "label": "21:9"
        },
        {
          "value": "landscape_16x9",
          "label": "16:9"
        },
        {
          "value": "landscape_6x4",
          "label": "6:4"
        },
        {
          "value": "fit",
          "label": "t:sections.all.ratio.adapt_to_image"
        }
      ],
      "default": "landscape_21x9"
    },
    {
      "type": "select",
      "id": "banner_width",
      "label": "t:sections.all.margin",
      "options": [
        {
          "value": "none",
          "label": "t:sections.all.full_width"
        },
        {
          "value": "page-width",
          "label": "t:sections.all.default"
        }
      ],
      "default": "none"
    },
    {
      "type": "header",
      "content": "t:sections.all.text"
    },
    {
      "type": "text",
      "id": "custom_heading",
      "label": "Custom heading",
      "info": "Leave blank to use the collection title."
    },
    {
      "type": "richtext",
      "id": "custom_description",
      "label": "Custom description",
      "info": "Leave blank to use the collection description."
    },
    {
      "type": "text",
      "id": "kaahu_eyebrow",
      "label": "Eyebrow text"
    },
    {
      "type": "checkbox",
      "id": "show_kaahu_breadcrumbs",
      "label": "Show breadcrumbs",
      "default": false
    },
    {
      "type": "text",
      "id": "breadcrumb_home_text",
      "label": "Breadcrumb home text",
      "default": "Home"
    },
    {
      "type": "text",
      "id": "breadcrumb_middle_text",
      "label": "Breadcrumb middle text"
    },
    {
      "type": "url",
      "id": "breadcrumb_middle_link",
      "label": "Breadcrumb middle link"
    },
    {
      "type": "text",
      "id": "breadcrumb_current_text",
      "label": "Breadcrumb current text"
    },
    {
      "type": "select",
      "id": "txt_alignment",
      "label": "t:sections.all.alignment.text_alignment_heading",
      "options": [
        {
          "value": "left",
          "label": "t:sections.all.alignment.left"
        },
        {
          "value": "center",
          "label": "t:sections.all.alignment.center"
        }
        ],
      "default": "left"
    },
    {
      "type": "select",
      "id": "text_width",
      "label": "t:sections.all.width",
      "options": [
        {
          "value": "small",
          "label": "t:sections.all.size.small"
        },
        {
          "value": "medium",
          "label": "t:sections.all.size.medium"
        },
        {
          "value": "wide",
          "label": "t:sections.all.size.wide"
        }
      ],
      "default": "medium"
    },
    {
      "type": "select",
      "id": "title_size",
      "label": "t:sections.all.heading_size.label",
      "options": [
        {
          "value": "h1",
          "label": "t:sections.all.heading_size.normal.label"
        },
        {
          "value": "ui-nav-element",
          "label": "t:sections.all.size.micro"
        },
        {
          "value": "h3",
          "label": "t:sections.all.heading_size.extra_small.label"
        },
        {
          "value": "h2",
          "label": "t:sections.all.heading_size.small.label"
        },
        {
          "value": "h0",
          "label": "t:sections.all.heading_size.large.label"
        },
        {
          "value": "hxl",
          "label": "t:sections.all.heading_size.xl.label"
        }
      ],
      "default": "h1"
    },
    {
      "type": "range",
      "id": "title_margin",
      "min": 0,
      "max": 80,
      "step": 5,
      "unit": "px",
      "default": 10,
      "label": "t:sections.all.heading_margin"
    },
    {
      "type": "checkbox",
      "id": "description_enable",
      "default": true,
      "label": "t:sections.main-collection-banner.settings.show_collection_description.label"
    },
    {
      "type": "select",
      "id": "description_size",
      "label": "t:sections.main-collection-banner.settings.description_font_size.label",
      "options": [
        {
          "value": "text-body",
          "label": "t:sections.all.size.normal"
        },
        {
          "value": "text-medium",
          "label": "t:sections.all.size.medium"
        },
        {
          "value": "text-large",
          "label": "t:sections.all.size.large"
        },
        {
          "value": "text-xl",
          "label": "t:sections.all.size.xl"
        }
      ],
      "default": "text-body"
    },
    {
      "type": "select",
      "id": "text_indent",
      "label": "t:sections.main-collection-banner.settings.description_text_indent.label",
      "options": [
        {
          "value": "none",
          "label": "t:sections.all.none"
        },
        {
          "value": "small",
          "label": "t:sections.all.size.small"
        },
        {
          "value": "medium",
          "label": "t:sections.all.size.medium"
        },
        {
          "value": "large",
          "label": "t:sections.all.size.large"
        }
      ],
      "default": "none"
    },
    {
      "type": "range",
      "id": "description_padding",
      "min": 20,
      "max": 120,
      "step": 10,
      "unit": "px",
      "default": 40,
      "label": "t:sections.all.padding.padding_vertical"
    },
    {
      "type": "header",
      "content": "t:sections.main-collection-banner.settings.header__1.content",
      "info": "t:sections.main-collection-banner.settings.header__1.info"
	  },
    {
      "type": "image_picker",
      "id": "custom_banner_image",
      "label": "Custom banner image",
      "info": "Leave blank to use the collection image."
    },
    {
      "type": "image_picker",
      "id": "custom_mobile_banner_image",
      "label": "Custom mobile banner image",
      "info": "Leave blank to use the custom banner image."
    },
    {
      "type": "text",
      "id": "custom_image_alt",
      "label": "Custom image alt text"
    },
    {
      "type": "text",
      "id": "custom_image_position_desktop",
      "label": "Image object position desktop",
      "default": "center center",
      "info": "Example: center center, 60% center, left center."
    },
    {
      "type": "text",
      "id": "custom_image_position_mobile",
      "label": "Image object position mobile",
      "default": "center center",
      "info": "Example: center center, 60% center, left center."
    },
    {
      "type": "select",
      "id": "cards_img_ratio",
      "label": "t:sections.all.ratio.image_ratio",
      "options": [
        {
          "value": "landscape",
          "label": "t:sections.all.ratio.landscape"
        },
        {
          "value": "square",
          "label": "t:sections.all.ratio.square"
        },
        {
          "value": "portrait",
          "label": "t:sections.all.ratio.portrait"
        },
        {
          "value": "fit",
          "label": "t:sections.all.ratio.adapt_to_image"
        }
      ],
      "default": "landscape"
    },
    {
      "type": "select",
      "id": "cards_img_position",
      "label": "t:sections.main-collection-banner.settings.image_position.label",
      "info": "t:sections.main-collection-banner.settings.image_position.info",
      "options": [
        {
          "value": "left",
          "label": "t:sections.all.alignment.left"
        },
        {
          "value": "right",
          "label": "t:sections.all.alignment.right"
        }
        ],
      "default": "right"
    },
    {
      "type": "select",
      "id": "image_padding",
      "label": "t:sections.all.margin",
      "options": [
        {
          "value": "none",
          "label": "t:sections.all.full_width"
        },
        {
          "value": "page_margin",
          "label": "t:sections.all.default"
        }
      ],
      "default": "none"
    },
    {
      "type": "select",
      "id": "grid_spacing",
      "label": "t:sections.all.layouts.horizontal_spacing",
      "options": [
        {
          "value": "none",
          "label": "t:sections.all.none"
        },
        {
          "value": "default",
          "label": "t:sections.all.default"
        }
      ],
      "default": "none"
    },
    {
      "type": "paragraph",
      "content": "t:sections.main-collection-banner.settings.paragraph_color.content"
	  },
    {
      "type": "color",
      "id": "txt_col",
      "label": "t:sections.all.colors.text_color.label"
    },
    {
      "type": "color",
      "id": "bg_col",
      "label": "t:sections.all.colors.background_color.label"
    },
    {
      "type": "header",
      "content": "All of Kaahu hero styling"
    },
    {
      "type": "range",
      "id": "kaahu_content_max_width",
      "min": 360,
      "max": 900,
      "step": 20,
      "unit": "px",
      "label": "Content max width",
      "default": 620
    },
    {
      "type": "range",
      "id": "kaahu_content_left_desktop",
      "min": 5,
      "max": 45,
      "step": 1,
      "unit": "%",
      "label": "Content left position desktop",
      "default": 16
    },
    {
      "type": "range",
      "id": "kaahu_content_offset_y",
      "min": -120,
      "max": 120,
      "step": 4,
      "unit": "px",
      "label": "Content vertical offset",
      "default": 0
    },
    {
      "type": "range",
      "id": "kaahu_description_gap",
      "min": 0,
      "max": 64,
      "step": 2,
      "unit": "px",
      "label": "Heading to description spacing",
      "default": 14
    },
    {
      "type": "range",
      "id": "kaahu_title_size_desktop",
      "min": 32,
      "max": 96,
      "step": 2,
      "unit": "px",
      "label": "Heading size desktop",
