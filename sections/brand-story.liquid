{{ 'component-image-with-text.css' | asset_url | stylesheet_tag }}
{{ 'section-brand-story.css' | asset_url | stylesheet_tag }}

{%- liquid
  assign eyebrow_font = section.settings.eyebrow_font_family
  assign intro_font = section.settings.intro_font_family
  assign heading_font = section.settings.heading_font_family
  assign body_font = section.settings.body_font_family
  assign heading_tag = section.settings.heading_tag
  if section.index == 1 and section.settings.heading_tag == 'h2'
    assign heading_tag = 'h1'
  endif
  assign feature_image = section.settings.desktop_image
  if feature_image == blank
    assign feature_image = section.settings.mobile_image
  endif
  assign image_alt = section.settings.image_alt | default: feature_image.alt | escape
  if image_alt == blank
    assign image_alt = section.settings.heading | escape
  endif
  assign desktop_image_height = section.settings.image_height_desktop
  assign mobile_image_height = section.settings.image_height_mobile
  assign background_gradient = section.settings.background_gradient
  if background_gradient == blank
    assign background_gradient = 'none'
  endif
-%}

{%- style -%}
  {{ eyebrow_font | font_face: font_display: 'swap' }}
  {{ intro_font | font_face: font_display: 'swap' }}
  {{ heading_font | font_face: font_display: 'swap' }}
  {{ body_font | font_face: font_display: 'swap' }}

  .section-{{ section.id }} {
    --bs-bg: {{ section.settings.background_color }};
    --bs-bg-gradient: {{ background_gradient }};
    --bs-section-max-width: {{ section.settings.section_max_width }}px;
    --bs-content-max-width: {{ section.settings.content_max_width }}px;
    --bs-padding-top-desktop: {{ section.settings.padding_top_desktop }}px;
    --bs-padding-bottom-desktop: {{ section.settings.padding_bottom_desktop }}px;
    --bs-padding-top-mobile: {{ section.settings.padding_top_mobile }}px;
    --bs-padding-bottom-mobile: {{ section.settings.padding_bottom_mobile }}px;
    --bs-gap-desktop: {{ section.settings.gap_desktop }}px;
    --bs-gap-mobile: {{ section.settings.gap_mobile }}px;
    --bs-content-width: {{ section.settings.content_width }}%;
    --bs-image-width: {{ section.settings.image_width }}%;
    --bs-vertical-align: {{ section.settings.content_vertical_alignment }};
    --bs-content-align-desktop: {{ section.settings.content_horizontal_alignment }};
    --bs-content-align-mobile: {{ section.settings.mobile_content_alignment }};
    --bs-image-aspect-ratio: {{ section.settings.image_aspect_ratio }};
    --bs-image-height-desktop: {% if desktop_image_height > 0 %}{{ desktop_image_height }}px{% else %}auto{% endif %};
    --bs-image-height-mobile: {% if mobile_image_height > 0 %}{{ mobile_image_height }}px{% else %}auto{% endif %};
    --bs-image-radius: {{ section.settings.image_border_radius }}px;
    --bs-image-fit: {{ section.settings.image_object_fit }};
    --bs-image-position: {{ section.settings.image_position }};
    --bs-eyebrow-font-family: {{ eyebrow_font.family }}, {{ eyebrow_font.fallback_families }};
    --bs-eyebrow-font-style: {{ eyebrow_font.style }};
    --bs-eyebrow-size-desktop: {{ section.settings.eyebrow_size_desktop }}px;
    --bs-eyebrow-size-mobile: {{ section.settings.eyebrow_size_mobile }}px;
    --bs-eyebrow-weight: {{ section.settings.eyebrow_weight }};
    --bs-eyebrow-letter-spacing: {{ section.settings.eyebrow_letter_spacing | divided_by: 100.0 }}em;
    --bs-eyebrow-color: {{ section.settings.eyebrow_color }};
    --bs-intro-font-family: {{ intro_font.family }}, {{ intro_font.fallback_families }};
    --bs-intro-font-style: {{ section.settings.intro_font_style }};
    --bs-intro-font-weight: {{ intro_font.weight }};
    --bs-intro-size-desktop: {{ section.settings.intro_size_desktop }}px;
    --bs-intro-size-mobile: {{ section.settings.intro_size_mobile }}px;
    --bs-intro-color: {{ section.settings.intro_color }};
    --bs-heading-font-family: {{ heading_font.family }}, {{ heading_font.fallback_families }};
    --bs-heading-font-style: {{ heading_font.style }};
    --bs-heading-size-desktop: {{ section.settings.heading_size_desktop }}px;
    --bs-heading-size-mobile: {{ section.settings.heading_size_mobile }}px;
    --bs-heading-weight: {{ section.settings.heading_weight }};
    --bs-heading-line-height: {{ section.settings.heading_line_height | divided_by: 100.0 }};
    --bs-heading-max-width: {{ section.settings.heading_max_width }}px;
    --bs-heading-color: {{ section.settings.heading_color }};
    --bs-body-font-family: {{ body_font.family }}, {{ body_font.fallback_families }};
    --bs-body-font-style: {{ body_font.style }};
    --bs-body-font-weight: {{ body_font.weight }};
    --bs-body-size-desktop: {{ section.settings.body_size_desktop }}px;
    --bs-body-size-mobile: {{ section.settings.body_size_mobile }}px;
    --bs-body-line-height: {{ section.settings.body_line_height | divided_by: 100.0 }};
    --bs-body-max-width: {{ section.settings.body_max_width }}px;
    --bs-body-color: {{ section.settings.body_color }};
    --bs-button-bg: {{ section.settings.button_background_color }};
    --bs-button-color: {{ section.settings.button_color }};
    --bs-button-hover-bg: {{ section.settings.button_hover_background_color }};
    --bs-button-hover-color: {{ section.settings.button_hover_color }};
  }
{%- endstyle -%}

<section
  class="brand-story section-{{ section.id }} brand-story--desktop-image-{{ section.settings.desktop_image_position }} brand-story--mobile-{{ section.settings.mobile_image_position }}"
  data-animation-enabled="{{ section.settings.enable_animations }}"
  data-animation-style="{{ section.settings.animation_style }}"
>
  <div class="brand-story__inner">
    <div class="brand-story__grid">
      <div class="brand-story__content brand-story__content--{{ section.settings.content_horizontal_alignment }} brand-story__content--mobile-{{ section.settings.mobile_content_alignment }}">
        <div class="brand-story__content-inner">
          {%- if section.settings.eyebrow != blank -%}
            <p class="brand-story__eyebrow">{{ section.settings.eyebrow }}</p>
          {%- endif -%}

          {%- if section.settings.intro_text != blank -%}
            <p class="brand-story__intro">{{ section.settings.intro_text }}</p>
          {%- endif -%}

          {%- if section.settings.heading != blank -%}
            <{{ heading_tag }} class="brand-story__heading">{{ section.settings.heading }}</{{ heading_tag }}>
          {%- endif -%}

          {%- if section.settings.body != blank -%}
            <div class="brand-story__body rte">
              {{ section.settings.body }}
            </div>
          {%- endif -%}

          {%- if section.settings.show_cta and section.settings.button_text != blank -%}
            <div class="brand-story__cta-wrap">
              <a
                class="{% if section.settings.button_style == 'link' %}brand-story__cta brand-story__cta--plain{% if section.settings.button_underline %} brand-story__cta--underlined{% endif %}{% else %}brand-story__cta button button--{{ section.settings.button_style }}{% endif %}"
                href="{{ section.settings.button_link | default: '#' }}"
              >
                <span>{{ section.settings.button_text }}</span>
                {%- if section.settings.button_show_arrow -%}
                  <span class="brand-story__cta-icon" aria-hidden="true">{% render 'icon-arrow' %}</span>
                {%- endif -%}
              </a>
            </div>
          {%- endif -%}
        </div>
      </div>

      <div class="brand-story__media">
        <div class="brand-story__image-frame{% if section.settings.image_shadow %} brand-story__image-frame--shadow{% endif %}">
          {%- if feature_image != blank -%}
            <picture>
              {%- if section.settings.mobile_image != blank -%}
                <source
                  media="(max-width: 749px)"
                  srcset="
                    {{ section.settings.mobile_image | image_url: width: 375 }} 375w,
                    {{ section.settings.mobile_image | image_url: width: 550 }} 550w,
                    {{ section.settings.mobile_image | image_url: width: 750 }} 750w,
                    {{ section.settings.mobile_image | image_url: width: 990 }} 990w
                  "
                  sizes="(max-width: 749px) calc(100vw - 36px), {{ section.settings.image_width }}vw"
                >
              {%- endif -%}
              {{
                feature_image
                | image_url: width: 1800
                | image_tag:
                  widths: '375, 550, 750, 990, 1200, 1500, 1800',
                  sizes: '(min-width: 990px) 45vw, calc(100vw - 36px)',
                  loading: 'lazy',
                  alt: image_alt,
                  class: 'brand-story__image'
              }}
            </picture>
          {%- else -%}
            {%- if section.settings.image_asset_filename != blank -%}
              {{ section.settings.image_asset_filename | asset_url | image_tag: loading: 'lazy', alt: image_alt, class: 'brand-story__image' }}
            {%- else -%}
              <div class="brand-story__placeholder">
                {% render 'media-placeholder-lifestyle', style: 2 %}
              </div>
            {%- endif -%}
          {%- endif -%}
        </div>
      </div>
    </div>
  </div>
</section>

{%- if section.settings.enable_animations and section.settings.animation_style != 'none' -%}
  <script>
    (() => {
      const section = document.querySelector('.section-{{ section.id }}');
      if (!section) return;
      const reveal = () => section.classList.add('is-visible');
      if (!('IntersectionObserver' in window)) {
        reveal();
        return;
      }
      const observer = new IntersectionObserver((entries) => {
        entries.forEach((entry) => {
          if (entry.isIntersecting) {
            reveal();
            observer.disconnect();
          }
        });
      }, { threshold: 0.2 });
      observer.observe(section);
    })();
  </script>
{%- endif -%}

{% schema %}
