#!/usr/bin/env zsh
set -euo pipefail

ROOT_DIR="${0:A:h}"
cd "$ROOT_DIR"

STORE="d68c2f-18.myshopify.com"
THEME_ID="162157330651"

case "${1:-}" in
  list)
    exec shopify theme list --store "$STORE"
    ;;
  pull)
    exec shopify theme pull --store "$STORE" --theme "$THEME_ID" --path "$ROOT_DIR" --nodelete
    ;;
  push)
    exec shopify theme push --store "$STORE" --theme "$THEME_ID" --path "$ROOT_DIR"
    ;;
  check)
    shift
    if (( $# > 0 )); then
      printf '%s\n' "Note: this Shopify CLI version does not support checking individual files; running the theme check for this folder."
    fi
    exec shopify theme check --path "$ROOT_DIR"
    ;;
  dev)
    exec shopify theme dev --store "$STORE" --theme "$THEME_ID" --path "$ROOT_DIR"
    ;;
  open)
    printf '%s\n' "Preview: https://$STORE?preview_theme_id=$THEME_ID"
    printf '%s\n' "Editor:  https://$STORE/admin/themes/$THEME_ID/editor"
    ;;
  *)
    cat <<'USAGE'
Usage: ./shopify-theme <command>

Commands:
  dev    Start local development against the June 3 draft theme.
  pull   Pull the June 3 draft theme into this folder.
  push   Push local changes to the June 3 draft theme only.
  check  Run Theme Check for this folder, using .theme-check.yml ignores.
  list   List store themes.
  open   Print preview and editor links for the June 3 draft theme.
USAGE
    ;;
esac
