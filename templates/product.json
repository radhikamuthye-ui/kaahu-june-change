            "item_2_fallback": "RJ",
            "item_2_title": "REGENERATIVE JUTE",
            "item_2_text": "<p>Our jute absorbs up to 15 tons of CO₂ per hectare to stay 100% carbon-negative — the ‘Golden Fibre’ that gives back more than it takes.</p>",
            "item_3_image": "shopify://shop_images/Cotton.svg",
            "item_3_fallback": "OC",
            "item_3_title": "CERTIFIED ORGANIC COTTON",
            "item_3_text": "<p>100% GOTS-certified organic cotton saves 91% more water than conventional crops — protecting our planet’s resources with every fibre.</p>",
            "item_4_image": "shopify://shop_images/reduce_waste.svg",
            "item_4_fallback": "RW",
            "item_4_title": "REDUCE WASTE",
            "item_4_text": "<p>Algae-based inks, water-activated tape and biodegradable packaging carry our commitment to zero waste down to every thoughtful detail.</p>",
            "open_by_default": false,
            "intro_bottom_spacing": 24,
            "row_gap": 24,
