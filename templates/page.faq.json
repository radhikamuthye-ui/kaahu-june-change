        "orders_cancel": {
          "type": "faq_item",
          "settings": {
            "category_number": "01",
            "category_title": "Orders & shipping",
            "category_anchor": "orders",
            "question": "Can I cancel or update my order?",
            "answer": "<p>You can cancel or update your order before it ships. Just email us at <a href=\"mailto:care@kaahu.us\">care@kaahu.us</a> with your order number. If your order has already shipped, we'll guide you through the return process.</p>"
          }
        },
        "orders_return": {
          "type": "faq_item",
          "settings": {
            "category_number": "01",
            "category_title": "Orders & shipping",
            "category_anchor": "orders",
            "question": "What is your return policy?",
            "answer": "<p>You have 90 days from delivery to initiate a return. Email us at <a href=\"mailto:care@kaahu.us\">care@kaahu.us</a> and we'll send you a return label. Your item should be:</p><ul><li>In original, unworn condition</li><li>With tags attached</li><li>In original packaging, including the dust bag</li></ul><p>Refunds are issued to the original method of payment once your return is received.</p>"
          }
        },
        "orders_exchanges": {
          "type": "faq_item",
          "settings": {
            "category_number": "01",
            "category_title": "Orders & shipping",
            "category_anchor": "orders",
            "question": "Do you offer exchanges?",
            "answer": "<p>We don't offer exchanges after an order has shipped. If you'd like a different item, place a new order and return the original.</p>"
          }
        },
        "orders_status": {
          "type": "faq_item",
          "settings": {
            "category_number": "01",
            "category_title": "Orders & shipping",
            "category_anchor": "orders",
            "question": "How can I check my order status?",
            "answer": "<p>You can track your order anytime from the <strong>Order History</strong> section of your account. For help, email us at <a href=\"mailto:care@kaahu.us\">care@kaahu.us</a>.</p>"
          }
        },
        "orders_international": {
          "type": "faq_item",
          "settings": {
            "category_number": "01",
            "category_title": "Orders & shipping",
            "category_anchor": "orders",
            "question": "Do you ship internationally?",
            "answer": "<p>We currently ship within the United States, excluding the following territories:</p><ul><li>Micronesia</li><li>Guam</li><li>Marshall Islands</li><li>Palau</li><li>U.S. Virgin Islands</li></ul><p>We're working toward international shipping soon.</p>"
          }
        },
        "orders_timing": {
          "type": "faq_item",
          "settings": {
            "category_number": "01",
            "category_title": "Orders & shipping",
            "category_anchor": "orders",
            "question": "How long will my order take to arrive?",
            "answer": "<p>With free shipping, orders typically arrive within <strong>5-8 business days</strong>.</p>"
          }
        },
        "materials_kaahu": {
          "type": "faq_item",
          "settings": {
            "category_number": "02",
            "category_title": "Product & materials",
            "category_anchor": "materials",
            "question": "What is Kaahu?",
            "answer": "<p>Kaahu is rooted in the Hawaiian idea of a guardian - someone who walks alongside, not ahead. We design bags that reflect care, connection, and craft.</p>"
          }
        },
        "materials_sustainable": {
          "type": "faq_item",
          "settings": {
            "category_number": "02",
            "category_title": "Product & materials",
            "category_anchor": "materials",
            "question": "What makes Kaahu sustainable?",
            "answer": "<p>We work with natural fibers like jute, organic cotton, and juco. Our production is low-waste, labor-conscious, and built to last. Through our partnership with 1% for the Planet, a portion of every sale goes toward environmental work around the world.</p>"
          }
        },
