            "title": "",
            "heading_top_margin": 5,
            "heading_margin": 5,
            "text": "<p>By using algae-based inks, water-activated tape, and biodegradable packaging, we ensure our commitment to reducing waste extends to every thoughtful detail.</p>",
            "block_btn_style": "link--underlined",
            "link_label": "",
            "link": ""
          }
        },
        "column_PyxbQE": {
